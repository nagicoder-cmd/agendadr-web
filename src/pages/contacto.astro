<script>
  // ── Custom Select ──────────────────────────────────────────
  const customSelect  = document.getElementById('custom-select') as HTMLElement;
  const dropdown      = document.getElementById('select-dropdown') as HTMLUListElement;
  const selectDisplay = document.getElementById('select-display') as HTMLSpanElement;
  const hiddenInput   = document.getElementById('tipo') as HTMLInputElement;

  function openSelect() {
    customSelect.classList.add('is-open');
    customSelect.setAttribute('aria-expanded', 'true');
  }
  function closeSelect() {
    customSelect.classList.remove('is-open');
    customSelect.setAttribute('aria-expanded', 'false');
  }
  function toggleSelect() {
    customSelect.classList.contains('is-open') ? closeSelect() : openSelect();
  }

  customSelect?.addEventListener('click', (e) => {
    // Don't toggle when clicking an option (handled separately)
    if ((e.target as HTMLElement).closest('.select-option')) return;
    toggleSelect();
  });

  customSelect?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleSelect(); }
    if (e.key === 'Escape') closeSelect();
  });

  dropdown?.querySelectorAll<HTMLLIElement>('.select-option').forEach((option) => {
    option.addEventListener('click', () => {
      const value = option.dataset.value ?? '';
      const icon  = option.querySelector('.opt-icon')?.innerHTML ?? '';
      const label = option.querySelector('span:last-child')?.textContent ?? '';

      // Update hidden input
      hiddenInput.value = value;

      // Update display: show icon + label (no placeholder)
      selectDisplay.innerHTML = `<span class="opt-icon" style="width:20px;display:flex;align-items:center;color:#03BB85">${icon}</span><span style="font-size:14px">${label}</span>`;

      // Mark selected
      dropdown.querySelectorAll('.select-option').forEach(o => o.classList.remove('is-selected'));
      option.classList.add('is-selected');

      closeSelect();
    });
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!customSelect?.contains(e.target as Node)) closeSelect();
  });

  // ── Contact Form ───────────────────────────────────────────
  const form    = document.getElementById('contact-form') as HTMLFormElement;
  const status  = document.getElementById('form-status') as HTMLParagraphElement;
  const btn     = document.getElementById('btn-submit') as HTMLButtonElement;
  const btnText = btn?.querySelector('.btn-text') as HTMLSpanElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btnText.textContent = 'Enviando...';
    status.className = 'form-status';
    status.textContent = '';

    try {
      // TODO: conectar a webhook / API
      await new Promise((r) => setTimeout(r, 1200));
      status.textContent = '✓ Mensaje enviado. Te contactamos pronto.';
      form.reset();
      // Reset custom select display
      selectDisplay.innerHTML = '<span class="select-placeholder">Selecciona una opción</span>';
      hiddenInput.value = '';
      dropdown?.querySelectorAll('.select-option').forEach(o => o.classList.remove('is-selected'));
    } catch {
      status.className = 'form-status error';
      status.textContent = 'Error al enviar. Intenta por WhatsApp.';
    } finally {
      btn.disabled = false;
      btnText.textContent = 'Enviar mensaje';
    }
  });
</script>
