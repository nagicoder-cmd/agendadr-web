---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout
  title="Contacto | AgendaDr"
  description="Contáctanos por WhatsApp, email o formulario. Te respondemos en menos de 2 horas en días hábiles."
  keywords={['contacto agendadr', 'soporte software médico']}
>
  <Header />

  <main>
    <div class="contact-page">

      <!-- Columna izquierda -->
      <div class="contact-info">
        <p class="label">Contacto</p>
        <h1 class="h1 title">¿Tienes preguntas?<br />Hablemos.</h1>
        <p class="subtitle">
          Escríbenos por WhatsApp, manda un email o llena el formulario.
          Te respondemos en menos de 2 horas en días hábiles.
        </p>

        <div class="channels">
          <!-- WhatsApp -->
          <div class="channel">
            <div class="channel-icon icon-green">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <div class="channel-name">
                WhatsApp
                <span class="badge">Principal</span>
              </div>
              <p class="channel-meta">Lunes a viernes · 9am – 6pm</p>
              <a href="https://wa.me/51XXXXXXXXX" class="channel-link">Escríbenos →</a>
            </div>
          </div>

          <div class="divider"></div>

          <!-- Email -->
          <div class="channel">
            <div class="channel-icon icon-gray">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <div>
              <div class="channel-name">Email</div>
              <a href="mailto:soporte@agendadr.com" class="channel-link">soporte@agendadr.com</a>
              <p class="channel-meta">Respuesta en menos de 24 h.</p>
            </div>
          </div>
        </div>

        <p class="company-data">ECOGIROS NEGOCIOS E.I.R.L. · RUC 20612344567 · Perú</p>
      </div>

      <!-- Columna derecha: formulario -->
      <div class="contact-form-col">
        <form id="contact-form" novalidate>

          <div class="form-row">
            <div class="form-group">
              <label for="nombre">Nombre</label>
              <input type="text" id="nombre" name="nombre" placeholder="Tu nombre completo" required autocomplete="name" />
            </div>
            <div class="form-group">
              <label for="telefono">Teléfono</label>
              <input type="tel" id="telefono" name="telefono" placeholder="+51 999 999 999" autocomplete="tel" />
            </div>
          </div>

          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="tu@email.com" required autocomplete="email" />
          </div>

          <div class="form-group">
            <label for="tipo">Tipo de consulta</label>
            <select id="tipo" name="tipo" required>
              <option value="" disabled selected>Selecciona una opción</option>
              <option value="ventas">Ventas</option>
              <option value="soporte">Soporte técnico</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div class="form-group">
            <label for="mensaje">Mensaje</label>
            <textarea id="mensaje" name="mensaje" rows="5" placeholder="Cuéntanos en qué podemos ayudarte..." required></textarea>
          </div>

          <button type="submit" class="btn-submit">Enviar mensaje</button>
          <p id="form-status"></p>

        </form>

        <!-- FAQ -->
        <div class="faq">
          <p class="faq-title">Preguntas frecuentes</p>

          <details class="faq-item">
            <summary>
              ¿Cuánto tardan en responder?
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p>Por WhatsApp, menos de 2 horas en horario laboral. Por email, menos de 24 horas.</p>
          </details>

          <details class="faq-item">
            <summary>
              ¿Puedo pedir una demo antes de comprar?
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p>Sí. Agenda una demo en <a href="/demo">agendadr.com/demo</a> y te mostramos el sistema en vivo.</p>
          </details>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  main {
    background: #ffffff;
    min-height: 100vh;
  }

  :global(html.dark) main {
    background: #0f172a;
  }

  .contact-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 120px 24px 96px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  @media (max-width: 768px) {
    .contact-page {
      grid-template-columns: 1fr;
      gap: 48px;
      padding: 100px 20px 64px;
    }
  }

  /* ── Info columna ── */
  .label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #03BB85;
    margin-bottom: 16px;
  }

  .title {
    color: #0f172a;
    margin-bottom: 20px;
  }

  :global(html.dark) .title {
    color: #f1f5f9;
  }

  .subtitle {
    font-size: 17px;
    line-height: 1.7;
    color: #64748b;
    margin-bottom: 48px;
  }

  :global(html.dark) .subtitle {
    color: #94a3b8;
  }

  /* Canales */
  .channels {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .channel {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px 0;
  }

  .channel-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .icon-green {
    background: rgba(3, 187, 133, 0.1);
    color: #03BB85;
  }

  .icon-gray {
    background: #f1f5f9;
    color: #64748b;
  }

  :global(html.dark) .icon-gray {
    background: #1e293b;
    color: #94a3b8;
  }

  .channel-name {
    font-size: 15px;
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  :global(html.dark) .channel-name {
    color: #f1f5f9;
  }

  .badge {
    font-size: 11px;
    font-weight: 600;
    background: rgba(3, 187, 133, 0.1);
    color: #03BB85;
    padding: 2px 8px;
    border-radius: 999px;
  }

  .channel-meta {
    font-size: 13px;
    color: #94a3b8;
    margin-bottom: 6px;
  }

  .channel-link {
    font-size: 14px;
    font-weight: 500;
    color: #03BB85;
    text-decoration: none;
    transition: color 0.15s;
  }

  .channel-link:hover {
    color: #02a676;
  }

  .divider {
    height: 1px;
    background: #f1f5f9;
  }

  :global(html.dark) .divider {
    background: #1e293b;
  }

  .company-data {
    font-size: 12px;
    color: #cbd5e1;
    margin-top: 40px;
    padding-top: 24px;
    border-top: 1px solid #f1f5f9;
  }

  :global(html.dark) .company-data {
    color: #334155;
    border-top-color: #1e293b;
  }

  /* ── Formulario ── */
  form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 480px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  label {
    font-size: 13px;
    font-weight: 500;
    color: #475569;
  }

  :global(html.dark) label {
    color: #94a3b8;
  }

  input, select, textarea {
    width: 100%;
    padding: 12px 14px;
    font-size: 14px;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    background: #ffffff;
    color: #0f172a;
    transition: border-color 0.15s, box-shadow 0.15s;
    outline: none;
    font-family: inherit;
    box-sizing: border-box;
  }

  :global(html.dark) input,
  :global(html.dark) select,
  :global(html.dark) textarea {
    background: #1e293b;
    border-color: #334155;
    color: #f1f5f9;
  }

  input::placeholder, textarea::placeholder {
    color: #94a3b8;
  }

  input:focus, select:focus, textarea:focus {
    border-color: #03BB85;
    box-shadow: 0 0 0 3px rgba(3, 187, 133, 0.12);
  }

  textarea {
    resize: vertical;
    min-height: 120px;
  }

  .btn-submit {
    width: 100%;
    padding: 13px;
    background: #03BB85;
    color: white;
    font-size: 15px;
    font-weight: 600;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.15s, transform 0.1s;
    font-family: inherit;
  }

  .btn-submit:hover {
    background: #02a676;
  }

  .btn-submit:active {
    transform: scale(0.99);
  }

  .btn-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  #form-status {
    font-size: 13px;
    text-align: center;
    color: #16a34a;
    min-height: 20px;
  }

  /* ── FAQ ── */
  .faq {
    margin-top: 40px;
    border-top: 1px solid #f1f5f9;
    padding-top: 32px;
  }

  :global(html.dark) .faq {
    border-top-color: #1e293b;
  }

  .faq-title {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #94a3b8;
    margin-bottom: 16px;
  }

  .faq-item {
    border-bottom: 1px solid #f1f5f9;
  }

  :global(html.dark) .faq-item {
    border-bottom-color: #1e293b;
  }

  .faq-item summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 0;
    font-size: 14px;
    font-weight: 500;
    color: #1e293b;
    cursor: pointer;
    list-style: none;
    gap: 12px;
  }

  :global(html.dark) .faq-item summary {
    color: #e2e8f0;
  }

  .faq-item summary svg {
    flex-shrink: 0;
    color: #94a3b8;
    transition: transform 0.2s;
  }

  .faq-item[open] summary svg {
    transform: rotate(180deg);
  }

  .faq-item p {
    font-size: 14px;
    color: #64748b;
    line-height: 1.6;
    padding: 0 0 14px;
  }

  :global(html.dark) .faq-item p {
    color: #94a3b8;
  }

  .faq-item a {
    color: #03BB85;
    text-decoration: none;
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLParagraphElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('.btn-submit') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Enviando...';

    // TODO: conectar a webhook
    await new Promise((r) => setTimeout(r, 1000));

    status.textContent = '✓ Mensaje enviado. Te contactamos pronto.';
    form.reset();
    btn.disabled = false;
    btn.textContent = 'Enviar mensaje';
  });
</script>
