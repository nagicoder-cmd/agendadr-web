---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout
  title="Contacto | AgendaDr"
  description="Contáctanos por WhatsApp, email o formulario. Te respondemos en menos de 2 horas en días hábiles."
  keywords={['contacto agendadr', 'soporte software médico']}
>
  <Header />

  <main>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <h1 class="hero-title">¿En qué podemos<br />ayudarte?</h1>
        <p class="hero-sub">
          Cuéntanos lo que necesitas y te orientamos sin compromiso.<br class="hide-mobile" />
          Atención real, en español, por el equipo AgendaDr.
        </p>
        <div class="trust-pills">
          <span class="pill">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Sin bots, atención real
          </span>
          <span class="pill">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            Sin spam ni llamadas
          </span>
          <span class="pill">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Lunes a viernes · 9am – 6pm
          </span>
        </div>

        <!-- Stats inline -->
        <div class="hero-stats-row">
          <div class="inline-stat">
            <span class="inline-stat-value">+500</span>
            <span class="inline-stat-desc">Médicos confían en AgendaDr</span>
          </div>
          <div class="inline-stat-sep"></div>
          <div class="inline-stat">
            <span class="inline-stat-value">100%</span>
            <span class="inline-stat-desc">Atención en español</span>
          </div>
          <div class="inline-stat-sep"></div>
          <div class="inline-stat">
            <span class="inline-stat-value">14 días</span>
            <span class="inline-stat-desc">Prueba gratis sin tarjeta</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Body: canales + formulario -->
    <section class="body-section">
      <div class="body-inner">

        <!-- Columna izquierda: canales -->
        <div class="col-left">

          <!-- Canal WhatsApp -->
          <a href="https://wa.me/51999999999" class="channel-card channel-wsp" target="_blank" rel="noopener noreferrer">
            <div class="channel-icon-wrap icon-wsp">
              <svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div class="channel-body">
              <div class="channel-top">
                <span class="channel-name">WhatsApp</span>
                <span class="channel-badge badge-green">Más rápido</span>
              </div>
              <p class="channel-desc">Lunes a viernes · 9am – 6pm</p>
              <span class="channel-action">Escríbenos ahora →</span>
            </div>
          </a>

          <!-- Canal Email -->
          <a href="mailto:soporte@agendadr.com" class="channel-card">
            <div class="channel-icon-wrap icon-gray">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <div class="channel-body">
              <div class="channel-top">
                <span class="channel-name">Email</span>
              </div>
              <p class="channel-desc">soporte@agendadr.com</p>
              <span class="channel-action">Respuesta en &lt; 24 h →</span>
            </div>
          </a>

          <!-- Canal Demo -->
          <a href="/demo" class="channel-card">
            <div class="channel-icon-wrap icon-primary">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/>
              </svg>
            </div>
            <div class="channel-body">
              <div class="channel-top">
                <span class="channel-name">Demo en vivo</span>
                <span class="channel-badge badge-teal">Gratis</span>
              </div>
              <p class="channel-desc">Te mostramos el sistema en 20 minutos</p>
              <span class="channel-action">Agendar demo →</span>
            </div>
          </a>

          <!-- Info legal + horarios -->
          <div class="info-box">
            <div class="info-row">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span>Lima, Perú</span>
            </div>
            <div class="info-row">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
              <span>ECOGIROS NEGOCIOS E.I.R.L. · RUC 20612344567</span>
            </div>
          </div>

          <!-- Card garantías -->
          <div class="garantias-card">
            <p class="garantias-title">Lo que puedes esperar</p>
            <ul class="garantias-list">
              <li>
                <span class="garantia-icon">✓</span>
                <span>Respuesta personalizada, no genérica</span>
              </li>
              <li>
                <span class="garantia-icon">✓</span>
                <span>Demo gratuita sin compromiso de compra</span>
              </li>
              <li>
                <span class="garantia-icon">✓</span>
                <span>Soporte incluido en todos los planes</span>
              </li>
              <li>
                <span class="garantia-icon">✓</span>
                <span>Onboarding guiado para tu clínica</span>
              </li>
            </ul>
          </div>

        </div>

        <!-- Columna derecha: formulario -->
        <div class="col-right">
          <div class="form-card">
            <div class="form-card-header">
              <p class="form-card-title">Envíanos un mensaje</p>
              <p class="form-card-sub">Te respondemos a la brevedad</p>
            </div>

            <form id="contact-form" novalidate>

              <div class="form-row">
                <div class="form-group">
                  <label for="nombre">Nombre completo <span class="required">*</span></label>
                  <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required autocomplete="name" />
                </div>
                <div class="form-group">
                  <label for="telefono">Teléfono</label>
                  <div class="phone-wrap">
                    <span class="phone-prefix">
                      <svg width="20" height="14" viewBox="0 0 20 14" xmlns="http://www.w3.org/2000/svg" aria-label="Perú" role="img">
                        <rect width="20" height="14" rx="2" fill="#D91023"/>
                        <rect x="6.5" width="7" height="14" fill="#F5F5F5"/>
                      </svg>
                    </span>
                    <input type="tel" id="telefono" name="telefono" placeholder="999 999 999" autocomplete="tel" class="phone-input" />
                  </div>
                </div>
              </div>

              <div class="form-group">
                <label for="email">Email <span class="required">*</span></label>
                <input type="email" id="email" name="email" placeholder="tu@email.com" required autocomplete="email" />
              </div>

              <div class="form-group">
                <label>Tipo de consulta <span class="required">*</span></label>
                <!-- Hidden input para el valor real -->
                <input type="hidden" id="tipo" name="tipo" required />
                <div class="custom-select" id="custom-select" role="combobox" aria-expanded="false" aria-haspopup="listbox" tabindex="0">
                  <div class="custom-select-trigger">
                    <span class="custom-select-value" id="select-display">
                      <span class="select-placeholder">Selecciona una opción</span>
                    </span>
                    <svg class="select-chevron" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                  </div>
                  <ul class="custom-select-dropdown" role="listbox" id="select-dropdown">
                    <li class="select-option" data-value="demo" role="option">
                      <span class="opt-icon"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></span>
                      <span>Quiero una demo gratuita</span>
                    </li>
                    <li class="select-option" data-value="ventas" role="option">
                      <span class="opt-icon"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></span>
                      <span>Información y precios</span>
                    </li>
                    <li class="select-option" data-value="soporte" role="option">
                      <span class="opt-icon"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg></span>
                      <span>Soporte técnico</span>
                    </li>
                    <li class="select-option" data-value="facturacion" role="option">
                      <span class="opt-icon"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/></svg></span>
                      <span>Facturación</span>
                    </li>
                    <li class="select-option" data-value="partnership" role="option">
                      <span class="opt-icon"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg></span>
                      <span>Partnership / alianzas</span>
                    </li>
                    <li class="select-option" data-value="otro" role="option">
                      <span class="opt-icon"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg></span>
                      <span>Otro</span>
                    </li>
                  </ul>
                </div>
              </div>

              <div class="form-group">
                <label for="mensaje">Mensaje <span class="required">*</span></label>
                <textarea id="mensaje" name="mensaje" rows="4" placeholder="Cuéntanos en qué podemos ayudarte..." required></textarea>
              </div>

              <button type="submit" class="btn-submit" id="btn-submit">
                <span class="btn-text">Enviar mensaje</span>
                <svg class="btn-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
              </button>

              <p id="form-status" class="form-status"></p>

            </form>
          </div>

        </div>
      </div>
    </section>

    <!-- FAQ sección propia -->
    <section class="faq-section">
      <div class="faq-inner">
        <div class="faq-header">
          <span class="faq-section-label">Preguntas frecuentes</span>
          <h2 class="faq-section-title">Resolvemos tus dudas</h2>
          <p class="faq-section-sub">¿No encuentras lo que buscas? <a href="https://wa.me/51999999999" target="_blank" rel="noopener">Escríbenos por WhatsApp →</a></p>
        </div>
        <div class="faq-grid">

          <details class="faq-item">
            <summary>
              ¿Cuánto tardan en responder?
              <svg class="faq-chevron" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p>Por WhatsApp, menos de 2 horas en horario laboral (L–V 9am–6pm). Por email, menos de 24 horas.</p>
          </details>

          <details class="faq-item">
            <summary>
              ¿Puedo pedir una demo antes de comprar?
              <svg class="faq-chevron" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p>Sí. <a href="/demo">Agenda una demo gratuita</a> y te mostramos el sistema en vivo en 20 minutos, sin compromiso.</p>
          </details>

          <details class="faq-item">
            <summary>
              ¿Tienen soporte en español?
              <svg class="faq-chevron" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p>100% en español. Nuestro equipo está en Lima y conoce la realidad de las clínicas peruanas.</p>
          </details>

          <details class="faq-item">
            <summary>
              ¿Hay costo adicional por el soporte?
              <svg class="faq-chevron" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p>No. El soporte está incluido en todos los planes sin costo adicional.</p>
          </details>

          <details class="faq-item">
            <summary>
              ¿Ofrecen capacitación para mi equipo?
              <svg class="faq-chevron" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p>Sí. Incluimos onboarding guiado para que tú y tu equipo puedan usar AgendaDr desde el primer día.</p>
          </details>

          <details class="faq-item">
            <summary>
              ¿Puedo cancelar cuando quiera?
              <svg class="faq-chevron" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p>Sí. No hay contratos de permanencia. Puedes cancelar tu suscripción en cualquier momento sin penalidades.</p>
          </details>

        </div>
      </div>
    </section>

      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  main {
    background: var(--bg-page);
    min-height: 100vh;
  }

  /* ── Hero ── */
  .hero {
    background: var(--bg-page);
    border-bottom: 1px solid var(--border-subtle);
    padding-top: calc(40px + 64px);
  }
  @media (max-width: 767px) {
    .hero { padding-top: calc(48px + 64px); }
  }

  .hero-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 64px 24px 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  @media (max-width: 767px) {
    .hero-inner { padding: 40px 20px 36px; }
  }
  .trust-pills { justify-content: center; }

  /* Stats inline row */
  .hero-stats-row {
    display: flex;
    align-items: center;
    gap: 0;
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid var(--border-subtle);
    width: 100%;
  }
  @media (max-width: 767px) {
    .hero-stats-row { justify-content: center; gap: 0; }
  }

  .inline-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }
  @media (max-width: 767px) {
    .inline-stat { align-items: center; }
  }

  .inline-stat-value {
    font-family: 'Cal Sans', Inter, sans-serif;
    font-size: 26px;
    font-weight: 700;
    color: #03BB85;
    line-height: 1;
  }
  .inline-stat-value:has(+ .inline-stat-desc) {
    /* emoji stat — mismo tamaño visual */
  }
  .inline-stat:last-child .inline-stat-value {
    font-size: 22px; /* emoji se ve más grande, lo compenso */
  }

  .inline-stat-desc {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.4;
  }

  .inline-stat-sep {
    width: 1px;
    height: 40px;
    background: var(--border-default);
    flex-shrink: 0;
    margin: 0 32px;
  }
  @media (max-width: 500px) {
    .inline-stat-sep { margin: 0 16px; }
    .inline-stat-value { font-size: 20px; }
  }

  .hero-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #03BB85;
    margin-bottom: 14px;
    display: block;
  }

  .hero-title {
    font-family: 'Cal Sans', Inter, sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 600;
    color: var(--text-heading);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 18px;
  }

  .hero-sub {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-tertiary);
    margin-bottom: 32px;
    max-width: 520px;
  }
  .hero-sub strong { color: var(--text-heading); font-weight: 600; }

  .hide-mobile { display: inline; }
  @media (max-width: 767px) { .hide-mobile { display: none; } }

  /* Trust pills */
  .trust-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  @media (max-width: 767px) { .trust-pills { justify-content: center; } }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-tertiary);
    background: var(--bg-subtle);
    border: 1px solid var(--border-default);
    border-radius: 999px;
    padding: 5px 12px;
  }
  .pill svg { color: #03BB85; flex-shrink: 0; }

  /* ── Body section ── */
  .body-section {
    background: var(--bg-page);
  }

  .body-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 64px 24px 96px;
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 56px;
    align-items: start;
  }
  @media (max-width: 900px) {
    .body-inner {
      grid-template-columns: 1fr;
      gap: 48px;
