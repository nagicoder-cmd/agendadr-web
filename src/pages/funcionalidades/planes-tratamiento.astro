---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---
<BaseLayout title="Planes de tratamiento | AgendaDr" description="Crea y gestiona planes de tratamiento para tus pacientes. Seguimiento sesión a sesión.">
  <Header />
  <main class="scaffold">
    <h1 class="h1">Planes de tratamiento</h1>
  </main>
  <Footer />
</BaseLayout>
<style>
  .scaffold { background:#fff; min-height:100vh; padding:140px 24px 96px; max-width:1100px; margin:0 auto; }
  :global(html.dark) .scaffold { background:#0f172a; }
</style>
