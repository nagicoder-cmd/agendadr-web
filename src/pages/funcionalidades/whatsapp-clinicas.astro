---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---
<BaseLayout
  title="CRM WhatsApp para clínicas | Convierte mensajes en citas | AgendaDr"
  description="CRM WhatsApp para clínicas integrado en el panel. Pipeline de leads, recordatorios automáticos, métricas de conversión y ROI por campaña Meta Ads."
>
  <Header />
  <main>

    <!-- ═══════════════════════════════════════════
         SECCIÓN 1 — HERO
    ════════════════════════════════════════════ -->
    <section class="hero-section">
      <div class="container">
        <div class="hero-badge">
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          CRM WhatsApp para clínicas
        </div>
        <h1 class="hero-headline">Convierte mensajes de WhatsApp en citas.<br class="desktop-br"> Sin doble trabajo.</h1>
        <p class="hero-sub">
          AgendaDr conecta el WhatsApp Business de tu clínica directo al panel de tu recepcionista. Los mensajes llegan, se responden y se convierten en citas agendadas — todo sin abrir otra app. Con métricas reales de cuántos leads se convierten en pacientes.
        </p>
        <div class="hero-actions">
          <a href="https://app.agendadr.com/registro" class="btn-primary">Empieza ahora →</a>
          <a href="/planes" class="btn-ghost">Ver planes</a>
        </div>

        <!-- MOCKUP PLACEHOLDER -->
        <div class="mockup-wrapper">
          <div class="mockup-browser">
            <div class="mockup-bar">
              <span class="dot dot-red"></span>
              <span class="dot dot-yellow"></span>
              <span class="dot dot-green"></span>
              <span class="mockup-url">app.agendadr.com · CRM WhatsApp</span>
            </div>
            <div class="mockup-screen">
              <!-- TODO: replace with real screenshot of WhatsApp CRM inbox panel -->
              <div class="mockup-hint">
                <svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                <span>Bandeja de conversaciones WhatsApp</span>
                <small>Todos los leads en un panel · Ordenados por urgencia</small>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         SECCIÓN 2 — EL PROBLEMA
    ════════════════════════════════════════════ -->
    <section class="problem-section anim-fade-up">
      <div class="container">
        <div class="problem-header">
          <h2>El 90% de tus pacientes nuevos llegan por WhatsApp.<br class="desktop-br"> ¿Y tú cómo los gestionas?</h2>
          <p>La realidad de la mayoría de clínicas en Perú:</p>
        </div>
        <div class="problem-flow">
          <div class="flow-step">
            <span class="flow-num">1</span>
            <p>Inviertes en Meta Ads (Instagram, Facebook)</p>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-step">
            <span class="flow-num">2</span>
            <p>El lead hace clic y cae a WhatsApp</p>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-step">
            <span class="flow-num">3</span>
            <p>Tu recepcionista contesta desde su celular personal</p>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-step bad">
            <span class="flow-num">4</span>
            <p>Anota el nombre en un cuaderno o Excel</p>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-step bad">
            <span class="flow-num">5</span>
            <p>Si no cierra la cita hoy, el lead se pierde entre 200 chats</p>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-step bad">
            <span class="flow-num">6</span>
            <p>Cuando por fin agenda, registra manualmente en otro sistema</p>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-step bad">
            <span class="flow-num">7</span>
            <p>El dueño no sabe cuántos leads entraron ni cuántos cerraron</p>
          </div>
        </div>
        <div class="problem-callout">
          <strong>Doble trabajo siempre. Cero métricas. Leads perdidos todos los días.</strong>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         SECCIÓN 3 — LA SOLUCIÓN
    ════════════════════════════════════════════ -->
    <section class="solution-section anim-fade-up">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">La solución</span>
          <h2>Con AgendaDr, WhatsApp vive dentro del sistema.</h2>
        </div>
        <div class="solution-steps">
          <div class="sol-step anim-item">
            <div class="sol-icon">
              <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
            </div>
            <div class="sol-content">
              <h3>El paciente escribe por WhatsApp</h3>
              <p>Ya sea por tu publicidad en Meta Ads, Google, tu Instagram o porque un amigo le pasó tu número.</p>
            </div>
          </div>
          <div class="sol-connector"></div>
          <div class="sol-step anim-item">
            <div class="sol-icon">
              <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 9h6M9 12h6M9 15h4"/></svg>
            </div>
            <div class="sol-content">
              <h3>El mensaje llega al panel de tu recepcionista</h3>
              <p>No a su celular personal. Al panel de AgendaDr. Con nombre, hora del mensaje y todo el historial de conversación.</p>
            </div>
          </div>
          <div class="sol-connector"></div>
          <div class="sol-step anim-item">
            <div class="sol-icon">
              <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <div class="sol-content">
              <h3>Responde desde el panel</h3>
              <p>Tu recepcionista contesta, usa respuestas rápidas predefinidas y resuelve dudas — sin abrir WhatsApp en el celular.</p>
            </div>
          </div>
          <div class="sol-connector"></div>
          <div class="sol-step anim-item">
            <div class="sol-icon green">
              <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <div class="sol-content">
              <h3>Agenda la cita con 1 clic</h3>
              <p>Desde la misma conversación, botón "Agendar cita". El lead se convierte en paciente registrado + cita agendada. Cero doble trabajo.</p>
            </div>
          </div>
          <div class="sol-connector"></div>
          <div class="sol-step anim-item">
            <div class="sol-icon">
              <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <div class="sol-content">
              <h3>Tú ves todo</h3>
              <p>Como administrador, ves cuántos leads entraron, cuántos se convirtieron en citas, y cuánto te costó cada paciente nuevo.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         SECCIÓN 4 — QUÉ INCLUYE EL CRM
    ════════════════════════════════════════════ -->
    <section class="features-section anim-fade-up">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">Funcionalidades</span>
          <h2>No es solo WhatsApp. Es un CRM completo.</h2>
        </div>
        <div class="crm-grid">
          <div class="crm-card anim-item">
            <div class="crm-icon">
              <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <h3>Bandeja de conversaciones</h3>
            <p>Todas las conversaciones en un solo panel. Badge con mensajes sin leer. Ordenadas por más reciente, sin responder o con seguimiento pendiente.</p>
          </div>
          <div class="crm-card anim-item">
            <div class="crm-icon">
              <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <h3>Respuestas rápidas</h3>
            <p>Plantillas predefinidas para precios, disponibilidad y especialidades. Con variables automáticas: nombre, doctor, fecha y hora. Tu recepcionista responde en 5 segundos.</p>
          </div>
          <div class="crm-card anim-item">
            <div class="crm-icon">
              <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <h3>Agendar desde el chat</h3>
            <p>Botón "Agendar cita" dentro de la conversación. Al confirmar, el lead ya es paciente registrado con cita en la agenda del doctor. Cero registro manual.</p>
          </div>
          <div class="crm-card anim-item pro-badge-card">
            <div class="pro-tag">Plan Profesional</div>
            <div class="crm-icon">
              <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h8m-8 4h4"/></svg>
            </div>
            <h3>Pipeline de leads</h3>
            <p>Vista visual: Nuevo → En conversación → Cita agendada → Asistió → Perdido. Arrastra y suelta. Filtra por estado, origen o especialidad.</p>
          </div>
          <div class="crm-card anim-item pro-badge-card">
            <div class="pro-tag">Plan Profesional</div>
            <div class="crm-icon">
              <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3>Seguimientos programados</h3>
            <p>Si un lead dice "después te confirmo", programa un seguimiento. Tu recepcionista recibe una alerta a esa hora. Nunca más se pierde un lead.</p>
          </div>
          <div class="crm-card anim-item pro-badge-card">
            <div class="pro-tag">Plan Profesional</div>
            <div class="crm-icon">
              <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <h3>Métricas de conversión</h3>
            <p>Total de leads, tasa de conversión, tiempo de primera respuesta, tiempo de cierre, rendimiento por recepcionista y leads por campaña.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         SECCIÓN 5 — TABLA CRM BÁSICO vs COMPLETO
    ════════════════════════════════════════════ -->
    <section class="compare-section anim-fade-up">
      <div class="container">
        <div class="section-header">
          <h2>Dos versiones según lo que necesites</h2>
        </div>
        <div class="table-wrapper">
          <table class="compare-table">
            <thead>
              <tr>
                <th>Funcionalidad</th>
                <th>CRM Básico<br><small>Individual &amp; Básico</small></th>
                <th class="highlight-col">CRM Completo<br><small>Profesional+</small></th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Bandeja de conversaciones</td>
                <td><span class="check">✅</span></td>
                <td class="highlight-col"><span class="check">✅</span></td>
              </tr>
              <tr>
                <td>Respuestas rápidas</td>
                <td><span class="check">✅</span></td>
                <td class="highlight-col"><span class="check">✅</span></td>
              </tr>
              <tr>
                <td>Agendar desde el chat</td>
                <td><span class="check">✅</span></td>
                <td class="highlight-col"><span class="check">✅</span></td>
              </tr>
              <tr>
                <td>Pipeline visual de leads</td>
                <td><span class="dash">—</span></td>
                <td class="highlight-col"><span class="check">✅</span></td>
              </tr>
              <tr>
                <td>Seguimientos programados</td>
                <td><span class="dash">—</span></td>
                <td class="highlight-col"><span class="check">✅</span></td>
              </tr>
              <tr>
                <td>Asignación por recepcionista</td>
                <td><span class="dash">—</span></td>
                <td class="highlight-col"><span class="check">✅</span></td>
              </tr>
              <tr>
                <td>Métricas de conversión</td>
                <td><span class="dash">—</span></td>
                <td class="highlight-col"><span class="check">✅</span></td>
              </tr>
              <tr>
                <td>ROI por campaña Meta Ads</td>
                <td><span class="dash">—</span></td>
                <td class="highlight-col"><span class="check">✅</span></td>
              </tr>
              <tr>
                <td>Rendimiento por recepcionista</td>
                <td><span class="dash">—</span></td>
                <td class="highlight-col"><span class="check">✅</span></td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="compare-cta">
          <a href="/planes" class="btn-outline">Ver todos los planes →</a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         SECCIÓN 6 — PARA EL DUEÑO
    ════════════════════════════════════════════ -->
    <section class="owner-section anim-fade-up">
      <div class="container">
        <div class="owner-grid">
          <div class="owner-content">
            <span class="section-tag">Para el dueño de la clínica</span>
            <h2>Por fin sabes cuánto te cuesta cada paciente nuevo.</h2>
            <p>Como administrador, ves un dashboard con las métricas que importan:</p>
            <ul class="owner-metrics">
              <li>
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#03BB85" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                Cuántos leads entraron esta semana
              </li>
              <li>
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#03BB85" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                Cuántos se convirtieron en citas
              </li>
              <li>
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#03BB85" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                Cuánto tiempo tardó tu recepcionista en responder
              </li>
              <li>
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#03BB85" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                Qué campaña de Meta Ads trajo más citas
              </li>
              <li>
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#03BB85" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                Qué recepcionista cierra más
              </li>
              <li>
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#03BB85" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                Motivo más frecuente de pérdida de leads
              </li>
            </ul>
            <p class="owner-claim">Esto no lo tiene ningún otro software médico en Perú. Punto.</p>
          </div>
          <div class="owner-visual">
            <!-- MOCKUP PLACEHOLDER -->
            <div class="mockup-browser small">
              <div class="mockup-bar">
                <span class="dot dot-red"></span>
                <span class="dot dot-yellow"></span>
                <span class="dot dot-green"></span>
                <span class="mockup-url">app.agendadr.com · Dashboard ROI</span>
              </div>
              <div class="mockup-screen">
                <!-- TODO: replace with real screenshot of lead conversion dashboard -->
                <div class="mockup-hint">
                  <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                  <span>Dashboard de conversión</span>
                  <small>ROI por campaña · Leads · Cierres</small>
                </div>
              </div>
            </div>
            <div class="kpi-chips">
              <div class="kpi-chip">
                <span class="kpi-val">35%</span>
                <span class="kpi-label">Tasa de conversión</span>
              </div>
              <div class="kpi-chip">
                <span class="kpi-val">&lt;2 min</span>
                <span class="kpi-label">Tiempo de respuesta</span>
              </div>
              <div class="kpi-chip">
                <span class="kpi-val">S/28</span>
                <span class="kpi-label">Costo por paciente</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         SECCIÓN 7 — RECORDATORIOS AUTOMÁTICOS
    ════════════════════════════════════════════ -->
    <section class="reminders-section anim-fade-up">
      <div class="container">
        <div class="reminders-card">
          <div class="reminders-icon">
            <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
          </div>
          <div class="reminders-content">
            <h2>También enviamos recordatorios automáticos.</h2>
            <p>Además del CRM, AgendaDr envía recordatorios de cita por WhatsApp a tus pacientes. Configura cuántas horas antes quieres que llegue el recordatorio. El paciente confirma, cancela o reagenda con un clic. Menos inasistencias, menos huecos en la agenda.</p>
          </div>
          <div class="reminders-stat">
            <span class="stat-num">-60%</span>
            <span class="stat-label">inasistencias</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         SECCIÓN 8 — VS LA COMPETENCIA
    ════════════════════════════════════════════ -->
    <section class="vs-section anim-fade-up">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">Comparativa</span>
          <h2>Nadie en Perú tiene un CRM de WhatsApp así.</h2>
        </div>
        <div class="table-wrapper">
          <table class="compare-table vs-table">
            <thead>
              <tr>
                <th>Funcionalidad</th>
                <th class="highlight-col">AgendaDr</th>
                <th>Doctocliq</th>
                <th>AgendaPro</th>
                <th>WhatsApp manual</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Bandeja WhatsApp en el panel</td>
                <td class="highlight-col"><span class="check">✅</span></td>
                <td><span class="cross">❌</span></td>
                <td><span class="cross">❌</span></td>
                <td><span class="cross-note">❌ celular</span></td>
              </tr>
              <tr>
                <td>Agendar cita desde el chat</td>
                <td class="highlight-col"><span class="check">✅ 1 clic</span></td>
                <td><span class="cross">❌</span></td>
                <td><span class="cross">❌</span></td>
                <td><span class="cross-note">❌ manual</span></td>
              </tr>
              <tr>
                <td>Pipeline visual de leads</td>
                <td class="highlight-col"><span class="check">✅</span></td>
                <td><span class="cross">❌</span></td>
                <td><span class="cross">❌</span></td>
                <td><span class="cross">❌</span></td>
              </tr>
              <tr>
                <td>Métricas de conversión</td>
