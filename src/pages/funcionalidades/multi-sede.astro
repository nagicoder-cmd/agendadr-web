---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---

<BaseLayout
  title="Gestión multi-sede para clínicas | AgendaDr"
  description="Gestiona múltiples sedes de tu clínica desde un solo dashboard. Reportes consolidados, doctores compartidos y CRM unificado. Plan Clínica S/599/mes."
  keywords={['software múltiples sedes clínica', 'gestión multi-sede', 'sistema varias clínicas', 'cadena centros médicos']}
>
  <Header />

  <main>

    <!-- ── HERO ── -->
    <section class="hero">
      <div class="hero-inner">

        <div class="hero-text anim-fade-up">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Inicio</a>
            <span aria-hidden="true">›</span>
            <a href="/funcionalidades">Funcionalidades</a>
            <span aria-hidden="true">›</span>
            <span>Multi-sede</span>
          </nav>
          <div class="hero-badge">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Multi-sede
          </div>
          <h1 class="hero-title">Dos sedes, tres sedes,<br />diez sedes. Un solo sistema.</h1>
          <p class="hero-sub">
            ¿Tu clínica creció y ahora tienes más de una ubicación? Con AgendaDr gestionas todas tus sedes
            desde un solo dashboard. Reportes consolidados o por sede, doctores compartidos,
            y una sola fuente de verdad.
          </p>
          <div class="hero-actions">
            <a href="/contacto" class="btn-primary">
              Contáctanos
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="/planes" class="btn-secondary">Ver plan Clínica</a>
          </div>
          <p class="hero-plan-note">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            Disponible desde el plan Clínica · S/599/mes
          </p>
        </div>

        <div class="hero-visual anim-fade-up" style="--delay:0.1s" aria-hidden="true">
          <!-- TODO: replace with real screenshot of multi-sede dashboard -->
          <div class="mockup-placeholder">
            <div class="mp-browser-bar">
              <span class="mp-dot mp-dot--red"></span>
              <span class="mp-dot mp-dot--yellow"></span>
              <span class="mp-dot mp-dot--green"></span>
              <div class="mp-url">AgendaDr · Dashboard multi-sede</div>
            </div>
            <div class="mp-body">
              <div class="mp-screen-hint">
                <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color:#03BB85;opacity:0.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <p>Vista consolidada de sedes</p>
                <span>Próximamente screenshot real</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ── EL PROBLEMA ── -->
    <section class="section section--alt">
      <div class="container container--narrow">
        <div class="section-head anim-fade-up">
          <span class="section-label">El problema</span>
          <h2 class="section-title">Más sedes = más caos.<br />A menos que tengas el sistema correcto.</h2>
        </div>
        <div class="problem-copy anim-fade-up" style="--delay:0.08s">
          <p>
            Cuando abres una segunda sede, todo se duplica: otra agenda, otra recepcionista, otros números,
            otro WhatsApp. De pronto tienes 2 Excels, 2 cuadernos, y 2 versiones diferentes
            de cómo va el negocio.
          </p>
          <p class="problem-callout">
            El doctor que trabaja en las 2 sedes tiene su agenda dividida. Los reportes no se consolidan.
            Y tú pasas más tiempo juntando información que tomando decisiones.
          </p>
        </div>
      </div>
    </section>

    <!-- ── LA SOLUCIÓN ── -->
    <section class="section">
      <div class="container">
        <div class="section-head anim-fade-up">
          <span class="section-label">La solución</span>
          <h2 class="section-title">Todas tus sedes, un solo AgendaDr.</h2>
        </div>
        <div class="solution-grid">
          {[
            {
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
              title: 'Dashboard consolidado',
              desc: 'Ve los KPIs de todas tus sedes juntas: ingresos totales, citas totales, ocupación global. O filtra por sede para ver cada una por separado.',
              delay: '0s',
            },
            {
              icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
              title: 'Doctores compartidos',
              desc: 'Un doctor puede atender en sede A los lunes y en sede B los miércoles. El sistema gestiona su disponibilidad por ubicación. Sin conflictos de agenda.',
              delay: '0.08s',
            },
            {
              icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
              title: 'Reportes por sede o consolidados',
              desc: 'Cuánto facturó cada sede, qué sede tiene mejor tasa de conversión, dónde están los huecos. Todo exportable.',
              delay: '0.16s',
            },
            {
              icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
              title: 'CRM unificado',
              desc: 'Los leads de todas las sedes llegan a un solo CRM. Asigna cada lead a la sede que le queda más cerca o a la que tiene disponibilidad.',
              delay: '0.24s',
            },
            {
              icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
              title: 'Un paciente, un historial',
              desc: 'Si un paciente se atiende en la sede A y luego va a la sede B, su historial médico es el mismo. No empieza de cero.',
              delay: '0.32s',
            },
          ].map((s) => (
            <div class="solution-card anim-fade-up" style={`--delay:${s.delay}`}>
              <div class="sol-icon">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={s.icon}/>
                </svg>
              </div>
              <div>
                <h3 class="sol-title">{s.title}</h3>
                <p class="sol-desc">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── PLANES ── -->
    <section class="section section--alt">
      <div class="container">
        <div class="section-head anim-fade-up">
          <span class="section-label">Planes recomendados</span>
          <h2 class="section-title">Elige según cuánto has crecido.</h2>
        </div>
        <div class="plans-grid anim-fade-up" style="--delay:0.08s">

          <div class="plan-card plan-card--featured">
            <div class="plan-badge">Más popular para multi-sede</div>
            <div class="plan-head">
              <span class="plan-name">Clínica</span>
              <div class="plan-price">
                <span class="plan-currency">S/</span>
                <span class="plan-amount">599</span>
                <span class="plan-per">/mes</span>
              </div>
              <p class="plan-tagline">Para clínicas con varias sedes y equipo grande.</p>
            </div>
            <ul class="plan-features">
              {[
                '15 doctores incluidos',
                '5 recepcionistas',
                'Multi-sede sin límite',
                'Reportes consolidados',
                'CRM unificado',
                'Soporte prioritario',
              ].map((f) => (
                <li>
                  <svg width="14" height="14" fill="none" stroke="#03BB85" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="https://app.agendadr.com/registro" class="plan-cta plan-cta--primary">Empezar ahora</a>
          </div>

          <div class="plan-card">
            <div class="plan-head">
              <span class="plan-name">Enterprise</span>
              <div class="plan-price plan-price--custom">
                <span class="plan-amount plan-amount--custom">Cotizar</span>
              </div>
              <p class="plan-tagline">Para cadenas de clínicas y redes médicas grandes.</p>
            </div>
            <ul class="plan-features">
              {[
                'Doctores ilimitados',
                'Sedes ilimitadas',
                'API e integraciones custom',
                'Onboarding dedicado',
                'SLA garantizado',
                'Facturación personalizada',
              ].map((f) => (
                <li>
                  <svg width="14" height="14" fill="none" stroke="#03BB85" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="/contacto" class="plan-cta plan-cta--secondary">Contáctanos</a>
          </div>

        </div>
      </div>
    </section>

    <!-- ── FAQ ── -->
    <section class="section">
      <div class="container container--narrow">
        <div class="section-head anim-fade-up">
          <span class="section-label">FAQ</span>
          <h2 class="section-title">Preguntas sobre multi-sede</h2>
        </div>
        <div class="faq-list anim-fade-up" style="--delay:0.08s">
          {[
            {
              q: '¿Cuántas sedes puedo tener?',
              a: 'El plan Clínica permite múltiples sedes. El plan Enterprise es ilimitado. Contáctanos si tienes más de 5 sedes para evaluar la mejor opción.',
            },
            {
              q: '¿Cada sede tiene su propio portal de agendamiento?',
              a: 'Sí. Cada sede tiene su URL propia (app.agendadr.com/clinica-sede-norte) con su propia configuración de doctores y horarios.',
            },
            {
              q: '¿Puedo ver reportes separados por sede?',
              a: 'Sí. Puedes ver reportes consolidados (todas las sedes juntas) o filtrar por sede específica. Todo exportable.',
            },
          ].map((item) => (
            <div class="faq-item">
              <button class="faq-q" aria-expanded="false">
                <span>{item.q}</span>
                <svg class="faq-chevron" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="faq-a">
                <p>{item.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── CTA FINAL ── -->
    <section class="cta-final">
      <div class="cta-blob cta-blob--1" aria-hidden="true"></div>
      <div class="cta-blob cta-blob--2" aria-hidden="true"></div>
      <div class="cta-blob cta-blob--3" aria-hidden="true"></div>
      <div class="cta-inner anim-fade-up">
        <h2 class="cta-title">Crece sin límites.<br />Tu sistema crece contigo.</h2>
        <p class="cta-sub">¿Ya tienes más de una sede o estás planeando abrir otra? Hablemos.</p>
        <div class="cta-actions">
          <a href="/contacto" class="btn-primary btn--lg">
            Contáctanos
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="/planes" class="btn-outline">Ver planes →</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  main { background: var(--bg-page); }

  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  .container--narrow { max-width: 760px; }
  .section { padding: 88px 24px; }
  .section--alt { background: var(--bg-subtle); }
  @media (max-width: 767px) { .section { padding: 60px 16px; } }

  .section-label {
    display: block; font-size: 12px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: #03BB85; margin-bottom: 12px;
  }
  .section-head { text-align: center; margin-bottom: 56px; }
  .section-title {
    font-family: 'Cal Sans', Inter, sans-serif;
    font-size: clamp(1.7rem, 4vw, 2.5rem);
    font-weight: 600; color: var(--text-heading);
    line-height: 1.15; letter-spacing: -0.03em; margin: 0 0 14px;
  }
  .section-sub { font-size: 16px; color: var(--text-muted); max-width: 540px; margin: 0 auto; line-height: 1.7; }

  /* ── Buttons ── */
  .btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 13px 24px; background: #03BB85; color: #0f172a;
    font-size: 15px; font-weight: 700; border-radius: 10px;
    text-decoration: none; transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
    box-shadow: 0 2px 12px rgba(3,187,133,0.35); white-space: nowrap;
  }
  .btn-primary:hover { background: #02a676; transform: translateY(-1px); box-shadow: 0 4px 18px rgba(3,187,133,0.45); }
  .btn-primary.btn--lg { padding: 15px 32px; font-size: 16px; }
  .btn-secondary {
    display: inline-flex; align-items: center;
    padding: 13px 20px; background: transparent; color: var(--text-secondary);
    font-size: 15px; font-weight: 600; text-decoration: none; border-radius: 10px;
    border: 1.5px solid var(--border-default); transition: border-color 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .btn-secondary:hover { border-color: #03BB85; color: #03BB85; }
  .btn-outline {
    display: inline-flex; align-items: center;
    padding: 15px 28px; background: transparent; color: #ffffff;
    font-size: 15px; font-weight: 600; text-decoration: none; border-radius: 10px;
    border: 2px solid rgba(255,255,255,0.4); transition: border-color 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .btn-outline:hover { border-color: rgba(255,255,255,0.8); background: rgba(255,255,255,0.07); }

  /* ── Animations ── */
  .anim-fade-up {
    opacity: 0; transform: translateY(28px);
    transition: opacity 0.55s cubic-bezier(0.22,1,0.36,1), transform 0.55s cubic-bezier(0.22,1,0.36,1);
    transition-delay: var(--delay, 0s);
  }
  .anim-fade-up.visible { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) { .anim-fade-up { transition: none; opacity: 1; transform: none; } }

  /* ── Hero ── */
  .hero {
    background: var(--bg-page); border-bottom: 1px solid var(--border-subtle);
    padding-top: calc(40px + 64px); overflow: hidden; position: relative;
  }
  @media (max-width: 767px) { .hero { padding-top: calc(48px + 56px); } }
  .hero::before {
    content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 1000px; height: 480px;
    background: radial-gradient(ellipse at 50% 0%, rgba(3,187,133,0.08) 0%, transparent 68%);
    pointer-events: none;
  }
  :global(html.dark) .hero::before {
    background: radial-gradient(ellipse at 50% 0%, rgba(3,187,133,0.12) 0%, transparent 68%);
  }
  .hero-inner {
    max-width: 1100px; margin: 0 auto; padding: 64px 24px 80px;
    display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center;
    position: relative; z-index: 1;
  }
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 40px; padding: 48px 20px 60px; }
    .hero-visual { display: none; }
  }
  @media (max-width: 767px) { .hero-inner { padding: 36px 16px 48px; } }

  .breadcrumb {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; color: var(--text-muted); margin-bottom: 20px; flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--text-muted); text-decoration: none; transition: color 0.15s; }
  .breadcrumb a:hover { color: #03BB85; }
  .breadcrumb span[aria-hidden] { color: var(--border-default); }
  .breadcrumb span:not([aria-hidden]) { color: var(--text-secondary); font-weight: 500; }

  .hero-badge {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: 12px; font-weight: 600; color: var(--text-secondary);
    background: var(--bg-subtle); border: 1px solid var(--border-default);
    border-radius: 999px; padding: 5px 12px; margin-bottom: 20px;
  }
  .hero-title {
    font-family: 'Cal Sans', Inter, sans-serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 600; color: var(--text-heading); line-height: 1.1; letter-spacing: -0.035em; margin: 0 0 20px;
  }
  .hero-sub { font-size: 17px; line-height: 1.75; color: var(--text-tertiary); margin: 0 0 32px; }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; margin-bottom: 16px; }
  .hero-plan-note {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; color: var(--text-muted); margin: 0;
  }
  .hero-plan-note svg { color: #03BB85; flex-shrink: 0; }

  /* ── Mockup placeholder ── */
  .mockup-placeholder {
    background: var(--bg-subtle); border: 1.5px solid var(--border-default);
    border-radius: 12px; overflow: hidden; box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }
  :global(html.dark) .mockup-placeholder { box-shadow: 0 12px 40px rgba(0,0,0,0.25); }
  .mp-browser-bar {
    display: flex; align-items: center; gap: 6px; padding: 9px 12px;
    background: var(--bg-page); border-bottom: 1px solid var(--border-default);
  }
  .mp-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .mp-dot--red { background: #ff5f57; }
  .mp-dot--yellow { background: #febc2e; }
  .mp-dot--green { background: #28c840; }
  .mp-url {
    flex: 1; font-size: 11px; color: var(--text-muted);
    background: var(--bg-subtle); border-radius: 6px; padding: 3px 10px; text-align: center;
  }
  .mp-body { min-height: 220px; display: flex; align-items: center; justify-content: center; }
  .mp-screen-hint {
    text-align: center; padding: 32px 24px;
    display: flex; flex-direction: column; align-items: center; gap: 10px;
  }
  .mp-screen-hint p { font-size: 14px; font-weight: 600; color: var(--text-secondary); margin: 0; }
  .mp-screen-hint span {
    font-size: 12px; color: var(--text-muted);
    background: rgba(3,187,133,0.08); border: 1px dashed rgba(3,187,133,0.3);
    border-radius: 6px; padding: 4px 10px;
  }

  /* ── Problem copy ── */
  .problem-copy { display: flex; flex-direction: column; gap: 16px; max-width: 640px; margin: 0 auto; text-align: center; }
  .problem-copy p { font-size: 17px; line-height: 1.8; color: var(--text-secondary); margin: 0; }
  .problem-callout { font-weight: 700 !important; color: var(--text-heading) !important; }

  /* ── Solution grid (horizontal cards) ── */
  .solution-grid { display: flex; flex-direction: column; gap: 16px; }

  .solution-card {
    display: flex; align-items: flex-start; gap: 20px;
    background: var(--bg-subtle); border: 1px solid var(--border-default);
    border-radius: 16px; padding: 24px 28px;
    transition: border-color 0.2s;
  }
  .solution-card:hover { border-color: rgba(3,187,133,0.4); }
  .sol-icon {
    width: 44px; height: 44px; border-radius: 12px; flex-shrink: 0;
    background: rgba(3,187,133,0.1); color: #03BB85;
    display: flex; align-items: center; justify-content: center;
  }
  .sol-title { font-size: 15px; font-weight: 700; color: var(--text-heading); margin: 0 0 6px; }
  .sol-desc { font-size: 14px; line-height: 1.65; color: var(--text-muted); margin: 0; }
  @media (max-width: 520px) { .solution-card { padding: 20px; } }

  /* ── Plans ── */
  .plans-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 24px; max-width: 720px; margin: 0 auto;
  }
  @media (max-width: 600px) { .plans-grid { grid-template-columns: 1fr; } }

  .plan-card {
    background: var(--bg-page); border: 1.5px solid var(--border-default);
    border-radius: 20px; padding: 32px 28px;
    display: flex; flex-direction: column; gap: 20px; position: relative;
    transition: border-color 0.2s;
  }
  .plan-card:hover { border-color: rgba(3,187,133,0.4); }
  .plan-card--featured {
    border-color: #03BB85;
    box-shadow: 0 0 0 4px rgba(3,187,133,0.1);
  }
  .plan-badge {
    position: absolute; top: -13px; left: 50%; transform: translateX(-50%);
    background: #03BB85; color: #0f172a;
    font-size: 11px; font-weight: 700; padding: 3px 14px;
    border-radius: 999px; white-space: nowrap;
  }
  .plan-head { display: flex; flex-direction: column; gap: 6px; }
  .plan-name { font-size: 13px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; }
  .plan-price { display: flex; align-items: baseline; gap: 3px; }
  .plan-currency { font-size: 1rem; font-weight: 700; color: var(--text-heading); line-height: 1; }
  .plan-amount {
