  .cta-blob--1 { width: 300px; height: 300px; background: rgba(255,255,255,0.15); top: -80px; left: -60px; }
  .cta-blob--2 { width: 200px; height: 200px; background: rgba(255,255,255,0.1); bottom: -40px; right: 10%; }
  .cta-blob--3 { width: 150px; height: 150px; background: rgba(2,50,36,0.3); top: 30%; right: -40px; }
</style>

<script>
  const obs = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    }),
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.anim-fade-up').forEach((el) => obs.observe(el));

  document.querySelectorAll('.faq-q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.faq-q').forEach((b) => {
        b.setAttribute('aria-expanded', 'false');
        (b.nextElementSibling as HTMLElement).style.maxHeight = '0';
      });
      if (!expanded) {
        btn.setAttribute('aria-expanded', 'true');
        const panel = btn.nextElementSibling as HTMLElement;
        panel.style.maxHeight = panel.scrollHeight + 'px';
      }
    });
  });
</script>
