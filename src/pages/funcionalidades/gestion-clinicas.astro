---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---

<BaseLayout
  title="Software de gestión para clínicas en Perú | AgendaDr"
  description="Dashboard de gestión de clínicas en tiempo real. KPIs, roles y permisos, catálogo de servicios y control total desde una sola pantalla. Desde S/49/mes."
  keywords={['software gestión clínicas perú', 'administrar clínica', 'gestión administrativa clínica', 'sistema gestión médica']}
>
  <Header />

  <main>

    <!-- ── HERO ── -->
    <section class="hero">
      <div class="hero-inner">

        <div class="hero-text anim-fade-up">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Inicio</a>
            <span aria-hidden="true">›</span>
            <a href="/funcionalidades">Funcionalidades</a>
            <span aria-hidden="true">›</span>
            <span>Gestión de clínicas</span>
          </nav>
          <div class="hero-badge">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
            Gestión de clínicas
          </div>
          <h1 class="hero-title">El control total de tu clínica.<br />En una sola pantalla.</h1>
          <p class="hero-sub">
            AgendaDr te da un dashboard donde ves citas del día, ingresos, ocupación por doctor,
            leads del CRM y comisiones — todo en tiempo real. Deja de perseguir información
            y empieza a tomar decisiones con datos.
          </p>
          <div class="hero-actions">
            <a href="https://app.agendadr.com/registro" class="btn-primary">
              Empieza ahora
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="/planes" class="btn-secondary">Ver planes</a>
          </div>
          <p class="hero-guarantee">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            Garantía 15 días · Desde S/49/mes · Sin contrato
          </p>
        </div>

        <div class="hero-visual anim-fade-up" style="--delay:0.1s" aria-hidden="true">
          <!-- TODO: replace with real screenshot of the admin dashboard -->
          <div class="mockup-placeholder">
            <div class="mp-browser-bar">
              <span class="mp-dot mp-dot--red"></span>
              <span class="mp-dot mp-dot--yellow"></span>
              <span class="mp-dot mp-dot--green"></span>
              <div class="mp-url">AgendaDr · Dashboard de administración</div>
            </div>
            <div class="mp-body">
              <div class="mp-screen-hint">
                <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color:#03BB85;opacity:0.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <p>Dashboard principal</p>
                <span>Próximamente screenshot real</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ── EL PROBLEMA ── -->
    <section class="section section--alt">
      <div class="container container--narrow">
        <div class="section-head anim-fade-up">
          <span class="section-label">El problema</span>
          <h2 class="section-title">Tu clínica genera datos todo el día. Tú no ves ninguno.</h2>
        </div>
        <div class="problem-copy anim-fade-up" style="--delay:0.08s">
          <p>
            Cuántas citas hubo hoy, cuánto se facturó, qué doctor está libre, cuántos leads llegaron,
            qué pacientes cancelaron. Toda esa información existe pero está repartida entre el cuaderno
            de la recepcionista, el Excel de pagos y el WhatsApp de todos.
          </p>
          <p class="problem-callout">
            Cuando quieres saber "cómo va la clínica", tienes que preguntar a 3 personas y esperar a fin de mes. Para entonces ya es tarde para actuar.
          </p>
        </div>
      </div>
    </section>

    <!-- ── QUÉ GESTIONAS ── -->
    <section class="section">
      <div class="container">
        <div class="section-head anim-fade-up">
          <span class="section-label">Qué gestionas</span>
          <h2 class="section-title">Todo tu negocio médico, organizado.</h2>
        </div>
        <div class="manage-grid">
          {[
            {
              icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
              title: 'Doctores',
              desc: 'Agrega, edita y desactiva doctores. Asigna especialidades, horarios y porcentaje de comisión. Cada doctor tiene su propio panel.',
              delay: '0s',
            },
            {
              icon: 'M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Recepcionistas',
              desc: 'Crea cuentas con los permisos adecuados. Gestiona la agenda, atiende pacientes, cobra y responde WhatsApp desde un solo panel.',
              delay: '0.06s',
            },
            {
              icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
              title: 'Especialidades y servicios',
              desc: 'Configura las especialidades de tu clínica con sus servicios, precios y duración de consulta. Catálogo controlado por ti.',
              delay: '0.12s',
            },
            {
              icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
              title: 'Pacientes',
              desc: 'Base de datos completa. Busca, filtra, ve historial y exporta. Cada paciente tiene su ficha con todo el historial clínico.',
              delay: '0.18s',
            },
            {
              icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Finanzas',
              desc: 'Ingresos del día, semana o mes. Desglose por doctor con comisiones. Pagos por método (Yape, Plin, tarjeta, efectivo). La caja cuadra sola.',
              delay: '0.24s',
            },
            {
              icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
              title: 'Configuración',
              desc: 'Logo, nombre, dirección, colores de tu portal, datos fiscales para SUNAT. Todo personalizable desde el panel.',
              delay: '0.30s',
            },
          ].map((m) => (
            <div class="manage-card anim-fade-up" style={`--delay:${m.delay}`}>
              <div class="manage-icon">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={m.icon}/>
                </svg>
              </div>
              <h3 class="manage-title">{m.title}</h3>
              <p class="manage-desc">{m.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── DASHBOARD ── -->
    <section class="section section--alt">
      <div class="container">
        <div class="dashboard-inner anim-fade-up">
          <div class="dashboard-text">
            <span class="section-label">Dashboard</span>
            <h2 class="dashboard-title">Abre AgendaDr y sabes cómo va tu clínica. Al instante.</h2>
            <p class="dashboard-desc">
              No necesitas esperar a fin de mes para saber cómo va el negocio. Cada vez que abres AgendaDr,
              tienes la foto completa. Y si algo no está bien, lo ves a tiempo para actuar.
            </p>
            <div class="kpi-grid">
              {[
                { label: 'Citas del día',        sub: 'Atendidas, pendientes, canceladas' },
                { label: 'Ingresos',             sub: 'Por día, semana o mes' },
                { label: 'Ocupación por doctor', sub: 'En tiempo real' },
                { label: 'Tasa de cancelación',  sub: 'Tendencia por período' },
                { label: 'Leads del CRM',        sub: 'Nuevos y en seguimiento' },
                { label: 'Comisiones',           sub: 'Acumuladas por doctor' },
              ].map((k) => (
                <div class="kpi-card">
                  <svg width="14" height="14" fill="none" stroke="#03BB85" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                  <div>
                    <span class="kpi-label">{k.label}</span>
                    <span class="kpi-sub">{k.sub}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="dashboard-visual" aria-hidden="true">
            <!-- TODO: replace with real screenshot of the KPI dashboard -->
            <div class="mockup-placeholder">
              <div class="mp-browser-bar">
                <span class="mp-dot mp-dot--red"></span>
                <span class="mp-dot mp-dot--yellow"></span>
                <span class="mp-dot mp-dot--green"></span>
                <div class="mp-url">AgendaDr · KPIs en tiempo real</div>
              </div>
              <div class="mp-body">
                <div class="mp-screen-hint">
                  <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color:#03BB85;opacity:0.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                  <p>Vista de KPIs</p>
                  <span>Próximamente screenshot real</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── ROLES Y PERMISOS ── -->
    <section class="section">
      <div class="container">
        <div class="section-head anim-fade-up">
          <span class="section-label">Roles y permisos</span>
          <h2 class="section-title">Cada quien ve lo que le toca.</h2>
          <p class="section-sub">No todos necesitan ver todo. En AgendaDr, cada perfil tiene acceso solo a lo que necesita.</p>
        </div>
        <div class="roles-grid">
          {[
            {
              role: 'Admin / Dueño',
              icon: 'M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z',
              highlight: true,
              perms: ['Dashboard completo', 'Finanzas y comisiones', 'CRM de WhatsApp', 'Configuración total', 'Gestión de usuarios'],
              denied: [],
            },
            {
              role: 'Doctor',
              icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
              highlight: false,
              perms: ['Su agenda personal', 'Sus pacientes', 'Historia clínica', 'Emitir recetas'],
              denied: ['Comisiones', 'Finanzas generales'],
            },
            {
              role: 'Recepcionista',
              icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
              highlight: false,
              perms: ['Agenda general', 'Gestión de pacientes', 'Cobros y pagos', 'CRM de WhatsApp'],
              denied: ['Comisiones', 'Configuración avanzada'],
            },
            {
              role: 'Paciente',
              icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z',
              highlight: false,
              perms: ['Sus citas', 'Sus recetas', 'Su plan de tratamiento'],
              denied: ['Datos de otros pacientes', 'Panel administrativo'],
            },
          ].map((r) => (
            <div class={`role-card${r.highlight ? ' role-card--admin' : ''} anim-fade-up`}>
              {r.highlight && <span class="role-badge">Acceso completo</span>}
              <div class="role-icon">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={r.icon}/>
                </svg>
              </div>
              <h3 class="role-name">{r.role}</h3>
              <ul class="role-perms">
                {r.perms.map((p) => (
                  <li class="perm-allow">
                    <svg width="13" height="13" fill="none" stroke="#03BB85" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                    </svg>
                    {p}
                  </li>
                ))}
                {r.denied.map((d) => (
                  <li class="perm-deny">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="opacity:0.35" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                    {d}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── FAQ ── -->
    <section class="section section--alt">
      <div class="container container--narrow">
        <div class="section-head anim-fade-up">
          <span class="section-label">FAQ</span>
          <h2 class="section-title">Preguntas sobre gestión de clínicas</h2>
        </div>
        <div class="faq-list anim-fade-up" style="--delay:0.08s">
          {[
            {
              q: '¿Puedo tener más de un admin?',
              a: 'Sí. Puedes crear cuentas de admin adicionales si tienes socios o gerentes que necesitan acceso completo.',
            },
            {
              q: '¿Puedo ver los datos desde mi celular?',
              a: 'Sí. AgendaDr funciona en cualquier dispositivo con navegador. Abres tu dashboard desde el celular y ves tus KPIs al instante.',
            },
            {
              q: '¿Cuántos usuarios puedo tener?',
              a: 'Depende de tu plan. Desde 1 doctor + 1 recepcionista (Individual) hasta ilimitados (Enterprise).',
            },
          ].map((item) => (
            <div class="faq-item">
              <button class="faq-q" aria-expanded="false">
                <span>{item.q}</span>
                <svg class="faq-chevron" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="faq-a">
                <p>{item.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── CTA FINAL ── -->
    <section class="cta-final">
      <div class="cta-blob cta-blob--1" aria-hidden="true"></div>
      <div class="cta-blob cta-blob--2" aria-hidden="true"></div>
      <div class="cta-blob cta-blob--3" aria-hidden="true"></div>
      <div class="cta-inner anim-fade-up">
        <h2 class="cta-title">Gestiona tu clínica con datos,<br />no con intuición.</h2>
        <p class="cta-sub">Planes desde S/49 al mes. Dashboard en tiempo real, roles y permisos, todo bajo tu control.</p>
        <div class="cta-actions">
          <a href="https://app.agendadr.com/registro" class="btn-primary btn--lg">
            Empieza ahora
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="/planes" class="btn-outline">Ver planes →</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  main { background: var(--bg-page); }

  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  .container--narrow { max-width: 760px; }
  .section { padding: 88px 24px; }
  .section--alt { background: var(--bg-subtle); }
  @media (max-width: 767px) { .section { padding: 60px 16px; } }

  .section-label {
    display: block; font-size: 12px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: #03BB85; margin-bottom: 12px;
  }
  .section-head { text-align: center; margin-bottom: 56px; }
  .section-title {
    font-family: 'Cal Sans', Inter, sans-serif;
    font-size: clamp(1.7rem, 4vw, 2.5rem);
    font-weight: 600; color: var(--text-heading);
    line-height: 1.15; letter-spacing: -0.03em; margin: 0 0 14px;
  }
  .section-sub { font-size: 16px; color: var(--text-muted); max-width: 540px; margin: 0 auto; line-height: 1.7; }

  /* ── Buttons ── */
  .btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 13px 24px; background: #03BB85; color: #0f172a;
    font-size: 15px; font-weight: 700; border-radius: 10px;
    text-decoration: none; transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
    box-shadow: 0 2px 12px rgba(3,187,133,0.35); white-space: nowrap;
  }
  .btn-primary:hover { background: #02a676; transform: translateY(-1px); box-shadow: 0 4px 18px rgba(3,187,133,0.45); }
  .btn-primary.btn--lg { padding: 15px 32px; font-size: 16px; }
  .btn-secondary {
    display: inline-flex; align-items: center;
    padding: 13px 20px; background: transparent; color: var(--text-secondary);
    font-size: 15px; font-weight: 600; text-decoration: none; border-radius: 10px;
    border: 1.5px solid var(--border-default); transition: border-color 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .btn-secondary:hover { border-color: #03BB85; color: #03BB85; }
  .btn-outline {
    display: inline-flex; align-items: center;
    padding: 15px 28px; background: transparent; color: #ffffff;
    font-size: 15px; font-weight: 600; text-decoration: none; border-radius: 10px;
    border: 2px solid rgba(255,255,255,0.4); transition: border-color 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .btn-outline:hover { border-color: rgba(255,255,255,0.8); background: rgba(255,255,255,0.07); }

  /* ── Animations ── */
  .anim-fade-up {
    opacity: 0; transform: translateY(28px);
    transition: opacity 0.55s cubic-bezier(0.22,1,0.36,1), transform 0.55s cubic-bezier(0.22,1,0.36,1);
    transition-delay: var(--delay, 0s);
  }
  .anim-fade-up.visible { opacity: 1; transform: translateY(0); }
  .anim-item {
    opacity: 0; transform: translateY(20px);
    transition: opacity 0.45s cubic-bezier(0.22,1,0.36,1), transform 0.45s cubic-bezier(0.22,1,0.36,1);
    transition-delay: calc(var(--i, 0) * 0.08s);
  }
  .anim-item.visible { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) {
    .anim-fade-up, .anim-item { transition: none; opacity: 1; transform: none; }
  }

  /* ── Hero ── */
  .hero {
    background: var(--bg-page); border-bottom: 1px solid var(--border-subtle);
    padding-top: calc(40px + 64px); overflow: hidden; position: relative;
  }
  @media (max-width: 767px) { .hero { padding-top: calc(48px + 56px); } }
  .hero::before {
    content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 1000px; height: 480px;
    background: radial-gradient(ellipse at 50% 0%, rgba(3,187,133,0.08) 0%, transparent 68%);
    pointer-events: none;
  }
  :global(html.dark) .hero::before {
    background: radial-gradient(ellipse at 50% 0%, rgba(3,187,133,0.12) 0%, transparent 68%);
  }
  .hero-inner {
    max-width: 1100px; margin: 0 auto; padding: 64px 24px 80px;
    display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center;
    position: relative; z-index: 1;
  }
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 40px; padding: 48px 20px 60px; }
    .hero-visual { display: none; }
  }
  @media (max-width: 767px) { .hero-inner { padding: 36px 16px 48px; } }

  .breadcrumb {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; color: var(--text-muted); margin-bottom: 20px; flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--text-muted); text-decoration: none; transition: color 0.15s; }
  .breadcrumb a:hover { color: #03BB85; }
