---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---
<BaseLayout title="Gestión de clínicas | AgendaDr" description="Administra tu clínica completa: doctores, pacientes, horarios, pagos y reportes desde un solo sistema.">
  <Header />
  <main class="scaffold">
    <h1 class="h1">Gestión de clínicas</h1>
  </main>
  <Footer />
</BaseLayout>
<style>
  .scaffold { background:#fff; min-height:100vh; padding:140px 24px 96px; max-width:1100px; margin:0 auto; }
  :global(html.dark) .scaffold { background:#0f172a; }
</style>
