---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---

<BaseLayout
  title="Historial médico digital para clínicas | AgendaDr"
  description="Historia clínica electrónica completa. Notas SOAP, archivos, recetas y portal del paciente. El paciente ve su propio historial. Desde S/49/mes."
  keywords={['historial médico digital', 'historia clínica electrónica', 'expediente médico digital', 'ficha clínica online']}
>
  <Header />

  <main>

    <!-- ── HERO ── -->
    <section class="hero">
      <div class="hero-inner">

        <div class="hero-text anim-fade-up">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Inicio</a>
            <span aria-hidden="true">›</span>
            <a href="/funcionalidades">Funcionalidades</a>
            <span aria-hidden="true">›</span>
            <span>Historial médico</span>
          </nav>
          <div class="hero-badge">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            Historial médico
          </div>
          <h1 class="hero-title">Toda la historia de tu paciente.<br />A un clic.</h1>
          <p class="hero-sub">
            AgendaDr centraliza el historial médico de tus pacientes en la nube: notas clínicas, diagnósticos,
            recetas, archivos y planes de tratamiento. Accesible desde cualquier dispositivo,
            seguro y siempre actualizado.
          </p>
          <div class="hero-actions">
            <a href="https://app.agendadr.com/registro" class="btn-primary">
              Empieza ahora
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="/planes" class="btn-secondary">Ver planes</a>
          </div>
          <p class="hero-guarantee">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            Garantía 15 días · Desde S/49/mes · Sin contrato
          </p>
        </div>

        <div class="hero-visual anim-fade-up" style="--delay:0.1s" aria-hidden="true">
          <!-- TODO: replace with real screenshot of the patient record/history view -->
          <div class="mockup-placeholder">
            <div class="mp-browser-bar">
              <span class="mp-dot mp-dot--red"></span>
              <span class="mp-dot mp-dot--yellow"></span>
              <span class="mp-dot mp-dot--green"></span>
              <div class="mp-url">AgendaDr · Historia clínica del paciente</div>
            </div>
            <div class="mp-body">
              <div class="mp-screen-hint">
                <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color:#03BB85;opacity:0.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <p>Historia clínica digital</p>
                <span>Próximamente screenshot real</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ── EL PROBLEMA ── -->
    <section class="section section--alt">
      <div class="container container--narrow">
        <div class="section-head anim-fade-up">
          <span class="section-label">El problema</span>
          <h2 class="section-title">Las fichas de papel se pierden. El Excel se desordena. Y el paciente espera.</h2>
        </div>
        <div class="problem-copy anim-fade-up" style="--delay:0.08s">
          <p>
            El paciente llega a consulta y el doctor busca su ficha: en un folder, en un archivo,
            en el Excel de la recepcionista. Le pide al paciente que repita su historial. Otra vez. Otra vez.
          </p>
          <p>
            Si el paciente se atiende con otro doctor de la clínica, no hay forma de que vea lo que anotó el anterior.
            Cada doctor tiene su propia versión de la historia.
          </p>
          <p class="problem-callout">Y si el folder se pierde o se moja... bueno, eso no debería pasar en 2026.</p>
        </div>
      </div>
    </section>

    <!-- ── LA SOLUCIÓN — 6 funcionalidades ── -->
    <section class="section">
      <div class="container">
        <div class="section-head anim-fade-up">
          <span class="section-label">La solución</span>
          <h2 class="section-title">Un expediente digital completo.<br />Siempre disponible, siempre seguro.</h2>
        </div>
        <div class="features-grid">
          {[
            {
              icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
              title: 'Notas clínicas SOAP',
              desc: 'Cada consulta se registra con el formato estándar médico: Subjetivo, Objetivo, Análisis y Plan. Estructurado, claro y profesional.',
              delay: '0s',
            },
            {
              icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Historial de consultas',
              desc: 'Todas las consultas anteriores en orden cronológico. El doctor ve cuándo fue la última visita, qué se diagnosticó y qué se recetó.',
              delay: '0.06s',
            },
            {
              icon: 'M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13',
              title: 'Archivos adjuntos',
              desc: 'Radiografías, resultados de laboratorio, fotos, documentos. Todo adjunto a la ficha del paciente, organizado por fecha.',
              delay: '0.12s',
            },
            {
              icon: 'M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z',
              title: 'Recetas digitales con QR',
              desc: 'El doctor emite la receta desde el sistema. El paciente la recibe digital con código QR verificable. Se reenvía por WhatsApp o descarga en PDF.',
              delay: '0.18s',
            },
            {
              icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
              title: 'Datos personales y médicos',
              desc: 'Información de contacto, alergias, antecedentes, medicamentos actuales, contacto de emergencia. Todo en un solo lugar.',
              delay: '0.24s',
            },
            {
              icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01',
              title: 'Planes de tratamiento',
              desc: 'Para tratamientos largos (ortodoncia, fisioterapia, nutrición), el doctor crea un plan con fases y citas automáticas. El paciente ve el progreso.',
              delay: '0.30s',
            },
          ].map((f) => (
            <div class="feat-card anim-fade-up" style={`--delay:${f.delay}`}>
              <div class="feat-icon">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={f.icon}/>
                </svg>
              </div>
              <h3 class="feat-title">{f.title}</h3>
              <p class="feat-desc">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── PARA EL DOCTOR ── -->
    <section class="section section--alt">
      <div class="container">
        <div class="doctor-inner anim-fade-up">
          <div class="doctor-text">
            <span class="section-label">Para el doctor</span>
            <h2 class="doctor-title">Todo lo que necesitas saber del paciente, antes de que entre al consultorio.</h2>
            <p class="doctor-desc">
              Antes de cada cita, el doctor abre la ficha del paciente y ve de inmediato:
            </p>
            <ul class="doctor-list">
              {[
                'Última consulta y diagnóstico',
                'Medicamentos que está tomando',
                'Alergias (con alerta visual si hay incompatibilidad)',
                'Resultados de laboratorio recientes',
                'Plan de tratamiento en curso',
                'Notas de otros doctores de la clínica',
              ].map((item) => (
                <li>
                  <svg width="16" height="16" fill="none" stroke="#03BB85" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
            <p class="doctor-footer">
              El paciente ya no tiene que repetir todo desde cero. Y el doctor toma mejores decisiones con información completa.
            </p>
          </div>
          <div class="doctor-visual" aria-hidden="true">
            <!-- TODO: replace with real screenshot of doctor's pre-consultation view -->
            <div class="mockup-placeholder">
              <div class="mp-browser-bar">
                <span class="mp-dot mp-dot--red"></span>
                <span class="mp-dot mp-dot--yellow"></span>
                <span class="mp-dot mp-dot--green"></span>
                <div class="mp-url">AgendaDr · Ficha del paciente</div>
              </div>
              <div class="mp-body">
                <div class="mp-screen-hint">
                  <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color:#03BB85;opacity:0.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                  <p>Vista del doctor</p>
                  <span>Próximamente screenshot real</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── PARA EL PACIENTE ── -->
    <section class="section">
      <div class="container">
        <div class="patient-inner anim-fade-up">
          <div class="patient-visual" aria-hidden="true">
            <!-- TODO: replace with real screenshot of the patient portal -->
            <div class="mockup-placeholder">
              <div class="mp-browser-bar">
                <span class="mp-dot mp-dot--red"></span>
                <span class="mp-dot mp-dot--yellow"></span>
                <span class="mp-dot mp-dot--green"></span>
                <div class="mp-url">app.agendadr.com · Portal del paciente</div>
              </div>
              <div class="mp-body">
                <div class="mp-screen-hint">
                  <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color:#03BB85;opacity:0.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                  <p>Portal del paciente</p>
                  <span>Próximamente screenshot real</span>
                </div>
              </div>
            </div>
          </div>
          <div class="patient-text">
            <div class="patient-badge">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
              </svg>
              Diferenciador clave
            </div>
            <span class="section-label">Para el paciente</span>
            <h2 class="patient-title">Tus pacientes también ven su historial.</h2>
            <p class="patient-desc">
              Esto es algo que casi ningún competidor ofrece: cada paciente tiene su propio portal
              donde puede ver sus citas, descargar sus recetas, revisar su plan de tratamiento
              y acceder a sus documentos.
            </p>
            <div class="patient-examples">
              {[
                { spec: 'Ortodoncia',       benefit: 'Ve en qué fase va su tratamiento' },
                { spec: 'Nutrición',        benefit: 'Revisa su progreso mensual' },
                { spec: 'Medicina general', benefit: 'Descarga la receta para la farmacia' },
              ].map((e) => (
                <div class="patient-example">
                  <span class="pe-spec">{e.spec}</span>
                  <span class="pe-arrow" aria-hidden="true">→</span>
                  <span class="pe-benefit">{e.benefit}</span>
                </div>
              ))}
            </div>
            <p class="patient-footer">
              Tu clínica se siente moderna, profesional y transparente.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── SEGURIDAD ── -->
    <section class="section section--alt">
      <div class="container container--narrow">
        <div class="section-head anim-fade-up">
          <span class="section-label">Seguridad</span>
          <h2 class="section-title">Datos médicos sensibles merecen seguridad de verdad.</h2>
          <p class="section-sub">
            La información médica es dato sensible según la Ley de Protección de Datos Personales del Perú (Ley 29733). AgendaDr lo toma en serio.
          </p>
        </div>
        <div class="security-grid anim-fade-up" style="--delay:0.08s">
          {[
            {
              icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
              title: 'Encriptación total',
              desc: 'Toda la información viaja encriptada. Nadie puede interceptar los datos de tus pacientes.',
            },
            {
              icon: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z',
              title: 'Backups automáticos',
              desc: 'Servidores seguros en la nube con copias de seguridad automáticas diarias. Tus datos nunca se pierden.',
            },
            {
              icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
              title: 'Acceso por roles',
              desc: 'Cada usuario ve solo lo que le corresponde. El doctor ve todo, la recepcionista lo administrativo, el paciente lo suyo.',
            },
            {
              icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
              title: 'Cumplimiento Ley 29733',
              desc: 'Cumplimiento con la normativa peruana de protección de datos personales. Nada de letra chica.',
            },
          ].map((s, i) => (
            <div class="security-card anim-item" style={`--i:${i}`}>
              <div class="sec-icon">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={s.icon}/>
                </svg>
              </div>
              <h3 class="sec-title">{s.title}</h3>
              <p class="sec-desc">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── VS COMPETENCIA ── -->
    <section class="section">
      <div class="container">
        <div class="section-head anim-fade-up">
          <span class="section-label">Comparativa</span>
          <h2 class="section-title">No es solo una ficha clínica. Es un expediente completo.</h2>
        </div>
        <div class="table-wrap anim-fade-up" style="--delay:0.08s">
          <table class="compare-table" role="table">
            <thead>
              <tr>
                <th scope="col">Funcionalidad</th>
                <th scope="col" class="col-featured">AgendaDr</th>
                <th scope="col">Doctocliq</th>
                <th scope="col">AgendaPro</th>
                <th scope="col">Fichas en papel</th>
              </tr>
            </thead>
            <tbody>
              {[
                { feature: 'Notas clínicas SOAP',                    vals: ['✅', '✅', 'Básico', '❌'] },
                { feature: 'Historial completo por paciente',         vals: ['✅', '✅', '✅', '❌ se pierde'] },
                { feature: 'Archivos adjuntos',                      vals: ['✅', '✅', '✅', '❌'] },
                { feature: 'Recetas digitales con QR',               vals: ['✅', '✅', '❌', '❌'] },
                { feature: 'Paciente ve su historial en portal',      vals: ['✅', '❌', '❌', '❌'] },
                { feature: 'Paciente descarga sus recetas',           vals: ['✅', '❌', '❌', '❌'] },
                { feature: 'Paciente ve plan de tratamiento',         vals: ['✅', '❌', '❌', '❌'] },
                { feature: 'Acceso compartido entre doctores',        vals: ['✅', '✅', '✅', '❌'] },
              ].map((row) => (
                <tr>
                  <td>{row.feature}</td>
                  {row.vals.map((v, i) => (
                    <td class={i === 0 ? 'col-featured' : ''}>
                      {v === '✅'
                        ? <span class="check" aria-label="Sí"><svg width="16" height="16" fill="none" stroke="#03BB85" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                        : v === '❌' || v.startsWith('❌')
                          ? <span class="cross" aria-label="No">
                              {v.includes(' ') ? <span class="cross-note">{v.replace('❌ ', '')}</span> : null}
                              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="color:var(--text-muted);opacity:0.4"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                            </span>
                          : <span class="partial">{v}</span>
                      }
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ── FAQ ── -->
    <section class="section section--alt">
      <div class="container container--narrow">
        <div class="section-head anim-fade-up">
          <span class="section-label">FAQ</span>
          <h2 class="section-title">Preguntas sobre el historial médico digital</h2>
        </div>
        <div class="faq-list anim-fade-up" style="--delay:0.08s">
          {[
            {
              q: '¿Puedo migrar mis fichas actuales al sistema?',
              a: 'Puedes ingresar los datos de tus pacientes actuales manualmente o, en el plan Enterprise, incluimos migración asistida de datos.',
            },
            {
              q: '¿Cada doctor ve las notas de los demás?',
              a: 'Sí. Si un paciente se atiende con varios doctores en tu clínica, todos ven el mismo historial. Esto mejora la continuidad de la atención.',
            },
            {
              q: '¿Puedo personalizar el formato de las notas?',
              a: 'Sí. Las notas clínicas son flexibles — puedes usar formato SOAP o libre según lo que necesite tu especialidad.',
            },
            {
              q: '¿Hay límite de archivos adjuntos?',
              a: 'No hay límite de cantidad. Puedes adjuntar radiografías, resultados, fotos y documentos sin restricción.',
            },
            {
              q: '¿El paciente puede ver TODO su historial?',
              a: 'El paciente ve sus citas, recetas, plan de tratamiento y documentos que el doctor haya marcado como visibles. Las notas clínicas internas del doctor no son visibles para el paciente.',
            },
          ].map((item) => (
            <div class="faq-item">
              <button class="faq-q" aria-expanded="false">
                <span>{item.q}</span>
                <svg class="faq-chevron" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="faq-a">
                <p>{item.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── CTA FINAL ── -->
    <section class="cta-final">
      <div class="cta-blob cta-blob--1" aria-hidden="true"></div>
      <div class="cta-blob cta-blob--2" aria-hidden="true"></div>
      <div class="cta-blob cta-blob--3" aria-hidden="true"></div>
      <div class="cta-inner anim-fade-up">
        <h2 class="cta-title">Deja las fichas de papel en el pasado.</h2>
        <p class="cta-sub">Tus pacientes merecen un historial médico organizado, seguro y accesible. Y tú mereces no buscar folders nunca más. Desde S/49 al mes.</p>
        <div class="cta-actions">
          <a href="https://app.agendadr.com/registro" class="btn-primary btn--lg">
            Empieza ahora
