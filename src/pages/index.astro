    background:transparent; border:none; cursor:pointer;
    color: var(--text-muted, #64748b);
    display:flex; align-items:center; justify-content:center;
    transition: background .15s, color .15s;
  }
  .popup-close:hover { background:rgba(0,0,0,0.06); color:var(--text-heading,#0f172a); }
  :global(html.dark) .popup-close:hover { background:rgba(255,255,255,0.08); color:#f1f5f9; }
  .popup-close:focus-visible { outline:2px solid #03BB85; outline-offset:2px; }

  .popup-badge {
    display: inline-block;
    font-size: 12px; font-weight: 700; letter-spacing: .05em;
    background: rgba(3,187,133,.12); color: #03BB85;
    border: 1px solid rgba(3,187,133,.25);
    padding: 4px 12px; border-radius: 999px;
    margin-bottom: 14px;
  }
  :global(html.dark) .popup-badge { background:rgba(3,187,133,.15); }

  .popup-title {
    font-size: clamp(1.2rem, 3vw, 1.5rem);
    font-weight: 800; line-height: 1.25;
    color: var(--text-heading, #0f172a);
    letter-spacing: -.02em; margin-bottom: 10px;
  }
  :global(html.dark) .popup-title { color: #f1f5f9; }

  .popup-sub {
    font-size: 13.5px; color: var(--text-secondary, #334155);
    line-height: 1.6; margin-bottom: 16px;
  }
  :global(html.dark) .popup-sub { color: #cbd5e1; }

  .popup-perks {
    list-style: none; display: flex; flex-direction: column; gap: 7px;
    margin-bottom: 24px;
  }
  .popup-perks li {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; color: var(--text-secondary, #334155);
  }
  :global(html.dark) .popup-perks li { color: #94a3b8; }
  .perk-check { font-size: 14px; flex-shrink: 0; }

  .popup-form { display: flex; flex-direction: column; gap: 10px; }
  .popup-input-row {
    display: flex; align-items: center;
    border: 1.5px solid var(--border, #e2e8f0); border-radius: 10px;
    overflow: hidden; background: var(--bg-page, #fff);
    transition: border-color .15s, box-shadow .15s;
  }
  :global(html.dark) .popup-input-row { background:#0f172a; border-color:#334155; }
  .popup-input-row:focus-within {
    border-color: #03BB85;
    box-shadow: 0 0 0 3px rgba(3,187,133,.12);
  }
  .popup-phone-prefix {
    padding: 0 12px;
    display: flex; align-items: center;
    border-right: 1px solid var(--border, #e2e8f0);
    flex-shrink: 0; user-select: none;
  }
  :global(html.dark) .popup-phone-prefix { border-color: #334155; }
  .popup-input {
    flex: 1; padding: 12px 14px; border: none; outline: none;
    font-size: 15px; color: var(--text-heading, #0f172a);
    background: transparent; font-family: inherit;
  }
  :global(html.dark) .popup-input { color: #f1f5f9; }
  .popup-input::placeholder { color: var(--text-muted, #94a3b8); }

  .popup-cta {
    width: 100%; padding: 13px 20px;
    background: #03BB85; color: #fff;
    font-size: 15px; font-weight: 700;
    border: none; border-radius: 10px; cursor: pointer;
    transition: background .15s, transform .12s;
    box-shadow: 0 2px 12px rgba(3,187,133,.35);
  }
  .popup-cta:hover { background: #029e70; transform: translateY(-1px); }
  .popup-cta:active { transform: translateY(0); }

  .popup-skip {
    display: block; width: 100%; margin-top: 10px;
    background: none; border: none; cursor: pointer;
    font-size: 13px; color: var(--text-muted, #64748b);
    text-align: center; transition: color .15s;
  }
  .popup-skip:hover { color: var(--text-secondary, #334155); }
  :global(html.dark) .popup-skip:hover { color: #cbd5e1; }

  /* Success */
  .popup-success-icon { font-size: 48px; margin-bottom: 12px; text-align: center; }
  #popup-success .popup-title { text-align: center; }
  #popup-success .popup-sub  { text-align: center; margin-bottom: 24px; }
  #popup-success .popup-cta  { max-width: 240px; margin: 0 auto; display: block; }

  @media (prefers-reduced-motion: reduce) {
    .popup-overlay, .popup-card { animation: none; }
  }
</style>

<script>
  // ── IntersectionObserver ──
  const obs = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    }),
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.anim-fade-up, .anim-item').forEach((el) => obs.observe(el));

  // ── Billing toggle ──
  const plansSection = document.getElementById('home-plans-section') as HTMLElement;
  const btnMonthly   = document.getElementById('btn-monthly') as HTMLButtonElement;
  const btnAnnual    = document.getElementById('btn-annual') as HTMLButtonElement;

  btnMonthly.addEventListener('click', () => {
    plansSection.classList.remove('is-annual');
    btnMonthly.classList.add('bt-btn--active');
    btnAnnual.classList.remove('bt-btn--active');
    btnMonthly.setAttribute('aria-pressed', 'true');
    btnAnnual.setAttribute('aria-pressed', 'false');
  });
  btnAnnual.addEventListener('click', () => {
    plansSection.classList.add('is-annual');
    btnAnnual.classList.add('bt-btn--active');
    btnMonthly.classList.remove('bt-btn--active');
    btnAnnual.setAttribute('aria-pressed', 'true');
    btnMonthly.setAttribute('aria-pressed', 'false');
  });

  // ── FAQ accordion ──
  document.querySelectorAll<HTMLButtonElement>('.faq-q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      // Close all
      document.querySelectorAll<HTMLButtonElement>('.faq-q').forEach((b) => {
        b.setAttribute('aria-expanded', 'false');
        (b.nextElementSibling as HTMLElement).style.maxHeight = '0';
      });

      // Open clicked if was closed
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        answer.style.maxHeight = answer.scrollHeight + 'px';
      }
    });
  });

  // ── POPUP: ACCESO ANTICIPADO ──
  const POPUP_KEY = 'agendadr_popup_v1';
  const POPUP_TTL = 7 * 24 * 60 * 60 * 1000; // 7 días

  function popupDismissed(): boolean {
    const raw = localStorage.getItem(POPUP_KEY);
    if (!raw) return false;
    try {
      const { ts } = JSON.parse(raw);
      return Date.now() - ts < POPUP_TTL;
    } catch { return false; }
  }

  function dismissPopup() {
    localStorage.setItem(POPUP_KEY, JSON.stringify({ ts: Date.now() }));
    const popup = document.getElementById('popup-early') as HTMLElement;
    popup.style.animation = 'overlay-in .2s ease reverse forwards';
    setTimeout(() => { popup.hidden = true; }, 200);
  }

  if (!popupDismissed()) {
    const popup   = document.getElementById('popup-early')!;
    const closeBtn = document.getElementById('popup-close')!;
    const skipBtn  = document.getElementById('popup-skip')!;
    const form     = document.getElementById('popup-form') as HTMLFormElement;
    const def      = document.getElementById('popup-default')!;
    const succ     = document.getElementById('popup-success')!;
    const doneBtn  = document.getElementById('popup-done')!;

    // Show after 5 s
    setTimeout(() => { popup.hidden = false; }, 5000);

    // Close on overlay click (not card click)
    popup.addEventListener('click', (e) => {
      if (e.target === popup) dismissPopup();
    });

    // Close button & skip
    closeBtn.addEventListener('click', dismissPopup);
    skipBtn.addEventListener('click', dismissPopup);
    doneBtn.addEventListener('click', dismissPopup);

    // Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !popup.hidden) dismissPopup();
    });

    // Form submit
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const phone = (document.getElementById('popup-phone') as HTMLInputElement).value.trim();
      if (phone.length < 9) {
        (document.getElementById('popup-phone') as HTMLInputElement).focus();
        return;
      }
      // TODO: send to webhook / CRM (replace URL below)
      // await fetch('https://hook.make.com/xxx', { method:'POST', body: JSON.stringify({ whatsapp: '+51' + phone }) });
      def.hidden = true;
      succ.hidden = false;
      localStorage.setItem(POPUP_KEY, JSON.stringify({ ts: Date.now(), submitted: true }));
    });
  }
</script>
