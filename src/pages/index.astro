---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout
  title="Software médico para clínicas en Perú | AgendaDr"
  description="Gestiona tu clínica sin volverte loco. Citas, historial, pagos con Yape y hasta un CRM de WhatsApp. Todo en un solo lugar desde S/49 al mes."
  keywords={['software médico perú', 'sistema de citas médicas', 'software para clínicas']}
>
  <Header />

  <main>

    <!-- ── HERO ── -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-text anim-fade-up">
          <div class="hero-badge">
            <svg width="16" height="11" viewBox="0 0 20 14" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect width="20" height="14" rx="2" fill="#D91023"/>
              <rect x="6.5" width="7" height="14" fill="#F5F5F5"/>
            </svg>
            Hecho en Perú para clínicas peruanas
          </div>
          <h1 class="hero-title">Gestiona tu clínica<br />sin volverte loco.</h1>
          <p class="hero-sub">
            Citas, historial, pagos con Yape y hasta un CRM de WhatsApp para que no se te escape ningún paciente.
            Todo en un solo lugar, desde <strong>S/49 al mes</strong>.
          </p>
          <div class="hero-actions">
            <a href="https://app.agendadr.com/registro" class="btn-primary">
              Empieza ahora
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="/demo" class="btn-secondary">Pide una demo gratis →</a>
          </div>
          <p class="hero-guarantee">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            15 días de garantía · Sin contratos · Cancela cuando quieras
          </p>
          <div class="hero-stats">
            <div class="hero-stat">
              <span class="hs-num">+500</span>
              <span class="hs-lbl">médicos activos</span>
            </div>
            <span class="hs-sep" aria-hidden="true"></span>
            <div class="hero-stat">
              <span class="hs-num">+18</span>
              <span class="hs-lbl">ciudades en Perú</span>
            </div>
            <span class="hs-sep" aria-hidden="true"></span>
            <div class="hero-stat">
              <span class="hs-num">98%</span>
              <span class="hs-lbl">satisfacción</span>
            </div>
          </div>
        </div>

        <!-- Mockup visual -->
        <div class="hero-visual anim-fade-up" style="--delay:0.1s">
          <div class="mockup-desktop">
            <div class="mockup-bar">
              <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
              <span class="mockup-url">app.agendadr.com/dashboard</span>
            </div>
            <div class="mockup-screen">
              <!-- Dashboard preview -->
              <div class="dash-sidebar">
                <div class="dash-logo-area"></div>
                <div class="dash-nav">
                  {[1,2,3,4,5].map(() => <div class="dash-nav-item"></div>)}
                </div>
              </div>
              <div class="dash-main">
                <div class="dash-header-row">
                  <div class="dash-title-block"></div>
                  <div class="dash-action-block"></div>
                </div>
                <div class="dash-stats">
                  {[
                    {num:'24', lbl:'Citas hoy'},
                    {num:'S/1,840', lbl:'Ingresos'},
                    {num:'3', lbl:'Pendientes'},
                    {num:'98%', lbl:'Satisfacción'},
                  ].map((s) => (
                    <div class="stat-card">
                      <span class="stat-num">{s.num}</span>
                      <span class="stat-lbl">{s.lbl}</span>
                    </div>
                  ))}
                </div>
                <div class="dash-calendar">
                  <div class="cal-header"></div>
                  <div class="cal-grid">
                    {Array.from({length: 12}).map((_,i) => (
                      <div class:list={['cal-slot', i === 2 || i === 5 || i === 9 ? 'filled' : '']}></div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- Mobile mockup -->
          <div class="mockup-mobile">
            <div class="mob-screen">
              <div class="mob-header"></div>
              <div class="mob-card">
                <div class="mob-avatar"></div>
                <div class="mob-info">
                  <div class="mob-line long"></div>
                  <div class="mob-line short"></div>
                </div>
              </div>
              <div class="mob-slots">
                {[1,2,3].map((_,i) => <div class:list={['mob-slot', i===1?'active':'']}></div>)}
              </div>
              <div class="mob-btn"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── TRUST BAR ── -->
    <div class="trust-bar">
      <div class="trust-inner">
        {[
          {icon:'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', text:'Hecho en Perú para clínicas peruanas'},
          {icon:'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z', text:'Pagos con Yape y Plin'},
          {icon:'M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2zM10 8.5a.5.5 0 11-1 0 .5.5 0 011 0zm5 5a.5.5 0 11-1 0 .5.5 0 011 0z', text:'Facturación SUNAT incluida'},
          {icon:'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z', text:'Tus datos seguros en la nube'},
        ].map((item) => (
          <div class="trust-item">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d={item.icon}/>
            </svg>
            <span>{item.text}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ── EL PROBLEMA ── -->
    <section class="section section--alt">
      <div class="container">
        <div class="section-head anim-fade-up">
          <span class="section-label">El día a día</span>
          <h2 class="section-title">Sabemos cómo es tu día a día.<br />Y no está fácil.</h2>
        </div>
        <div class="problems-grid">
          {[
            {
              icon:'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
              title:'Tu recepcionista hace malabares con WhatsApp',
              desc:'Contesta desde su celular, anota en un cuaderno, pasa los datos a otro sistema... y los leads que no cierran hoy desaparecen para siempre. Doble trabajo, cero control.',
              delay:'0s',
            },
            {
              icon:'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z',
              title:'Cobrar es todo un show',
              desc:'"¿Aceptan Yape?" — y ahí va tu recepcionista a hacer el cobro por fuera, anotar a mano y rezar para que cuadre la caja al final del día.',
              delay:'0.08s',
            },
            {
              icon:'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z',
              title:'Las comisiones de tus doctores son un misterio',
              desc:'El Excel dice una cosa, el cuaderno dice otra, y al final del mes nadie sabe cuánto ganó la clínica realmente. Suena conocido, ¿no?',
              delay:'0.16s',
            },
          ].map((p) => (
            <div class="problem-card anim-fade-up" style={`--delay:${p.delay}`}>
              <div class="prob-icon">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={p.icon}/>
                </svg>
              </div>
              <h3 class="prob-title">{p.title}</h3>
              <p class="prob-desc">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── BRIDGE ── -->
    <div class="bridge">
      <div class="bridge-inner anim-fade-up">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
        <span>¿Y si hubiera una mejor forma?</span>
      </div>
    </div>

    <!-- ── LA SOLUCIÓN ── -->
    <section class="section">
      <div class="container">
        <div class="section-head anim-fade-up">
          <span class="section-label">La solución</span>
          <h2 class="section-title">AgendaDr le pone orden al caos.<br />Así de simple.</h2>
        </div>
        <div class="benefits-grid">
          {[
            {
              icon:'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
              title:'WhatsApp directo en el panel',
              desc:'Los mensajes de tus pacientes llegan al panel de tu recepcionista. Responde, agenda y listo — sin salir del sistema. Los leads de Meta Ads se convierten en citas, no en mensajes perdidos.',
              delay:'0s',
            },
            {
              icon:'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z',
              title:'Cobros con Yape y Plin que se registran solos',
              desc:'Tu paciente agenda online y paga como paga todo: con Yape o Plin. Cero cobros manuales, cero perseguir pagos. La caja cuadra sola.',
              delay:'0.08s',
            },
            {
              icon:'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
              title:'Tus pacientes con su propio portal',
              desc:'Cada paciente puede ver sus citas, descargar recetas, revisar su plan de tratamiento y reagendar sin llamar a la clínica. Se siente premium y a ti te quita trabajo.',
              delay:'0.16s',
            },
            {
              icon:'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title:'Comisiones que se calculan solas',
              desc:'Configura el porcentaje de cada doctor una vez. El sistema hace el resto: bruto, comisión, neto de la clínica. Sin errores, sin discusiones, con un clic lo exportas.',
              delay:'0.24s',
            },
          ].map((b) => (
            <div class="benefit-card anim-fade-up" style={`--delay:${b.delay}`}>
              <div class="ben-icon">
                <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={b.icon}/>
                </svg>
              </div>
              <h3 class="ben-title">{b.title}</h3>
              <p class="ben-desc">{b.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── CÓMO FUNCIONA ── -->
    <section class="section section--alt">
      <div class="container">
        <div class="section-head anim-fade-up">
          <span class="section-label">Cómo funciona</span>
          <h2 class="section-title">Arranca en 3 pasos.<br />En serio, así de fácil.</h2>
        </div>
        <div class="steps-grid">
          {[
            {
              num:'01',
              title:'Elige tu plan',
              desc:'Desde S/49 al mes. No importa si eres un doctor solo o una clínica con 15 especialistas — hay un plan que te calza.',
              icon:'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
              delay:'0s',
            },
            {
              num:'02',
              title:'Arma tu consultorio',
              desc:'Sube tu logo, pon tus colores, agrega tus doctores. En unos minutos tienes tu portal de citas con tu propia marca. Sí, con tu marca.',
              icon:'M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4',
              delay:'0.1s',
            },
            {
              num:'03',
              title:'A recibir pacientes',
              desc:'Comparte tu link por WhatsApp o redes. Tus pacientes agendan y pagan online, 24/7. Tú solo atiendes.',
              icon:'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
              delay:'0.2s',
            },
          ].map((s, i) => (
            <div class="step-card anim-fade-up" style={`--delay:${s.delay}`}>
              <div class="step-num">{s.num}</div>
              {i < 2 && <div class="step-connector" aria-hidden="true"></div>}
              <div class="step-icon">
                <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={s.icon}/>
                </svg>
              </div>
              <h3 class="step-title">{s.title}</h3>
              <p class="step-desc">{s.desc}</p>
            </div>
          ))}
        </div>
        <div class="steps-cta anim-fade-up" style="--delay:0.3s">
          <a href="https://app.agendadr.com/registro" class="btn-primary">
            Empieza ahora →
          </a>
        </div>
      </div>
    </section>

    <!-- ── FUNCIONALIDADES ── -->
    <section class="section">
      <div class="container">
        <div class="section-head anim-fade-up">
          <span class="section-label">Funcionalidades</span>
          <h2 class="section-title">Todo lo que necesitas<br />(y algunas cosas que ni sabías que necesitabas)</h2>
        </div>
        <div class="features-grid">
          <!-- Featured card: CRM WhatsApp -->
          <div class="feature-card feature-card--hero anim-item" style="--i:0">
            <div class="feat-icon feat-icon--lg">
              <svg width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
            </div>
            <div class="feat-hero-badge">Más usado</div>
            <h3 class="feat-title feat-title--lg">CRM de WhatsApp</h3>
            <p class="feat-desc feat-desc--lg">Los mensajes de tus pacientes llegan directamente al panel de tu recepcionista. Responde, agenda y listo — sin salir del sistema, sin abrir otra app. Los leads de Meta Ads se convierten en citas, no en chats perdidos.</p>
            <div class="feat-hero-stats">
              <div class="fhs-item">
                <span class="fhs-num">3x</span>
                <span class="fhs-lbl">más conversión</span>
              </div>
              <div class="fhs-item">
                <span class="fhs-num">0</span>
                <span class="fhs-lbl">leads perdidos</span>
              </div>
            </div>
          </div>
          <!-- Regular cards -->
          {[
            {icon:'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title:'Agenda médica', desc:'Por día, semana o mes. Por doctor o por especialidad. Siempre al día.'},
            {icon:'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title:'Historia clínica digital', desc:'Notas SOAP, diagnósticos, archivos. Todo en un solo lugar.'},
            {icon:'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z', title:'Cobros con Yape y Plin', desc:'El paciente paga al agendar. Sin efectivo, sin dramas.'},
            {icon:'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', title:'Comisiones automáticas', desc:'Bruto, comisión y neto por doctor. Se calcula solo.'},
            {icon:'M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z', title:'Recetas con QR', desc:'Recetas digitales verificables. Adiós al papel.'},
            {icon:'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01', title:'Planes de tratamiento', desc:'Crea fases y citas automáticas. El paciente ve su progreso.'},
            {icon:'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title:'Reportes en tiempo real', desc:'Ingresos, cancelaciones, demanda por doctor. Todo visible.'},
          ].map((f, i) => (
            <div class="feature-card anim-item" style={`--i:${i + 1}`}>
              <div class="feat-icon">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={f.icon}/>
                </svg>
              </div>
              <h3 class="feat-title">{f.title}</h3>
              <p class="feat-desc">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── WHITE LABEL ── -->
    <section class="section section--alt">
      <div class="container">
        <div class="wl-inner anim-fade-up">
          <div class="wl-text">
            <span class="section-label">White-label</span>
            <h2 class="wl-title">Tu marca, no la nuestra.</h2>
            <p class="wl-desc">Tu clínica merece verse como TU clínica. Con AgendaDr, cada consultorio tiene su propio portal de citas con su logo, sus colores y su URL personalizada. Tus pacientes ni se enteran que usas AgendaDr — solo ven tu marca.</p>
            <a href="https://app.agendadr.com/registro" class="btn-primary">
              Crear mi portal →
            </a>
          </div>
          <div class="wl-visual">
            <div class="wl-browser">
              <div class="wl-browser-bar">
                <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
                <span class="wl-url">app.agendadr.com/<strong>tu-clinica</strong></span>
              </div>
              <div class="wl-screen">
                <div class="wl-brand-row">
                  <div class="wl-logo-placeholder"></div>
                  <div class="wl-brand-name"></div>
                </div>
                <div class="wl-hero-block"></div>
                <div class="wl-btn-block"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── PLANES ── -->
    <section class="section" id="precios">
      <div class="container">
        <div class="section-head anim-fade-up">
          <span class="section-label">Planes y precios</span>
          <h2 class="section-title">Un plan para cada momento<br />de tu clínica.</h2>
          <p class="section-sub">Desde que abres tu primer consultorio hasta que tengas una cadena. Mismo sistema, sin migraciones.</p>
        </div>
        <!-- Billing toggle -->
        <div class="billing-toggle anim-fade-up" style="--delay:0.04s" id="billing-toggle">
          <button class="bt-btn bt-btn--active" id="btn-monthly" aria-pressed="true">Mensual</button>
          <button class="bt-btn" id="btn-annual" aria-pressed="false">
            Anual
            <span class="bt-save">2 meses gratis</span>
          </button>
        </div>

        <div class="plans-grid" id="home-plans-section">
          {[
            {
              name:'Individual',
              priceMo:'S/49', priceYr:'S/39', annualNote:'S/470/año',
              tagline:'Para ti y tu recepcionista',
              features:['1 doctor · 1 recepcionista','Portal de pacientes','CRM WhatsApp básico','Cobros con Yape/Plin','Portal con tu marca'],
