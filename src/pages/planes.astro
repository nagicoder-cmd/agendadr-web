---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout
  title="Planes y precios AgendaDr | Software médico desde S/49/mes"
  description="Planes para clínicas y consultorios en Perú. Individual S/49, Básico S/149, Profesional S/299, Clínica S/599 y Enterprise. Garantía de 15 días."
  keywords={['software médico precios perú', 'planes software clínica', 'precio software médico perú']}
>
  <Header />

  <main>

    <!-- ── Hero ── -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-text anim-fade-up">
          <span class="section-label">Planes y precios</span>
          <h1 class="hero-title">Un plan para cada momento<br />de tu clínica.</h1>
          <p class="hero-sub">
            Desde que abres tu primer consultorio hasta que tengas una cadena.
            Mismo sistema, sin migraciones, sin dolores de cabeza. Y si no te convence,
            te devolvemos tu plata en los primeros 15 días.
          </p>
        </div>
        <div class="billing-wrap anim-fade-up" style="--delay:0.1s">
          <div class="billing-toggle" role="group" aria-label="Ciclo de facturación">
            <button class="tbtn tbtn--active" id="btn-monthly" type="button" aria-pressed="true">Mensual</button>
            <button class="tbtn" id="btn-annual" type="button" aria-pressed="false">
              Anual
              <span class="save-pill">Ahorra 20%</span>
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Plans grid ── -->
    <section class="plans-section" id="plans-section">
      <div class="plans-outer">

        <div class="plans-grid">

          <!-- Individual -->
          <div class="plan-card anim-item" style="--i:0">
            <div class="plan-main">
              <div>
                <span class="plan-name">Individual</span>
                <p class="plan-tagline">Para ti y tu recepcionista</p>
              </div>
              <div class="plan-pricing">
                <div class="plan-price">
                  <span class="p-curr">S/</span>
                  <span class="p-num">
                    <span class="p-mo">49</span>
                    <span class="p-yr">39</span>
                  </span>
                  <span class="p-period">/mes</span>
                </div>
                <p class="billing-note">
                  <span class="n-mo">facturado mensual</span>
                  <span class="n-yr">S/470/año · ahorras S/118</span>
                </p>
              </div>
              <div class="plan-caps">
                <span class="cap">1 doctor</span>
                <span class="cap">1 recepcionista</span>
              </div>
              <ul class="plan-feats">
                <li><span class="fc">✓</span>Agenda médica completa</li>
                <li><span class="fc">✓</span>Historia clínica digital (SOAP)</li>
                <li><span class="fc">✓</span>Recetas digitales con QR</li>
                <li><span class="fc">✓</span>Planes de tratamiento con fases</li>
                <li><span class="fc">✓</span>Portal de pacientes + portal con tu marca</li>
                <li><span class="fc">✓</span>Cobros Yape, Plin y tarjeta</li>
                <li><span class="fc">✓</span>Recordatorios automáticos</li>
                <li><span class="fc">✓</span>Facturación SUNAT</li>
                <li><span class="fc">✓</span>CRM WhatsApp básico</li>
              </ul>
            </div>
            <a href="https://app.agendadr.com/checkout?plan=individual&periodo=mensual" class="plan-btn plan-cta" data-plan="individual">
              Empezar ahora
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>

          <!-- Básico -->
          <div class="plan-card anim-item" style="--i:1">
            <div class="plan-main">
              <div>
                <span class="plan-name">Básico</span>
                <p class="plan-tagline">Tu consultorio está creciendo</p>
              </div>
              <div class="plan-pricing">
                <div class="plan-price">
                  <span class="p-curr">S/</span>
                  <span class="p-num">
                    <span class="p-mo">149</span>
                    <span class="p-yr">119</span>
                  </span>
                  <span class="p-period">/mes</span>
                </div>
                <p class="billing-note">
                  <span class="n-mo">facturado mensual</span>
                  <span class="n-yr">S/1,430/año · ahorras S/358</span>
                </p>
              </div>
              <div class="plan-caps">
                <span class="cap">2 doctores</span>
                <span class="cap">1 recepcionista</span>
              </div>
              <p class="plan-prev">Todo lo del Individual, más:</p>
              <ul class="plan-feats plan-feats--addon">
                <li><span class="fc">✓</span>Comisiones de doctores (bruto / comisión / neto)</li>
                <li><span class="fc">✓</span>Reportes por doctor</li>
                <li><span class="fc">✓</span>Catálogo de servicios por especialidad</li>
              </ul>
            </div>
            <a href="https://app.agendadr.com/checkout?plan=basico&periodo=mensual" class="plan-btn plan-cta" data-plan="basico">
              Empezar ahora
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>

          <!-- Profesional (popular) -->
          <div class="plan-card plan-card--pop anim-item" style="--i:2">
            <div class="pop-badge">
              <svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              Más popular
            </div>
            <div class="plan-main">
              <div>
                <span class="plan-name">Profesional</span>
                <p class="plan-tagline">Tu clínica ya es un negocio serio</p>
              </div>
              <div class="plan-pricing">
                <div class="plan-price">
                  <span class="p-curr">S/</span>
                  <span class="p-num">
                    <span class="p-mo">299</span>
                    <span class="p-yr">239</span>
                  </span>
                  <span class="p-period">/mes</span>
                </div>
                <p class="billing-note">
                  <span class="n-mo">facturado mensual</span>
                  <span class="n-yr">S/2,870/año · ahorras S/718</span>
                </p>
              </div>
              <div class="plan-caps">
                <span class="cap">5 doctores</span>
                <span class="cap">2 recepcionistas</span>
              </div>
              <p class="plan-prev">Todo lo del Básico, más:</p>
              <ul class="plan-feats plan-feats--addon">
                <li><span class="fc">✓</span>CRM WhatsApp completo</li>
                <li><span class="fc">✓</span>Pipeline de leads</li>
                <li><span class="fc">✓</span>Métricas de conversión + seguimientos</li>
                <li><span class="fc">✓</span>Reportes avanzados (embudo, ROI)</li>
                <li><span class="fc">✓</span>Rendimiento por recepcionista</li>
              </ul>
            </div>
            <a href="https://app.agendadr.com/checkout?plan=profesional&periodo=mensual" class="plan-btn plan-btn--pop plan-cta" data-plan="profesional">
              Empezar ahora
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>

          <!-- Clínica -->
          <div class="plan-card anim-item" style="--i:3">
            <div class="plan-main">
              <div>
                <span class="plan-name">Clínica</span>
                <p class="plan-tagline">Varias especialidades, un solo sistema</p>
              </div>
              <div class="plan-pricing">
                <div class="plan-price">
                  <span class="p-curr">S/</span>
                  <span class="p-num">
                    <span class="p-mo">599</span>
                    <span class="p-yr">479</span>
                  </span>
                  <span class="p-period">/mes</span>
                </div>
                <p class="billing-note">
                  <span class="n-mo">facturado mensual</span>
                  <span class="n-yr">S/5,750/año · ahorras S/1,438</span>
                </p>
              </div>
              <div class="plan-caps">
                <span class="cap">15 doctores</span>
                <span class="cap">5 recepcionistas</span>
              </div>
              <p class="plan-prev">Todo lo del Profesional, más:</p>
              <ul class="plan-feats plan-feats--addon">
                <li><span class="fc">✓</span>Multi-sede (varias ubicaciones)</li>
                <li><span class="fc">✓</span>Reportes consolidados por sede</li>
                <li><span class="fc">✓</span>Soporte prioritario (&lt; 2 horas)</li>
                <li><span class="fc">✓</span>Onboarding asistido</li>
              </ul>
            </div>
            <a href="https://app.agendadr.com/checkout?plan=clinica&periodo=mensual" class="plan-btn plan-cta" data-plan="clinica">
              Empezar ahora
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>

        </div>

        <!-- Enterprise -->
        <div class="enterprise-row anim-fade-up">
          <div class="enterprise-left">
            <div class="ent-icon">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <div>
              <span class="ent-name">Enterprise</span>
              <p class="ent-desc">Para cadenas y redes médicas — doctores, sedes y recepcionistas ilimitados. API custom, onboarding dedicado con migración de datos, SLA garantizado y gerente de cuenta asignado.</p>
            </div>
          </div>
          <a href="https://app.agendadr.com/contacto-enterprise" class="ent-btn">Contáctanos →</a>
        </div>

        <!-- Guarantee -->
        <div class="guarantee-row anim-fade-up">
          <div class="guarantee-box">
            <svg width="20" height="20" fill="none" stroke="#03BB85" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            <p><strong>Garantía de 15 días</strong> — Si no te convence, te devolvemos tu plata. Sin preguntas, sin letra chica.</p>
          </div>
          <div class="all-incl">
            <p class="all-label">Todos los planes incluyen:</p>
            <div class="all-items">
              <span><svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>Acceso en la nube</span>
              <span><svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>Actualizaciones automáticas</span>
              <span><svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>Soporte por WhatsApp</span>
              <span><svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>Cifrado de datos</span>
              <span><svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg>Backups diarios</span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ── Comparison table ── -->
    <section class="compare-section">
      <div class="compare-inner">
        <div class="compare-hd anim-fade-up">
          <span class="section-label">Comparativa</span>
          <h2 class="section-title">Compara los planes al detalle</h2>
        </div>
        <div class="table-wrap anim-fade-up" style="--delay:0.1s">
          <table class="ctable">
            <thead>
              <tr>
                <th class="fcol">Funcionalidad</th>
                <th>Individual<br /><em>S/49/mes</em></th>
                <th>Básico<br /><em>S/149/mes</em></th>
                <th class="th-pop">Profesional<br /><em>S/299/mes</em></th>
                <th>Clínica<br /><em>S/599/mes</em></th>
                <th>Enterprise<br /><em>Cotizar</em></th>
              </tr>
            </thead>
            <tbody>
              <tr class="gr"><td colspan="6">Capacidad</td></tr>
              <tr><td class="fcol">Doctores</td><td>1</td><td>2</td><td class="td-pop">5</td><td>15</td><td>Ilimitado</td></tr>
              <tr><td class="fcol">Recepcionistas</td><td>1</td><td>1</td><td class="td-pop">2</td><td>5</td><td>Ilimitado</td></tr>

              <tr class="gr"><td colspan="6">Gestión médica</td></tr>
              <tr><td class="fcol">Agenda médica completa</td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td class="td-pop"><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td></tr>
              <tr><td class="fcol">Historia clínica (SOAP)</td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td class="td-pop"><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td></tr>
              <tr><td class="fcol">Recetas digitales con QR</td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td class="td-pop"><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td></tr>
              <tr><td class="fcol">Planes de tratamiento</td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td class="td-pop"><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td></tr>
              <tr><td class="fcol">Ticket expandible</td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td class="td-pop"><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td></tr>
              <tr><td class="fcol">Portal de pacientes</td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td class="td-pop"><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td></tr>
              <tr><td class="fcol">Portal white-label (tu marca)</td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td class="td-pop"><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td></tr>
              <tr><td class="fcol">Cobros Yape / Plin / tarjeta</td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td class="td-pop"><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td></tr>
              <tr><td class="fcol">Recordatorios automáticos</td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td class="td-pop"><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td></tr>
              <tr><td class="fcol">Facturación SUNAT</td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td class="td-pop"><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td></tr>

              <tr class="gr"><td colspan="6">Gestión de negocio</td></tr>
              <tr><td class="fcol">CRM WhatsApp</td><td><span class="part">Básico</span></td><td><span class="part">Básico</span></td><td class="td-pop"><span class="yes">Completo</span></td><td><span class="yes">Completo</span></td><td><span class="yes">Completo</span></td></tr>
              <tr><td class="fcol">Comisiones de doctores</td><td><span class="no">—</span></td><td><span class="yes">✓</span></td><td class="td-pop"><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td></tr>
              <tr><td class="fcol">Reportes por doctor</td><td><span class="no">—</span></td><td><span class="yes">✓</span></td><td class="td-pop"><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td></tr>
              <tr><td class="fcol">Pipeline de leads</td><td><span class="no">—</span></td><td><span class="no">—</span></td><td class="td-pop"><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td></tr>
              <tr><td class="fcol">Métricas de conversión</td><td><span class="no">—</span></td><td><span class="no">—</span></td><td class="td-pop"><span class="yes">✓</span></td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td></tr>

              <tr class="gr"><td colspan="6">Escala</td></tr>
              <tr><td class="fcol">Multi-sede</td><td><span class="no">—</span></td><td><span class="no">—</span></td><td class="td-pop"><span class="no">—</span></td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td></tr>
              <tr><td class="fcol">Soporte prioritario (&lt; 2h)</td><td><span class="no">—</span></td><td><span class="no">—</span></td><td class="td-pop"><span class="no">—</span></td><td><span class="yes">✓</span></td><td><span class="yes">✓</span></td></tr>
              <tr><td class="fcol">API e integraciones custom</td><td><span class="no">—</span></td><td><span class="no">—</span></td><td class="td-pop"><span class="no">—</span></td><td><span class="no">—</span></td><td><span class="yes">✓</span></td></tr>
              <tr><td class="fcol">Onboarding dedicado + migración</td><td><span class="no">—</span></td><td><span class="no">—</span></td><td class="td-pop"><span class="no">—</span></td><td><span class="no">—</span></td><td><span class="yes">✓</span></td></tr>
              <tr><td class="fcol">Gerente de cuenta asignado</td><td><span class="no">—</span></td><td><span class="no">—</span></td><td class="td-pop"><span class="no">—</span></td><td><span class="no">—</span></td><td><span class="yes">✓</span></td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ── Help section ── -->
    <section class="help-section">
      <div class="help-inner anim-fade-up">
        <div class="help-icon">
          <svg width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        </div>
        <div class="help-text">
          <h2 class="help-title">¿No sabes cuál es el plan ideal para ti?</h2>
          <p class="help-sub">No te compliques. Cuéntanos cuántos doctores tienes y qué necesitas, y te decimos cuál plan te conviene. Sin compromiso, sin presión.</p>
