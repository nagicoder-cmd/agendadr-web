  .help-title {
    font-family: 'Cal Sans', Inter, sans-serif;
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-weight: 600; color: var(--text-heading); margin: 0 0 6px;
    letter-spacing: -0.01em;
  }
  .help-sub { font-size: 14px; line-height: 1.65; color: var(--text-muted); margin: 0; }
  .help-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 22px; border-radius: 10px; text-decoration: none;
    font-size: 14px; font-weight: 700; color: #ffffff;
    background: #25D366; white-space: nowrap; flex-shrink: 0;
    transition: background 0.15s;
  }
  .help-btn:hover { background: #1ebe5d; }

  /* ── FAQ ── */
  .faq-section {
    background: var(--bg-page);
    padding: 80px 24px;
    border-bottom: 1px solid var(--border-subtle);
  }
  @media (max-width: 767px) { .faq-section { padding: 56px 16px; } }

  .faq-inner { max-width: 760px; margin: 0 auto; }

  .faq-hd { text-align: center; margin-bottom: 40px; }

  .faq-list { display: flex; flex-direction: column; gap: 0; }

  .faq-item {
    border-bottom: 1px solid var(--border-subtle);
  }
  .faq-item:first-child { border-top: 1px solid var(--border-subtle); }

  .faq-btn {
    width: 100%; display: flex; align-items: center; justify-content: space-between;
    gap: 16px; padding: 18px 0;
    background: none; border: none; cursor: pointer;
    font-size: 15px; font-weight: 600; color: var(--text-heading);
    text-align: left; font-family: inherit;
    transition: color 0.15s;
  }
  .faq-btn:hover { color: #03BB85; }
  .faq-item.open .faq-btn { color: #03BB85; }

  .faq-chevron {
    flex-shrink: 0; color: var(--text-muted);
    transition: transform 0.25s ease;
  }
  .faq-item.open .faq-chevron { transform: rotate(180deg); color: #03BB85; }

  .faq-answer {
    max-height: 0; overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .faq-answer p {
    padding: 0 0 20px;
    font-size: 14.5px; line-height: 1.75; color: var(--text-tertiary); margin: 0;
  }

  /* ── CTA final ── */
  .cta-section {
    background: var(--bg-subtle);
    padding: 96px 24px 100px;
  }
  @media (max-width: 767px) { .cta-section { padding: 64px 20px 72px; } }

  .cta-inner { max-width: 600px; margin: 0 auto; text-align: center; }

  .cta-title {
    font-family: 'Cal Sans', Inter, sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600; color: var(--text-heading);
    line-height: 1.15; letter-spacing: -0.02em; margin: 0 0 16px;
  }
  .cta-sub {
    font-size: 16px; line-height: 1.7;
    color: var(--text-tertiary); margin: 0 0 36px;
  }
  .cta-btns {
    display: flex; align-items: center; justify-content: center;
    gap: 12px; flex-wrap: wrap;
  }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 13px 26px; background: #03BB85; color: #0f172a;
    font-size: 15px; font-weight: 700; border-radius: 10px;
    text-decoration: none;
    transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
    box-shadow: 0 2px 12px rgba(3,187,133,0.35);
  }
  .btn-primary:hover { background: #02a676; transform: translateY(-1px); box-shadow: 0 4px 18px rgba(3,187,133,0.45); }

  .btn-secondary {
    display: inline-flex; align-items: center;
    padding: 13px 22px; background: transparent; color: var(--text-secondary);
    font-size: 15px; font-weight: 600;
    border: 1.5px solid var(--border-default);
    border-radius: 10px; text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-secondary:hover { border-color: #03BB85; color: #03BB85; }

  /* ── Animations ── */
  .anim-fade-up {
    opacity: 0; transform: translateY(28px);
    transition: opacity 0.55s cubic-bezier(0.22,1,0.36,1), transform 0.55s cubic-bezier(0.22,1,0.36,1);
    transition-delay: var(--delay, 0s);
  }
  .anim-fade-up.visible { opacity: 1; transform: translateY(0); }

  .anim-item {
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.5s cubic-bezier(0.22,1,0.36,1), transform 0.5s cubic-bezier(0.22,1,0.36,1);
    transition-delay: calc(var(--i, 0) * 0.07s);
  }
  .anim-item.visible { opacity: 1; transform: translateY(0); }

  @media (prefers-reduced-motion: reduce) {
    .anim-fade-up, .anim-item { transition: none; opacity: 1; transform: none; }
  }
</style>

<script>
  // ── Billing toggle ──
  const plansSection = document.getElementById('plans-section')!;
  const btnMonthly   = document.getElementById('btn-monthly')!;
  const btnAnnual    = document.getElementById('btn-annual')!;

  function setPeriodo(periodo: string) {
    document.querySelectorAll<HTMLAnchorElement>('.plan-cta').forEach((btn) => {
      const url = new URL(btn.href);
      url.searchParams.set('periodo', periodo);
      btn.href = url.toString();
    });
  }

  btnAnnual.addEventListener('click', () => {
    plansSection.classList.add('is-annual');
    btnAnnual.classList.add('tbtn--active');
    btnAnnual.setAttribute('aria-pressed', 'true');
    btnMonthly.classList.remove('tbtn--active');
    btnMonthly.setAttribute('aria-pressed', 'false');
    setPeriodo('anual');
  });
  btnMonthly.addEventListener('click', () => {
    plansSection.classList.remove('is-annual');
    btnMonthly.classList.add('tbtn--active');
    btnMonthly.setAttribute('aria-pressed', 'true');
    btnAnnual.classList.remove('tbtn--active');
    btnAnnual.setAttribute('aria-pressed', 'false');
    setPeriodo('mensual');
  });

  // ── FAQ accordion ──
  document.querySelectorAll('.faq-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item   = btn.closest('.faq-item') as HTMLElement;
      const answer = item.querySelector('.faq-answer') as HTMLElement;
      const isOpen = item.classList.contains('open');

      // Close all
      document.querySelectorAll('.faq-item.open').forEach((i) => {
        i.classList.remove('open');
        (i.querySelector('.faq-answer') as HTMLElement).style.maxHeight = '';
        i.querySelector('.faq-btn')!.setAttribute('aria-expanded', 'false');
      });

      // Open clicked if was closed
      if (!isOpen) {
        item.classList.add('open');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // ── IntersectionObserver for animations ──
  const obs = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    }),
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.anim-fade-up, .anim-item').forEach((el) => obs.observe(el));
</script>
