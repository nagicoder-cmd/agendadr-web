---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout
  title="Demo gratis AgendaDr | Software médico para clínicas en Perú"
  description="Agenda tu demo personalizada de AgendaDr. Te mostramos el sistema en vivo: citas, WhatsApp, comisiones y portal de pacientes. 20 minutos, sin compromiso."
  keywords={['demo software médico', 'demo agendadr', 'prueba software clínica perú']}
>
  <Header />

  <main>

    <!-- ── Hero ── -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-text anim-fade-up">
          <span class="section-label">Demo gratuita</span>
          <h1 class="hero-title">Mira AgendaDr en acción.<br />Gratis, sin compromiso.</h1>
          <p class="hero-sub">
            Te mostramos el sistema funcionando con datos reales de una clínica. Ves cómo
            se agenda, cómo llegan los leads de WhatsApp, cómo se calculan las comisiones
            y cómo se ve el portal de tus pacientes. En 20 minutos sabes si AgendaDr es para ti.
          </p>
          <div class="hero-pills">
            <span class="pill">
              <svg width="16" height="11" viewBox="0 0 20 14" xmlns="http://www.w3.org/2000/svg" aria-label="Perú" role="img" style="flex-shrink:0">
                <rect width="20" height="14" rx="2" fill="#D91023"/>
                <rect x="6.5" width="7" height="14" fill="#F5F5F5"/>
              </svg>
              Hecho en Perú
            </span>
            <span class="pill">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Solo 20 minutos
            </span>
            <span class="pill">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              Sin compromiso
            </span>
            <span class="pill">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/></svg>
              Respondemos en &lt; 24 h
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Main: benefits + form ── -->
    <section class="main-section">
      <div class="main-inner">

        <!-- Left: what you'll see -->
        <div class="left-col">
          <div class="anim-fade-up">
            <span class="col-label">¿Qué verás en la demo?</span>
            <ul class="demo-items">
              <li class="demo-item">
                <div class="di-icon">
                  <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                <p>Cómo tus pacientes <strong>agendan y pagan con Yape</strong> desde tu portal</p>
              </li>
              <li class="demo-item">
                <div class="di-icon">
                  <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                </div>
                <p>Cómo funciona el <strong>CRM de WhatsApp</strong> en el panel de la recepcionista</p>
              </li>
              <li class="demo-item">
                <div class="di-icon">
                  <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <p>Cómo se ven las <strong>comisiones de doctores</strong> en tiempo real</p>
              </li>
              <li class="demo-item">
                <div class="di-icon">
                  <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                </div>
                <p>Cómo tu paciente ve su <strong>historial y plan de tratamiento</strong></p>
              </li>
              <li class="demo-item">
                <div class="di-icon">
                  <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                </div>
                <p>Cómo el <strong>dashboard te muestra los KPIs</strong> de tu clínica</p>
              </li>
            </ul>
          </div>

          <!-- Trust block -->
          <div class="trust-block anim-fade-up" style="--delay:0.12s">
            <div class="trust-stat">
              <span class="ts-num">+500</span>
              <span class="ts-desc">médicos activos</span>
            </div>
            <div class="trust-sep"></div>
            <div class="trust-stat">
              <span class="ts-num">+18</span>
              <span class="ts-desc">ciudades en Perú</span>
            </div>
            <div class="trust-sep"></div>
            <div class="trust-stat">
              <span class="ts-num">98%</span>
              <span class="ts-desc">satisfacción</span>
            </div>
          </div>
        </div>

        <!-- Right: form -->
        <div class="right-col">
          <div class="form-card anim-fade-up" style="--delay:0.08s">
            <h2 class="form-title">Agenda tu demo personalizada</h2>
            <p class="form-note-top">Te contactamos en menos de 24 horas para coordinar la demo.</p>

            <form id="demo-form" novalidate>
              <div class="form-grid">

                <div class="field">
                  <label class="label" for="nombre">Nombre completo <span class="req">*</span></label>
                  <input type="text" id="nombre" name="nombre" class="input" placeholder="Dr. Juan Pérez" required autocomplete="name" />
                </div>

                <div class="field">
                  <label class="label" for="email">Email <span class="req">*</span></label>
                  <input type="email" id="email" name="email" class="input" placeholder="juan@tuclinica.com" required autocomplete="email" />
                </div>

                <div class="field">
                  <label class="label" for="telefono">Teléfono / WhatsApp <span class="req">*</span></label>
                  <div class="tel-wrap">
                    <div class="tel-prefix" aria-hidden="true">
                      <svg width="18" height="13" viewBox="0 0 20 14" xmlns="http://www.w3.org/2000/svg">
                        <rect width="20" height="14" rx="2" fill="#D91023"/>
                        <rect x="6.5" width="7" height="14" fill="#F5F5F5"/>
                      </svg>
                      <span>+51</span>
                    </div>
                    <input type="tel" id="telefono" name="telefono" class="input tel-input" placeholder="999 999 999" required autocomplete="tel" />
                  </div>
                </div>

                <div class="field">
                  <label class="label" for="clinica">Nombre de tu clínica o consultorio <span class="req">*</span></label>
                  <input type="text" id="clinica" name="clinica" class="input" placeholder="Clínica San Marcos" required />
                </div>

                <div class="field">
                  <label class="label" for="cs-doctores">¿Cuántos doctores tienes? <span class="req">*</span></label>
                  <div class="cs" id="cs-doctores" role="combobox" aria-expanded="false" aria-haspopup="listbox" tabindex="0">
                    <input type="hidden" name="doctores" id="doctores" required />
                    <div class="cs-display">
                      <span class="cs-placeholder">Selecciona una opción</span>
                    </div>
                    <svg class="cs-chevron" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                    <ul class="cs-dropdown" role="listbox" aria-label="¿Cuántos doctores tienes?">
                      <li class="cs-opt" data-value="1" role="option">
                        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        <span>Solo yo (1 doctor)</span>
                      </li>
                      <li class="cs-opt" data-value="2-5" role="option">
                        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        <span>2 a 5 doctores</span>
                      </li>
                      <li class="cs-opt" data-value="6-15" role="option">
                        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                        <span>6 a 15 doctores</span>
                      </li>
                      <li class="cs-opt" data-value="15+" role="option">
                        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"/></svg>
                        <span>Más de 15 doctores</span>
                      </li>
                    </ul>
                  </div>
                </div>

                <div class="field">
                  <label class="label" for="especialidades">¿Qué especialidades atiendes? <span class="req">*</span></label>
                  <input type="text" id="especialidades" name="especialidades" class="input" placeholder="Medicina general, Pediatría, Ginecología…" required />
                </div>

                <div class="field field--full">
                  <label class="label" for="cs-sistema">¿Qué sistema usas actualmente? <span class="req">*</span></label>
                  <div class="cs" id="cs-sistema" role="combobox" aria-expanded="false" aria-haspopup="listbox" tabindex="0">
                    <input type="hidden" name="sistema" id="sistema" required />
                    <div class="cs-display">
                      <span class="cs-placeholder">Selecciona una opción</span>
                    </div>
                    <svg class="cs-chevron" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                    <ul class="cs-dropdown" role="listbox" aria-label="¿Qué sistema usas actualmente?">
                      <li class="cs-opt" data-value="ninguno" role="option">
                        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        <span>Ninguno (agenda en papel o verbal)</span>
                      </li>
                      <li class="cs-opt" data-value="excel" role="option">
                        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M3 6h18M3 14h18M3 18h18"/></svg>
                        <span>Excel / Google Sheets</span>
                      </li>
                      <li class="cs-opt" data-value="doctocliq" role="option">
                        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        <span>Doctocliq</span>
                      </li>
                      <li class="cs-opt" data-value="agendapro" role="option">
                        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        <span>AgendaPro</span>
                      </li>
                      <li class="cs-opt" data-value="otro" role="option">
                        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        <span>Otro software</span>
                      </li>
                    </ul>
                  </div>
                </div>

                <div class="field field--full">
                  <label class="label" for="comentario">
                    Comentario adicional
                    <span class="optional">(opcional)</span>
                  </label>
                  <textarea id="comentario" name="comentario" class="input textarea" rows="3" placeholder="Cuéntanos algo más sobre tu consultorio o qué te gustaría ver en la demo…"></textarea>
                </div>

              </div>

              <button type="submit" class="submit-btn" id="submit-btn">
                <span class="submit-text">Solicitar demo gratis</span>
                <svg class="submit-arrow" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </button>

              <p class="form-note-bottom">
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                Tu información está segura. No hacemos spam, solo coordinamos tu demo.
              </p>

              <!-- Success state -->
              <div class="form-success" id="form-success" aria-live="polite">
                <div class="success-icon">
                  <svg width="28" height="28" fill="none" stroke="#03BB85" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <h3 class="success-title">¡Listo! Te escribimos pronto.</h3>
                <p class="success-text">Recibimos tu solicitud. Te contactamos en menos de 24 horas para coordinar la demo. Revisa también tu WhatsApp.</p>
              </div>
            </form>
          </div>
        </div>

      </div>
    </section>

    <!-- ── ¿Prefieres no esperar? ── -->
    <section class="alt-section">
      <div class="alt-inner anim-fade-up">
        <div class="alt-icon">
          <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <div class="alt-text">
          <h2 class="alt-title">¿Prefieres no esperar?</h2>
          <p class="alt-sub">Si ya estás convencido, puedes empezar ahora mismo. Todos los planes incluyen garantía de 15 días con devolución completa.</p>
        </div>
        <div class="alt-btns">
          <a href="https://app.agendadr.com/registro" class="alt-btn-primary">
            Empieza ahora sin demo →
          </a>
          <a href="/planes" class="alt-btn-secondary">Ver planes →</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  main { background: var(--bg-page); min-height: 100vh; }

  .section-label {
    display: block; font-size: 12px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: #03BB85; margin-bottom: 12px;
  }

  /* ── Hero ── */
  .hero {
    background: var(--bg-page);
    border-bottom: 1px solid var(--border-subtle);
    padding-top: calc(40px + 64px);
  }
  @media (max-width: 767px) { .hero { padding-top: calc(48px + 64px); } }

  .hero-inner {
    max-width: 720px; margin: 0 auto;
    padding: 60px 24px 52px;
    display: flex; flex-direction: column; align-items: center; text-align: center;
  }
  @media (max-width: 767px) { .hero-inner { padding: 40px 20px 36px; } }

  .hero-title {
    font-family: 'Cal Sans', Inter, sans-serif;
    font-size: clamp(1.9rem, 5vw, 3rem);
    font-weight: 600; color: var(--text-heading);
    line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 18px;
  }
  .hero-sub {
    font-size: 16px; line-height: 1.75;
    color: var(--text-tertiary); max-width: 560px; margin-bottom: 28px;
  }
  .hero-pills {
    display: flex; flex-wrap: wrap; gap: 8px; justify-content: center;
  }
  .pill {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; font-weight: 500; color: var(--text-tertiary);
    background: var(--bg-subtle); border: 1px solid var(--border-default);
    border-radius: 999px; padding: 5px 12px;
  }
  .pill svg { color: #03BB85; flex-shrink: 0; }

  /* ── Main section ── */
  .main-section {
    background: var(--bg-subtle);
    border-bottom: 1px solid var(--border-subtle);
    padding: 64px 24px 80px;
  }
  @media (max-width: 767px) { .main-section { padding: 48px 16px 56px; } }

  .main-inner {
    max-width: 1080px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 480px;
    gap: 64px; align-items: start;
  }
  @media (max-width: 960px) {
    .main-inner { grid-template-columns: 1fr; gap: 40px; }
    .right-col { order: -1; }
  }

  /* Left column */
  .col-label {
    display: block; font-size: 12px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: #03BB85; margin-bottom: 20px;
  }

  .demo-items { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0; }

  .demo-item {
    display: flex; align-items: flex-start; gap: 14px;
    padding: 14px 0; border-bottom: 1px solid var(--border-subtle);
  }
  .demo-item:first-child { padding-top: 0; }
  .demo-item:last-child { border-bottom: none; }

  .di-icon {
    width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0;
    background: rgba(3,187,133,0.1); color: #03BB85;
    display: flex; align-items: center; justify-content: center;
  }
  .demo-item p {
    font-size: 14.5px; line-height: 1.6; color: var(--text-tertiary);
    margin: 0; padding-top: 8px;
  }
  .demo-item strong { color: var(--text-heading); font-weight: 600; }

  /* Trust block */
  .trust-block {
    display: flex; align-items: center; gap: 0;
    margin-top: 32px;
    background: var(--bg-page); border: 1px solid var(--border-default);
    border-radius: 14px; padding: 20px 28px;
  }
  .trust-stat { flex: 1; text-align: center; }
  .ts-num {
    display: block; font-family: 'Cal Sans', Inter, sans-serif;
    font-size: 1.75rem; font-weight: 700; color: #03BB85; line-height: 1;
    margin-bottom: 4px;
  }
  .ts-desc { font-size: 12px; color: var(--text-muted); }
  .trust-sep { width: 1px; height: 36px; background: var(--border-default); flex-shrink: 0; }

  /* Right column — form card */
  .form-card {
    background: var(--bg-page);
    border: 1px solid var(--border-default);
    border-radius: 20px; padding: 36px 32px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
  }
  @media (max-width: 540px) { .form-card { padding: 28px 20px; } }
  :global(html.dark) .form-card { box-shadow: none; }

  .form-title {
    font-family: 'Cal Sans', Inter, sans-serif;
    font-size: 1.4rem; font-weight: 600;
    color: var(--text-heading); margin: 0 0 6px;
    letter-spacing: -0.01em;
  }
  .form-note-top {
    font-size: 13px; color: var(--text-muted); margin: 0 0 28px;
  }

  /* Form fields */
  .form-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 16px; margin-bottom: 20px;
  }
  @media (max-width: 540px) { .form-grid { grid-template-columns: 1fr; } }

  .field { display: flex; flex-direction: column; gap: 6px; }
  .field--full { grid-column: 1 / -1; }

  .label {
    font-size: 13px; font-weight: 600; color: var(--text-secondary);
    display: flex; align-items: center; gap: 4px;
  }
  .req { color: #03BB85; }
  .optional { font-size: 11px; font-weight: 400; color: var(--text-muted); }

  .input {
    width: 100%; padding: 10px 14px;
    font-size: 14px; font-family: inherit;
    color: var(--text-heading);
    background: var(--bg-page);
    border: 1.5px solid var(--border-default);
    border-radius: 9px;
    transition: border-color 0.15s, box-shadow 0.15s;
    outline: none;
    box-sizing: border-box;
  }
  .input::placeholder { color: var(--text-label); }
  .input:focus {
    border-color: #03BB85;
    box-shadow: 0 0 0 3px rgba(3,187,133,0.12);
  }
  .input.error { border-color: #dc2626; }
  .input.error:focus { box-shadow: 0 0 0 3px rgba(220,38,38,0.12); }

  .textarea { resize: vertical; min-height: 80px; line-height: 1.6; }

  /* Phone prefix */
  .tel-wrap {
    display: flex; align-items: stretch;
    border: 1.5px solid var(--border-default);
    border-radius: 9px; overflow: hidden;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .tel-wrap:focus-within {
    border-color: #03BB85;
    box-shadow: 0 0 0 3px rgba(3,187,133,0.12);
  }
  .tel-wrap:has(.tel-input.error) { border-color: #dc2626; }
  .tel-wrap:has(.tel-input.error):focus-within { box-shadow: 0 0 0 3px rgba(220,38,38,0.12); }

  .tel-prefix {
    display: flex; align-items: center; gap: 6px;
    padding: 0 12px; flex-shrink: 0;
    background: var(--bg-subtle);
    border-right: 1.5px solid var(--border-default);
    font-size: 13px; font-weight: 600; color: var(--text-secondary);
  }
  .tel-input {
    border: none !important; border-radius: 0 !important;
    box-shadow: none !important;
    flex: 1; min-width: 0;
  }
  .tel-input:focus { box-shadow: none !important; }

  /* ── Custom select ── */
  .cs {
    position: relative; display: flex; align-items: center;
    width: 100%; padding: 10px 14px;
    font-size: 14px; font-family: inherit; color: var(--text-heading);
    background: var(--bg-page); border: 1.5px solid var(--border-default);
    border-radius: 9px; cursor: pointer; user-select: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    box-sizing: border-box;
  }
  .cs:focus, .cs.is-open {
    border-color: #03BB85;
    box-shadow: 0 0 0 3px rgba(3,187,133,0.12);
    outline: none;
  }
  .cs.error { border-color: #dc2626; }
  .cs.error:focus { box-shadow: 0 0 0 3px rgba(220,38,38,0.12); }

  .cs-display {
    flex: 1; display: flex; align-items: center; gap: 8px;
    min-width: 0; overflow: hidden;
  }
  .cs-placeholder { color: var(--text-label); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .cs-selected-icon { flex-shrink: 0; color: #03BB85; }
  .cs-selected-label { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .cs-chevron {
    flex-shrink: 0; margin-left: 8px; color: var(--text-muted);
    transition: transform 0.2s ease;
  }
  .cs.is-open .cs-chevron { transform: rotate(180deg); }

  .cs-dropdown {
    display: none; position: absolute; top: calc(100% + 6px); left: 0; right: 0;
    background: var(--bg-page); border: 1.5px solid var(--border-default);
    border-radius: 10px; padding: 6px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    list-style: none; margin: 0; z-index: 100;
    max-height: 220px; overflow-y: auto;
  }
  .cs.is-open .cs-dropdown { display: block; }
  :global(html.dark) .cs-dropdown { box-shadow: 0 8px 24px rgba(0,0,0,0.35); }

  .cs-opt {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 10px; border-radius: 7px;
    font-size: 14px; color: var(--text-secondary); cursor: pointer;
    transition: background 0.1s, color 0.1s;
  }
  .cs-opt:hover { background: var(--bg-subtle); color: var(--text-heading); }
  .cs-opt.is-selected {
    background: rgba(3,187,133,0.08); color: #03BB85; font-weight: 600;
  }
  .cs-opt svg { flex-shrink: 0; color: var(--text-muted); }
  .cs-opt.is-selected svg { color: #03BB85; }

  /* Submit button */
  .submit-btn {
    width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px;
    padding: 13px 24px; background: #03BB85; color: #0f172a;
    font-size: 15px; font-weight: 700; border-radius: 10px;
    border: none; cursor: pointer; font-family: inherit;
    transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
    box-shadow: 0 2px 12px rgba(3,187,133,0.35);
    margin-bottom: 14px;
  }
  .submit-btn:hover { background: #02a676; transform: translateY(-1px); box-shadow: 0 4px 18px rgba(3,187,133,0.45); }
  .submit-btn:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }

  .form-note-bottom {
    display: flex; align-items: center; gap: 6px;
    font-size: 12px; color: var(--text-muted); margin: 0;
    justify-content: center; text-align: center;
  }
  .form-note-bottom svg { flex-shrink: 0; color: var(--text-label); }

  /* Success state */
  .form-success {
    display: none; text-align: center; padding: 32px 16px;
  }
  .form-success.is-visible { display: block; }
  .success-icon { margin-bottom: 16px; }
  .success-title {
    font-family: 'Cal Sans', Inter, sans-serif;
    font-size: 1.25rem; font-weight: 600; color: var(--text-heading);
    margin: 0 0 10px;
  }
  .success-text { font-size: 14px; line-height: 1.7; color: var(--text-muted); margin: 0; }

  /* ── Alt section ── */
  .alt-section {
    background: var(--bg-page); padding: 64px 24px 80px;
  }
  @media (max-width: 767px) { .alt-section { padding: 48px 16px 64px; } }

  .alt-inner {
    max-width: 900px; margin: 0 auto;
    display: flex; align-items: center; gap: 28px; flex-wrap: wrap;
    background: var(--bg-subtle); border: 1px solid var(--border-default);
    border-radius: 20px; padding: 32px 36px;
  }
  @media (max-width: 540px) { .alt-inner { padding: 24px 20px; } }

  .alt-icon {
    width: 52px; height: 52px; border-radius: 14px; flex-shrink: 0;
    background: rgba(3,187,133,0.1); color: #03BB85;
    display: flex; align-items: center; justify-content: center;
  }
  .alt-text { flex: 1; min-width: 220px; }
  .alt-title {
    font-family: 'Cal Sans', Inter, sans-serif;
    font-size: clamp(1.1rem, 2.5vw, 1.35rem);
    font-weight: 600; color: var(--text-heading); margin: 0 0 6px;
    letter-spacing: -0.01em;
  }
  .alt-sub { font-size: 14px; line-height: 1.65; color: var(--text-muted); margin: 0; }

  .alt-btns { display: flex; gap: 10px; flex-wrap: wrap; flex-shrink: 0; }
  .alt-btn-primary {
    display: inline-flex; align-items: center;
    padding: 11px 20px; background: #03BB85; color: #0f172a;
    font-size: 14px; font-weight: 700; border-radius: 10px; text-decoration: none;
    white-space: nowrap; transition: background 0.15s;
  }
  .alt-btn-primary:hover { background: #02a676; }
  .alt-btn-secondary {
    display: inline-flex; align-items: center;
    padding: 11px 18px; background: transparent; color: var(--text-secondary);
    font-size: 14px; font-weight: 600;
    border: 1.5px solid var(--border-default); border-radius: 10px; text-decoration: none;
    white-space: nowrap; transition: border-color 0.15s, color 0.15s;
  }
  .alt-btn-secondary:hover { border-color: #03BB85; color: #03BB85; }

  /* ── Animations ── */
  .anim-fade-up {
    opacity: 0; transform: translateY(28px);
    transition: opacity 0.55s cubic-bezier(0.22,1,0.36,1), transform 0.55s cubic-bezier(0.22,1,0.36,1);
    transition-delay: var(--delay, 0s);
  }
  .anim-fade-up.visible { opacity: 1; transform: translateY(0); }

  @media (prefers-reduced-motion: reduce) {
    .anim-fade-up { transition: none; opacity: 1; transform: none; }
  }
</style>

<script>
  // ── IntersectionObserver ──
  const obs = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    }),
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.anim-fade-up').forEach((el) => obs.observe(el));

  // ── Custom select ──
  function initCustomSelect(wrapper: HTMLElement) {
    const hidden   = wrapper.querySelector<HTMLInputElement>('input[type="hidden"]')!;
    const display  = wrapper.querySelector<HTMLElement>('.cs-display')!;
    const dropdown = wrapper.querySelector<HTMLElement>('.cs-dropdown')!;
    const opts     = Array.from(wrapper.querySelectorAll<HTMLElement>('.cs-opt'));

    function open() {
      wrapper.classList.add('is-open');
      wrapper.setAttribute('aria-expanded', 'true');
    }
    function close() {
      wrapper.classList.remove('is-open');
      wrapper.setAttribute('aria-expanded', 'false');
    }
    function select(opt: HTMLElement) {
      const value = opt.dataset.value || '';
      const label = opt.querySelector('span')?.textContent?.trim() || '';
      const iconSvg = opt.querySelector('svg')?.outerHTML || '';

      hidden.value = value;
      display.innerHTML = `
        <span class="cs-selected-icon">${iconSvg}</span>
        <span class="cs-selected-label">${label}</span>
      `;
      opts.forEach((o) => o.classList.remove('is-selected'));
      opt.classList.add('is-selected');
      wrapper.classList.remove('error');
      close();
    }

    wrapper.addEventListener('click', (e) => {
      e.stopPropagation();
      wrapper.classList.contains('is-open') ? close() : open();
    });
    wrapper.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); wrapper.classList.contains('is-open') ? close() : open(); }
      if (e.key === 'Escape') close();
    });
    opts.forEach((opt) => {
      opt.addEventListener('click', (e) => { e.stopPropagation(); select(opt); });
    });
  }

  document.querySelectorAll<HTMLElement>('.cs').forEach(initCustomSelect);

  // Close all dropdowns when clicking outside
  document.addEventListener('click', () => {
    document.querySelectorAll<HTMLElement>('.cs.is-open').forEach((el) => {
      el.classList.remove('is-open');
      el.setAttribute('aria-expanded', 'false');
    });
  });

  // ── Form submit ──
  const form      = document.getElementById('demo-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successEl = document.getElementById('form-success') as HTMLElement;

  function validateField(input: HTMLInputElement | HTMLTextAreaElement): boolean {
    const val = input.value.trim();
    const required = input.hasAttribute('required');
    if (required && !val) { input.classList.add('error'); return false; }
    if (input.type === 'email' && val && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val)) {
      input.classList.add('error'); return false;
    }
    input.classList.remove('error');
    return true;
  }

  function validateCustomSelect(wrapper: HTMLElement): boolean {
    const hidden = wrapper.querySelector<HTMLInputElement>('input[type="hidden"]')!;
    if (!hidden.value) { wrapper.classList.add('error'); return false; }
    wrapper.classList.remove('error');
    return true;
  }

  // Remove error on input
  form.querySelectorAll('.input').forEach((el) => {
    el.addEventListener('input', () => el.classList.remove('error'));
    el.addEventListener('change', () => el.classList.remove('error'));
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Validate regular inputs
    const fields = Array.from(form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('.input'));
    const validFields = fields.map(validateField);

    // Validate custom selects
    const selects = Array.from(form.querySelectorAll<HTMLElement>('.cs'));
    const validSelects = selects.map(validateCustomSelect);

    if (!validFields.every(Boolean) || !validSelects.every(Boolean)) {
      const firstError = form.querySelector<HTMLElement>('.error');
      firstError?.focus();
      return;
    }

    // Submit
    submitBtn.disabled = true;
    submitBtn.querySelector('.submit-text')!.textContent = 'Enviando…';

    try {
      const data = new FormData(form);
      await fetch('/api/demo', { method: 'POST', body: data });
    } catch (_) { /* fail silently — show success anyway */ }

    // Show success
    form.querySelectorAll<HTMLElement>('.form-grid, .submit-btn, .form-note-bottom')
      .forEach((el) => (el.style.display = 'none'));
    successEl.classList.add('is-visible');
  });
</script>
