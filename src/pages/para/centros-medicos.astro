---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---
<BaseLayout
  title="Software para centros médicos en Perú | AgendaDr"
  description="Sistema para centros médicos con múltiples especialidades. Dashboard consolidado, CRM WhatsApp, comisiones automáticas, multi-sede. Plan Clínica S/599/mes."
>
  <Header />
  <main>

    <!-- HERO -->
    <section class="hero-section">
      <div class="container">
        <div class="hero-badge">Para centros médicos</div>
        <h1 class="hero-headline">Múltiples especialidades, múltiples doctores.<br class="dbr"> Un solo sistema.</h1>
        <p class="hero-sub">AgendaDr está diseñado para centros médicos con varias especialidades, equipos grandes y alto volumen de pacientes. Dashboard consolidado, CRM WhatsApp completo, comisiones automáticas y reportes avanzados.</p>
        <div class="hero-actions">
          <a href="https://app.agendadr.com/registro" class="btn-primary">Empieza ahora →</a>
          <a href="/demo" class="btn-ghost">Pide una demo gratis</a>
        </div>
        <div class="hero-trust">
          <span>✅ Garantía 15 días</span>
          <span>✅ Onboarding asistido</span>
          <span>✅ Soporte prioritario</span>
        </div>
      </div>
    </section>

    <!-- PARA QUIÉN -->
    <section class="forwhom-section anim-fade-up">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">¿Es para ti?</span>
          <h2>Si tu centro médico tiene esto, AgendaDr es para ti.</h2>
        </div>
        <div class="forwhom-list">
          <div class="fw-item anim-item"><span class="fw-check">✅</span><span>Más de 5 doctores en distintas especialidades</span></div>
          <div class="fw-item anim-item"><span class="fw-check">✅</span><span>Varias recepcionistas gestionando agenda y WhatsApp</span></div>
          <div class="fw-item anim-item"><span class="fw-check">✅</span><span>Campañas en Meta Ads para captar pacientes</span></div>
          <div class="fw-item anim-item"><span class="fw-check">✅</span><span>Necesidad de controlar comisiones, ingresos y rendimiento por doctor</span></div>
          <div class="fw-item anim-item"><span class="fw-check">✅</span><span>Una o más sedes</span></div>
        </div>
      </div>
    </section>

    <!-- QUÉ OBTIENES -->
    <section class="features-section anim-fade-up">
      <div class="container">
        <div class="section-header">
          <h2>Todo lo que un centro médico necesita para funcionar al 100%</h2>
        </div>
        <div class="features-grid">
          <div class="feat-card anim-item">
            <div class="fc-icon"><svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg></div>
            <h3>Dashboard con KPIs en tiempo real</h3>
            <p>Citas, ingresos, ocupación por doctor, leads del CRM, cancelaciones. Todo al abrir el sistema.</p>
          </div>
          <div class="feat-card anim-item">
            <div class="fc-icon"><svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg></div>
            <h3>CRM WhatsApp completo</h3>
            <p>Pipeline de leads, seguimientos programados, asignación por recepcionista, métricas de conversión y ROI por campaña de Meta Ads.</p>
          </div>
          <div class="feat-card anim-item">
            <div class="fc-icon"><svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg></div>
            <h3>Comisiones automáticas</h3>
            <p>Bruto, comisión y neto por cada doctor. Porcentajes diferentes según el acuerdo. Exportable en PDF y Excel.</p>
          </div>
          <div class="feat-card anim-item">
            <div class="fc-icon"><svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg></div>
            <h3>Catálogo de servicios controlado</h3>
            <p>Define servicios por especialidad con rangos de precio. Los doctores eligen del catálogo y ajustan dentro de tu rango.</p>
          </div>
          <div class="feat-card anim-item">
            <div class="fc-icon"><svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div>
            <h3>Multi-sede</h3>
            <p>Gestiona varias ubicaciones desde un solo dashboard. Reportes consolidados o por sede.</p>
          </div>
          <div class="feat-card anim-item">
            <div class="fc-icon"><svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg></div>
            <h3>Portal de pacientes</h3>
            <p>Cada paciente ve sus citas, recetas, plan de tratamiento y reagenda sin llamar.</p>
          </div>
          <div class="feat-card anim-item">
            <div class="fc-icon"><svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
            <h3>Cobros con Yape, Plin y tarjeta</h3>
            <p>Integrado con Culqi. El paciente paga al agendar. Registrado automáticamente.</p>
          </div>
          <div class="feat-card anim-item">
            <div class="fc-icon"><svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg></div>
            <h3>Soporte prioritario</h3>
            <p>Respuesta en menos de 2 horas. Onboarding asistido incluido en el plan Clínica.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- PLANES -->
    <section class="plans-section anim-fade-up">
      <div class="container">
        <div class="section-header">
          <h2>Planes recomendados para centros médicos</h2>
        </div>
        <div class="plans-grid">
          <div class="plan-card featured anim-item">
            <div class="plan-popular">⭐ Recomendado para centros médicos</div>
            <div class="plan-name">Clínica</div>
            <div class="plan-price">S/599<span>/mes</span></div>
            <ul class="plan-feats">
              <li>15 doctores · 5 recepcionistas</li>
              <li>Multi-sede</li>
              <li>CRM WhatsApp completo</li>
              <li>Reportes consolidados</li>
              <li>Comisiones automáticas</li>
              <li>Soporte prioritario</li>
              <li>Onboarding asistido</li>
              <li>✅ Garantía 15 días</li>
            </ul>
            <a href="https://app.agendadr.com/registro" class="btn-plan">Empezar ahora →</a>
          </div>
          <div class="plan-card anim-item">
            <div class="plan-name">Enterprise</div>
            <div class="plan-price-alt">Cotizar</div>
            <ul class="plan-feats">
              <li>Doctores y sedes ilimitadas</li>
              <li>API e integraciones custom</li>
              <li>Migración de datos dedicada</li>
              <li>Onboarding completo</li>
              <li>SLA garantizado</li>
              <li>Gerente de cuenta asignado</li>
            </ul>
            <a href="/contacto" class="btn-plan-ghost">Contáctanos →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="cta-section anim-fade-up">
      <div class="container">
        <div class="cta-card">
          <h2>Tu centro médico merece un sistema a su nivel.</h2>
          <p>Gestión completa para múltiples especialidades y doctores. Garantía de 15 días.</p>
          <div class="cta-actions">
            <a href="https://app.agendadr.com/registro" class="btn-cta-white">Empieza ahora →</a>
            <a href="/demo" class="btn-cta-ghost">Pide una demo gratis →</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  * { box-sizing:border-box; }
  main { overflow-x:hidden; }
  .container { max-width:1100px; margin:0 auto; padding:0 24px; }
  .dbr { display:none; }
  @media (min-width:768px) { .dbr { display:block; } }
  :root { --green:#03BB85; --green-dark:#029e70; --green-light:rgba(3,187,133,0.1); }

  .btn-primary { display:inline-flex; align-items:center; background:var(--green); color:#fff; font-weight:600; font-size:1rem; padding:13px 28px; border-radius:10px; text-decoration:none; transition:background 150ms, transform 150ms; }
  .btn-primary:hover { background:var(--green-dark); transform:translateY(-1px); }
  .btn-ghost { display:inline-flex; align-items:center; padding:13px 24px; border:1.5px solid var(--border-default,#e2e8f0); border-radius:10px; font-weight:500; font-size:1rem; color:var(--text-heading,#0f172a); text-decoration:none; transition:border-color 150ms, background 150ms; }
  .btn-ghost:hover { border-color:var(--green); background:var(--green-light); }
  .btn-cta-white { display:inline-flex; align-items:center; background:#fff; color:var(--green); font-weight:700; font-size:1rem; padding:14px 32px; border-radius:10px; text-decoration:none; transition:background 150ms; }
  .btn-cta-white:hover { background:rgba(255,255,255,.9); }
  .btn-cta-ghost { display:inline-flex; align-items:center; padding:14px 28px; border:1.5px solid rgba(255,255,255,.35); border-radius:10px; font-weight:500; font-size:1rem; color:rgba(255,255,255,.9); text-decoration:none; transition:border-color 150ms, background 150ms; }
  .btn-cta-ghost:hover { border-color:#fff; background:rgba(255,255,255,.1); }

  .section-header { text-align:center; margin-bottom:48px; }
  .section-header h2 { font-size:clamp(1.6rem,3.5vw,2.2rem); font-weight:700; color:var(--text-heading,#0f172a); margin:0 auto; max-width:700px; }
  .section-tag { display:inline-block; background:var(--green-light); color:var(--green); font-size:.78rem; font-weight:600; letter-spacing:.06em; text-transform:uppercase; padding:4px 12px; border-radius:99px; margin-bottom:14px; }

  .anim-fade-up { opacity:0; transform:translateY(28px); transition:opacity .55s ease, transform .55s ease; }
  .anim-fade-up.visible { opacity:1; transform:none; }
  .anim-item { opacity:0; transform:translateY(20px); transition:opacity .45s ease, transform .45s ease; }
  .anim-item.visible { opacity:1; transform:none; }
  @media (prefers-reduced-motion:reduce) { .anim-fade-up,.anim-item { opacity:1; transform:none; transition:none; } }

  .hero-section { padding:140px 0 80px; text-align:center; background:var(--bg-subtle,#f8fafc); }
  :global(html.dark) .hero-section { background:rgba(255,255,255,.02); }
  .hero-badge { display:inline-block; background:var(--green-light); color:var(--green); font-size:.8rem; font-weight:600; padding:6px 14px; border-radius:99px; margin-bottom:20px; }
  .hero-headline { font-size:clamp(1.9rem,4.5vw,3rem); font-weight:800; color:var(--text-heading,#0f172a); line-height:1.18; margin:0 auto 20px; max-width:800px; }
  .hero-sub { font-size:1.05rem; color:var(--text-secondary,#475569); max-width:640px; margin:0 auto 36px; line-height:1.7; }
  .hero-actions { display:flex; flex-wrap:wrap; gap:12px; justify-content:center; margin-bottom:24px; }
  .hero-trust { display:flex; flex-wrap:wrap; gap:16px; justify-content:center; font-size:.82rem; color:var(--text-muted,#94a3b8); }

  .forwhom-section { padding:72px 0; }
  .forwhom-list { display:flex; flex-direction:column; gap:10px; max-width:600px; margin:0 auto; }
  .fw-item { display:flex; align-items:center; gap:14px; background:var(--bg-subtle,#f8fafc); border:1.5px solid var(--border-default,#e2e8f0); border-radius:10px; padding:14px 18px; font-size:.92rem; color:var(--text-secondary,#475569); }
  :global(html.dark) .fw-item { background:rgba(255,255,255,.04); border-color:rgba(255,255,255,.08); }
  .fw-check { font-size:1rem; flex-shrink:0; }

  .features-section { padding:88px 0; background:var(--bg-subtle,#f8fafc); }
  :global(html.dark) .features-section { background:rgba(255,255,255,.02); }
  .features-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:18px; }
  .feat-card { background:var(--bg-page,#fff); border:1.5px solid var(--border-default,#e2e8f0); border-radius:14px; padding:26px; transition:border-color 200ms, box-shadow 200ms; }
  .feat-card:hover { border-color:var(--green); box-shadow:0 4px 16px rgba(3,187,133,.1); }
  :global(html.dark) .feat-card { background:rgba(255,255,255,.04); border-color:rgba(255,255,255,.08); }
  .fc-icon { width:44px; height:44px; background:var(--green-light); color:var(--green); border-radius:10px; display:flex; align-items:center; justify-content:center; margin-bottom:14px; }
  .feat-card h3 { font-size:.92rem; font-weight:700; color:var(--text-heading,#0f172a); margin:0 0 8px; }
  .feat-card p { font-size:.85rem; color:var(--text-secondary,#475569); margin:0; line-height:1.6; }

  .plans-section { padding:88px 0; }
  .plans-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:20px; max-width:700px; margin:0 auto; }
  .plan-card { background:var(--bg-subtle,#f8fafc); border:1.5px solid var(--border-default,#e2e8f0); border-radius:16px; padding:28px; }
  .plan-card.featured { background:var(--bg-page,#fff); border-color:var(--green); box-shadow:0 4px 28px rgba(3,187,133,.15); }
  :global(html.dark) .plan-card { background:rgba(255,255,255,.04); border-color:rgba(255,255,255,.08); }
  :global(html.dark) .plan-card.featured { background:rgba(255,255,255,.06); border-color:var(--green); }
  .plan-popular { font-size:.75rem; font-weight:700; color:var(--green); margin-bottom:10px; }
  .plan-name { font-size:.78rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--text-muted,#94a3b8); margin-bottom:6px; }
  .plan-price { font-size:2.2rem; font-weight:800; color:var(--text-heading,#0f172a); margin-bottom:16px; }
  .plan-price span { font-size:.9rem; font-weight:400; color:var(--text-muted,#94a3b8); }
  .plan-price-alt { font-size:1.8rem; font-weight:800; color:var(--text-heading,#0f172a); margin-bottom:16px; }
  .plan-feats { list-style:none; margin:0 0 20px; padding:0; display:flex; flex-direction:column; gap:8px; }
  .plan-feats li { font-size:.85rem; color:var(--text-secondary,#475569); }
  .btn-plan { display:inline-flex; align-items:center; background:var(--green); color:#fff; font-weight:600; font-size:.9rem; padding:11px 22px; border-radius:9px; text-decoration:none; transition:background 150ms; }
  .btn-plan:hover { background:var(--green-dark); }
  .btn-plan-ghost { display:inline-flex; align-items:center; border:1.5px solid var(--green); color:var(--green); font-weight:600; font-size:.9rem; padding:11px 22px; border-radius:9px; text-decoration:none; transition:background 150ms, color 150ms; }
  .btn-plan-ghost:hover { background:var(--green); color:#fff; }

  .cta-section { padding:88px 0; background:var(--bg-subtle,#f8fafc); }
  :global(html.dark) .cta-section { background:rgba(255,255,255,.02); }
  .cta-card { background:linear-gradient(135deg,#02a876 0%,#03BB85 50%,#05d49a 100%); border-radius:20px; padding:64px 48px; text-align:center; box-shadow:0 16px 56px rgba(3,187,133,.3); }
  .cta-card h2 { font-size:clamp(1.6rem,3.5vw,2.4rem); font-weight:800; color:#fff; margin:0 0 16px; }
  .cta-card p { font-size:1.05rem; color:rgba(255,255,255,.9); max-width:560px; margin:0 auto 36px; line-height:1.65; }
  .cta-actions { display:flex; flex-wrap:wrap; gap:12px; justify-content:center; }
  @media (max-width:640px) { .cta-card { padding:44px 24px; } .hero-section { padding:120px 0 60px; } }
</style>

<script>
  const obs = new IntersectionObserver(e => { e.forEach(el => { if(el.isIntersecting) { el.target.classList.add('visible'); el.target.querySelectorAll('.anim-item').forEach((i,n) => setTimeout(()=>i.classList.add('visible'),n*80)); } }); }, {threshold:0.1});
  document.querySelectorAll('.anim-fade-up').forEach(el => obs.observe(el));
</script>
