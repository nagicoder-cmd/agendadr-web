---
const year = new Date().getFullYear();

const columns = [
  {
    title: 'Empresa',
    links: [
      { href: '/planes',          label: 'Precios' },
      { href: '/demo',            label: 'Pedir demo' },
      { href: '/casos-de-exito',  label: 'Casos de éxito' },
      { href: '/nosotros',        label: 'Nosotros' },
      { href: '/contacto',        label: 'Contacto' },
      { href: '/centro-de-ayuda', label: 'Centro de ayuda' },
    ],
  },
  {
    title: 'Funcionalidades',
    links: [
      { href: '/funcionalidades/citas-online',     label: 'Citas online' },
      { href: '/funcionalidades/pagos-medicos',     label: 'Pagos médicos' },
      { href: '/funcionalidades/whatsapp-clinicas', label: 'WhatsApp automático' },
      { href: '/funcionalidades/historial-medico',  label: 'Historial médico' },
      { href: '/funcionalidades/recetas-digitales', label: 'Recetas digitales' },
      { href: '/funcionalidades/reportes',          label: 'Reportes' },
      { href: '/funcionalidades/comisiones',        label: 'Comisiones' },
      { href: '/funcionalidades/multi-sede',        label: 'Multi-sede' },
    ],
  },
  {
    title: 'Especialidades',
    links: [
      { href: '/especialidades/odontologia',      label: 'Odontología' },
      { href: '/especialidades/psicologia',       label: 'Psicología' },
      { href: '/especialidades/dermatologia',     label: 'Dermatología' },
      { href: '/especialidades/ginecologia',      label: 'Ginecología' },
      { href: '/especialidades/pediatria',        label: 'Pediatría' },
      { href: '/especialidades/nutricion',        label: 'Nutrición' },
      { href: '/especialidades/fisioterapia',     label: 'Fisioterapia' },
      { href: '/especialidades/medicina-general', label: 'Medicina general' },
    ],
  },
  {
    title: 'Para quién',
    links: [
      { href: '/para/doctores',        label: 'Doctores' },
      { href: '/para/consultorios',    label: 'Consultorios' },
      { href: '/para/clinicas',        label: 'Clínicas' },
      { href: '/para/centros-medicos', label: 'Centros médicos' },
      { href: '/para/policlinicos',    label: 'Policlínicos' },
    ],
  },
  {
    title: 'Comparar',
    links: [
      { href: '/comparar/excel',      label: 'vs Excel' },
      { href: '/comparar/doctocliq',  label: 'vs DoctorCliq' },
      { href: '/comparar/agendapro',  label: 'vs AgendaPro' },
      { href: '/comparar/doctoralia', label: 'vs Doctoralia' },
      { href: '/comparar/medinet',    label: 'vs Medinet' },
    ],
  },
];

const legalLinks = [
  { href: '/terminos',               label: 'Términos' },
  { href: '/privacidad',             label: 'Privacidad' },
  { href: '/cookies',                label: 'Cookies' },
  { href: '/libro-de-reclamaciones', label: 'Libro de reclamaciones' },
];
---

<footer class="site-footer">

  <!-- Desktop: brand + columns | Mobile: brand compacto + acordeones -->
  <div class="footer-body">

    <!-- Brand -->
    <div class="footer-brand">
      <a href="/" class="footer-logo">Agenda<span>Dr</span></a>
      <p class="footer-tagline">La plataforma de gestión de citas médicas más sencilla para clínicas y consultorios en Perú.</p>
      <span class="footer-badge">🇵🇪 Hecho en Perú</span>

      <div class="social-links">
        <a href="https://linkedin.com/company/agendadr" target="_blank" rel="noopener" aria-label="LinkedIn" class="social-icon">
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://instagram.com/agendadr" target="_blank" rel="noopener" aria-label="Instagram" class="social-icon">
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://facebook.com/agendadr" target="_blank" rel="noopener" aria-label="Facebook" class="social-icon">
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://x.com/agendadr" target="_blank" rel="noopener" aria-label="X / Twitter" class="social-icon">
          <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://youtube.com/@agendadr" target="_blank" rel="noopener" aria-label="YouTube" class="social-icon">
          <svg width="17" height="17" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      </div>
    </div>

    <!-- Desktop columns -->
    <div class="footer-cols" aria-label="Navegación del footer">
      {columns.map(({ title, links }) => (
        <div class="footer-col">
          <p class="col-title">{title}</p>
          <ul>
            {links.map(({ href, label }) => (
              <li><a href={href} class="col-link">{label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Mobile accordions -->
    <div class="footer-accordions" aria-label="Navegación del footer">
      {columns.map(({ title, links }) => (
        <details class="footer-accordion">
          <summary class="accordion-header">
            <span>{title}</span>
            <svg class="chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </summary>
          <div class="accordion-body">
            <ul>
              {links.map(({ href, label }) => (
                <li><a href={href} class="col-link">{label}</a></li>
              ))}
            </ul>
          </div>
        </details>
      ))}
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <p>© {year} AgendaDr · ECOGIROS NEGOCIOS E.I.R.L. · RUC 20612344567</p>
    <nav class="legal-links">
      {legalLinks.map(({ href, label }) => (
        <a href={href}>{label}</a>
      ))}
    </nav>
  </div>

</footer>

<style>
  .site-footer {
    background: var(--bg-page);
    border-top: 1px solid var(--border-subtle);
  }

  /* ── Body layout ─────────────────────────────────── */
  .footer-body {
    max-width: 1280px;
    margin: 0 auto;
    padding: 48px 24px 40px;
    display: grid;
    grid-template-columns: 200px 1fr;
    grid-template-areas: "brand cols";
    gap: 56px;
    align-items: start;
  }

  .footer-brand      { grid-area: brand; }
  .footer-cols       { grid-area: cols; }
  .footer-accordions { display: none; }

  /* ── Brand ───────────────────────────────────────── */
  .footer-logo {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 600;
    color: var(--text-heading);
    text-decoration: none;
    display: block;
    margin-bottom: 10px;
  }
  .footer-logo span { color: var(--color-primary); }

  .footer-tagline {
    font-size: 12px;
    line-height: 1.65;
    color: var(--text-muted);
    margin-bottom: 14px;
  }

  .footer-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 600;
    background: rgba(33,150,243,0.08);
    color: #03BB85;
    padding: 3px 10px;
    border-radius: 999px;
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 16px;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    color: var(--text-muted);
    transition: color 0.15s, background 0.15s;
    text-decoration: none;
  }
  .social-icon:hover {
    color: var(--text-heading);
    background: var(--bg-subtle);
  }

  /* ── Desktop columns ─────────────────────────────── */
  .footer-cols {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 24px 16px;
  }

  @media (max-width: 1000px) {
    .footer-cols { grid-template-columns: repeat(3, 1fr); }
  }

  .col-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-label);
    margin-bottom: 10px;
  }

  .footer-col ul,
  .accordion-body ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .col-link {
    font-size: 13px;
    color: var(--text-tertiary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .col-link:hover { color: var(--color-primary-link); }

  /* ── Mobile: acordeones ──────────────────────────── */
  @media (max-width: 767px) {
    .footer-body {
      grid-template-columns: 1fr;
      grid-template-areas:
        "brand"
        "accordions";
      gap: 0;
      padding: 28px 16px 8px;
    }

    .footer-brand {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      padding-bottom: 24px;
      border-bottom: 1px solid var(--border-subtle);
      margin-bottom: 4px;
    }

    .footer-cols       { display: none; }
    .footer-accordions {
      grid-area: accordions;
      display: flex;
      flex-direction: column;
    }
  }

  /* ── Accordion ───────────────────────────────────── */
  .footer-accordion {
    border-bottom: 1px solid var(--border-subtle);
  }

  .accordion-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 4px;
    cursor: pointer;
    list-style: none;
    user-select: none;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    transition: color 0.15s;
  }
  .accordion-header::-webkit-details-marker { display: none; }
  .accordion-header:hover { color: var(--text-heading); }

  .chevron {
    flex-shrink: 0;
    color: var(--text-label);
    transition: transform 0.2s ease-out;
  }

  .footer-accordion[open] .chevron {
    transform: rotate(180deg);
  }

  .accordion-body {
    padding: 4px 4px 16px;
    animation: accordionOpen 0.2s ease-out;
  }

  .accordion-body ul { gap: 10px; }

  .accordion-body .col-link {
    font-size: 14px;
    display: block;
    padding: 2px 0;
  }

  @keyframes accordionOpen {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .accordion-body { animation: none; }
    .chevron { transition: none; }
  }

  /* ── Tablet intermedio ───────────────────────────── */
  @media (min-width: 768px) and (max-width: 860px) {
    .footer-body {
      grid-template-columns: 1fr;
      grid-template-areas:
        "brand"
        "cols";
      gap: 32px;
    }
    .footer-cols { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── Bottom bar ──────────────────────────────────── */
  .footer-bottom {
    max-width: 1280px;
    margin: 0 auto;
    padding: 16px 24px;
    border-top: 1px solid var(--border-subtle);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    font-size: 12px;
    color: var(--text-muted);
  }

  @media (max-width: 767px) {
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
      padding: 16px 16px 24px;
    }
  }

  .legal-links {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  @media (max-width: 767px) {
    .legal-links { gap: 12px; }
  }

  .legal-links a {
    font-size: 12px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .legal-links a:hover { color: var(--text-secondary); }
</style>
