---
import Button from '../ui/Button.astro';
import AnnouncementBar from './AnnouncementBar.astro';
import {
  ChevronDown, Menu, X, Sun, Moon,
  Calendar, CreditCard, MessageCircle, ClipboardList,
  FileText, Building2, BarChart2, MapPin, Percent, Stethoscope,
  UserRound, Store, Hospital, HeartPulse, Users
} from '@lucide/astro';

const paraQuien = [
  { href: '/para/doctores',        label: 'Doctores independientes' },
  { href: '/para/consultorios',    label: 'Consultorios' },
  { href: '/para/clinicas',        label: 'Clínicas' },
  { href: '/para/centros-medicos', label: 'Centros médicos' },
  { href: '/para/policlinicos',    label: 'Policlínicos' },
];
---

<AnnouncementBar />
<header id="header" class="site-header">
  <div class="header-inner">
    <div class="header-content">

      <!-- Hamburger (mobile izquierda / desktop oculto) -->
      <button id="menu-toggle" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu" class="hamburger">
        <Menu id="icon-open"  size={20} />
        <X    id="icon-close" size={20} class="hidden" />
      </button>

      <!-- Logo (centro en mobile / izquierda en desktop) -->
      <a href="/" class="logo" aria-label="AgendaDr inicio">
        <span class="logo-text">Agenda<span class="logo-accent">Dr</span></span>
      </a>

      <!-- Nav desktop -->
      <nav class="nav-desktop" aria-label="Navegación principal">

        <!-- Funcionalidades dropdown -->
        <div class="nav-item" id="drop-func">
          <button class="nav-trigger" aria-expanded="false" aria-haspopup="true">
            Funcionalidades
            <ChevronDown size={14} class="chevron" />
          </button>
          <div class="nav-dropdown dropdown-wide" role="menu">
            <div class="dropdown-grid">
              <a href="/funcionalidades/citas-online"      class="dropdown-item" role="menuitem"><Calendar      size={15} class="dropdown-icon" /><span>Citas online</span></a>
              <a href="/funcionalidades/pagos-medicos"     class="dropdown-item" role="menuitem"><CreditCard    size={15} class="dropdown-icon" /><span>Pagos médicos</span></a>
              <a href="/funcionalidades/whatsapp-clinicas" class="dropdown-item" role="menuitem"><MessageCircle size={15} class="dropdown-icon" /><span>WhatsApp automático</span><span class="item-badge badge-new">Nuevo</span></a>
              <a href="/funcionalidades/historial-medico"  class="dropdown-item" role="menuitem"><ClipboardList size={15} class="dropdown-icon" /><span>Historial médico</span></a>
              <a href="/funcionalidades/recetas-digitales" class="dropdown-item" role="menuitem"><FileText      size={15} class="dropdown-icon" /><span>Recetas digitales</span></a>
              <a href="/funcionalidades/gestion-clinicas"  class="dropdown-item" role="menuitem"><Building2     size={15} class="dropdown-icon" /><span>Gestión de clínica</span></a>
              <a href="/funcionalidades/reportes"          class="dropdown-item" role="menuitem"><BarChart2     size={15} class="dropdown-icon" /><span>Reportes</span></a>
              <a href="/funcionalidades/multi-sede"        class="dropdown-item" role="menuitem"><MapPin        size={15} class="dropdown-icon" /><span>Multi-sede</span></a>
              <a href="/funcionalidades/comisiones"        class="dropdown-item" role="menuitem"><Percent       size={15} class="dropdown-icon" /><span>Comisiones</span></a>
              <a href="/funcionalidades/planes-tratamiento"class="dropdown-item" role="menuitem"><Stethoscope   size={15} class="dropdown-icon" /><span>Planes de tratamiento</span></a>
            </div>
          </div>
        </div>

        <!-- Para quién dropdown -->
        <div class="nav-item" id="drop-para">
          <button class="nav-trigger" aria-expanded="false" aria-haspopup="true">
            Para quién
            <ChevronDown size={14} class="chevron" />
          </button>
          <div class="nav-dropdown dropdown-narrow" role="menu">
            <a href="/para/doctores"        class="dropdown-item" role="menuitem"><UserRound  size={15} class="dropdown-icon" /><span>Doctores independientes</span></a>
            <a href="/para/consultorios"    class="dropdown-item" role="menuitem"><Store      size={15} class="dropdown-icon" /><span>Consultorios</span></a>
            <a href="/para/clinicas"        class="dropdown-item" role="menuitem"><Hospital   size={15} class="dropdown-icon" /><span>Clínicas</span></a>
            <a href="/para/centros-medicos" class="dropdown-item" role="menuitem"><HeartPulse size={15} class="dropdown-icon" /><span>Centros médicos</span></a>
            <a href="/para/policlinicos"    class="dropdown-item" role="menuitem"><Users      size={15} class="dropdown-icon" /><span>Policlínicos</span></a>
          </div>
        </div>

        <a href="/planes" class="nav-link">Precios</a>
        <a href="/nosotros"  class="nav-link">Nosotros</a>
        <a href="/contacto"  class="nav-link">Contacto</a>
      </nav>

      <!-- CTAs desktop -->
      <div class="nav-ctas">
        <!-- Theme toggle -->
        <button id="theme-toggle" type="button" aria-label="Cambiar tema" class="theme-btn">
          <Sun  id="icon-sun"  size={18} class="theme-icon" />
          <Moon id="icon-moon" size={18} class="theme-icon" />
        </button>
        <Button variant="ghost" size="sm" href="https://app.agendadr.com/login">Iniciar sesión</Button>
        <Button variant="primary" size="sm" href="/demo">Empezar gratis</Button>
      </div>

      <!-- Mobile right: CTA + theme toggle -->
      <div class="mobile-right">
        <a href="/demo" class="mobile-cta-btn">Empezar gratis</a>
        <button id="theme-toggle-mobile" type="button" aria-label="Cambiar tema" class="theme-btn theme-btn-mobile">
          <Sun  id="icon-sun-mobile"  size={18} class="theme-icon" />
          <Moon id="icon-moon-mobile" size={18} class="theme-icon" />
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile backdrop -->
  <div id="mobile-backdrop" class="mobile-backdrop"></div>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="mobile-menu">
    <!-- Drawer header -->
    <div class="drawer-header">
      <a href="/" class="logo" aria-label="AgendaDr inicio">
        <span class="logo-text">Agenda<span class="logo-accent">Dr</span></span>
      </a>
      <button id="drawer-close" type="button" aria-label="Cerrar menú" class="drawer-close-btn">
        <X size={20} />
      </button>
    </div>
    <nav class="mobile-nav">

      <!-- Funcionalidades -->
      <div class="mobile-section">
        <button class="mobile-section-toggle" aria-expanded="false">
          Funcionalidades
          <ChevronDown size={14} class="chevron" />
        </button>
        <div class="mobile-section-body hidden">
          <a href="/funcionalidades/citas-online"       class="mobile-link mobile-link-sub"><Calendar      size={14} /><span>Citas online</span></a>
          <a href="/funcionalidades/pagos-medicos"      class="mobile-link mobile-link-sub"><CreditCard    size={14} /><span>Pagos médicos</span></a>
          <a href="/funcionalidades/whatsapp-clinicas"  class="mobile-link mobile-link-sub"><MessageCircle size={14} /><span>WhatsApp automático</span></a>
          <a href="/funcionalidades/historial-medico"   class="mobile-link mobile-link-sub"><ClipboardList size={14} /><span>Historial médico</span></a>
          <a href="/funcionalidades/recetas-digitales"  class="mobile-link mobile-link-sub"><FileText      size={14} /><span>Recetas digitales</span></a>
          <a href="/funcionalidades/gestion-clinicas"   class="mobile-link mobile-link-sub"><Building2     size={14} /><span>Gestión de clínica</span></a>
          <a href="/funcionalidades/reportes"           class="mobile-link mobile-link-sub"><BarChart2     size={14} /><span>Reportes</span></a>
          <a href="/funcionalidades/multi-sede"         class="mobile-link mobile-link-sub"><MapPin        size={14} /><span>Multi-sede</span></a>
          <a href="/funcionalidades/comisiones"         class="mobile-link mobile-link-sub"><Percent       size={14} /><span>Comisiones</span></a>
          <a href="/funcionalidades/planes-tratamiento" class="mobile-link mobile-link-sub"><Stethoscope   size={14} /><span>Planes de tratamiento</span></a>
        </div>
      </div>

      <!-- Para quién -->
      <div class="mobile-section">
        <button class="mobile-section-toggle" aria-expanded="false">
          Para quién
          <ChevronDown size={14} class="chevron" />
        </button>
        <div class="mobile-section-body hidden">
          {paraQuien.map(({ href, label }) => (
            <a href={href} class="mobile-link mobile-link-sub">{label}</a>
          ))}
        </div>
      </div>

      <a href="/planes"   class="mobile-link">Precios</a>
      <a href="/nosotros" class="mobile-link">Nosotros</a>
      <a href="/contacto" class="mobile-link">Contacto</a>
    </nav>

    <div class="mobile-ctas">
      <a href="https://app.agendadr.com/login" class="mobile-login-link">
        ¿Ya tienes cuenta? <strong>Iniciar sesión</strong>
      </a>
    </div>
  </div>
</header>

<style>
  /* ── Base ── */
  .site-header {
    position: fixed;
    top: 40px; left: 0; right: 0;
    z-index: 50;
    transition: box-shadow 0.3s ease, top 0.3s ease;
  }

  .header-inner {
    background: #ffffff;
    border-bottom: 1px solid #f1f5f9;
    transition: box-shadow 0.3s ease;
  }

  .site-header.header-scrolled .header-inner {
    box-shadow: 0 1px 12px rgba(0,0,0,0.07);
  }

  :global(html.dark) .header-inner {
    background: #0f172a;
    border-bottom-color: #1e293b;
  }

  .header-content {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  /* Mobile: hamburger | logo | [cta + toggle] */
  @media (max-width: 768px) {
    .header-content {
      display: grid;
      grid-template-columns: 44px 1fr auto;
      gap: 0;
      padding: 0 8px 0 4px;
    }
    .logo {
      grid-column: 2;
      justify-self: center;
    }
    .hamburger {
      grid-column: 1;
      justify-self: start;
      margin-left: 0;
    }
    .mobile-right {
      grid-column: 3;
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .nav-desktop,
    .nav-ctas { display: none !important; }
  }

  /* ── Logo ── */
  .logo { text-decoration: none; flex-shrink: 0; }
  .logo-text {
    font-family: 'Cal Sans', Inter, sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: #0f172a;
  }
  :global(html.dark) .logo-text { color: #f1f5f9; }
  .logo-accent { color: #03BB85; }

  /* ── Nav desktop ── */
  .nav-desktop {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    flex: 1;
  }

  @media (max-width: 768px) {
    .nav-desktop { display: none; }
  }

  .nav-link {
    padding: 6px 12px;
    font-size: 14px;
    font-weight: 500;
    color: #475569;
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .nav-link:hover {
    color: #03BB85;
    background: #f0fdf9;
  }
  :global(html.dark) .nav-link { color: #94a3b8; }
  :global(html.dark) .nav-link:hover {
    color: #4CE5B5;
    background: rgba(3,187,133,0.1);
  }

  /* ── Dropdown trigger ── */
  .nav-item {
    position: relative;
  }

  .nav-trigger {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 6px 12px;
    font-size: 14px;
    font-weight: 500;
    color: #475569;
    background: none;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
    font-family: inherit;
  }
  .nav-trigger:hover { color: #0f172a; background: #f1f5f9; }
  :global(html.dark) .nav-trigger { color: #94a3b8; }
  :global(html.dark) .nav-trigger:hover { color: #f1f5f9; background: rgba(255,255,255,0.08); }

  .nav-trigger.active {
    color: #03BB85;
    background: #f0fdf9;
  }
  :global(html.dark) .nav-trigger.active {
    color: #4CE5B5;
    background: rgba(3,187,133,0.1);
  }

  .chevron {
    transition: transform 0.2s ease;
  }
  .nav-trigger.active .chevron,
  .nav-trigger[aria-expanded="true"] .chevron {
    transform: rotate(180deg);
  }

  /* ── Dropdown panel ── */
  .nav-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.10);
    padding: 8px;
    z-index: 100;
    animation: dropIn 0.15s ease-out;
  }

  :global(html.dark) .nav-dropdown {
    background: #1e293b;
    border-color: #334155;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }

  .nav-dropdown.open { display: block; }

  @keyframes dropIn {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .dropdown-wide   { width: 440px; }
  .dropdown-narrow { width: 220px; }

  .dropdown-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    font-size: 13px;
    font-weight: 500;
    color: #0f172a;
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.1s, color 0.1s;
    white-space: nowrap;
  }
  .dropdown-item:hover { background: #f0fdf9; color: #03BB85; }
  :global(html.dark) .dropdown-item { color: #e2e8f0; }
  :global(html.dark) .dropdown-item:hover { background: #134e4a; color: #4CE5B5; }

  .dropdown-icon {
    flex-shrink: 0;
    color: #64748b;
    transition: color 0.1s;
  }
  .dropdown-item:hover .dropdown-icon { color: #03BB85; }

  /* ── Badges ── */
  .item-badge {
    margin-left: auto;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 2px 7px;
    border-radius: 999px;
    line-height: 1.6;
    flex-shrink: 0;
  }
  .badge-new {
    background: #ecfdf5;
    color: #059669;
  }
  :global(html.dark) .badge-new {
    background: rgba(5,150,105,0.15);
    color: #34d399;
  }

  .nav-link-badge {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .nav-badge {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 2px 7px;
    border-radius: 999px;
    line-height: 1.6;
    background: #fffbeb;
    color: #d97706;
    border: 1px solid #fde68a;
  }
  :global(html.dark) .nav-badge {
    background: rgba(217,119,6,0.15);
    color: #fbbf24;
    border-color: rgba(217,119,6,0.3);
  }

  /* ── Theme toggle ── */
  .theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: none;
    background: none;
    color: #475569;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    flex-shrink: 0;
  }
  .theme-btn:hover { background: rgba(0,0,0,0.05); color: #0f172a; }
  :global(html.dark) .theme-btn { color: #94a3b8; }
  :global(html.dark) .theme-btn:hover { background: rgba(255,255,255,0.08); color: #f1f5f9; }

  /* Theme icons — transition opacity+scale */
  .theme-icon {
    position: absolute;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .theme-btn { position: relative; }

  /* Light mode: show moon, hide sun */
  #icon-sun, #icon-sun-mobile {
    opacity: 0; transform: scale(0.6) rotate(-30deg);
  }
  #icon-moon, #icon-moon-mobile {
    opacity: 1; transform: scale(1) rotate(0deg);
  }

  /* Dark mode: show sun, hide moon */
  :global(html.dark) #icon-sun, :global(html.dark) #icon-sun-mobile {
    opacity: 1; transform: scale(1) rotate(0deg);
  }
  :global(html.dark) #icon-moon, :global(html.dark) #icon-moon-mobile {
    opacity: 0; transform: scale(0.6) rotate(30deg);
  }

  /* Mobile theme btn: visible only on mobile */
  .theme-btn-mobile { display: none; }
  @media (max-width: 768px) { .theme-btn-mobile { display: flex; } }

  /* Desktop theme btn: hidden on mobile */
  @media (max-width: 768px) { .nav-ctas .theme-btn:not(.theme-btn-mobile) { display: none; } }

  /* ── CTAs ── */
  .nav-ctas {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  @media (max-width: 768px) { .nav-ctas { display: none; } }

  /* ── Hamburger ── */
  .hamburger {
    display: none;
    padding: 8px;
    border-radius: 8px;
    border: none;
    background: none;
    color: #475569;
    cursor: pointer;
  }
  .hamburger:hover { background: #f1f5f9; }
  :global(html.dark) .hamburger { color: #94a3b8; }
  :global(html.dark) .hamburger:hover { background: #1e293b; }
  @media (max-width: 768px) { .hamburger { display: flex; } }

  /* ── Mobile backdrop ── */
  .mobile-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 149;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .mobile-backdrop.backdrop-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Mobile drawer — slide desde la izquierda ── */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 78vw;
    max-width: 320px;
    background: #ffffff;
    border-right: 1px solid #e2e8f0;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    z-index: 150;
    transform: translateX(-100%);
    pointer-events: none;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .mobile-menu.menu-open {
    transform: translateX(0);
    pointer-events: auto;
    box-shadow: 4px 0 32px rgba(0,0,0,0.18);
  }
  :global(html.dark) .mobile-menu {
    background: #0f172a;
    border-right-color: #1e293b;
  }

  /* Drawer header */
  .drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 16px 12px;
    border-bottom: 1px solid #f1f5f9;
    flex-shrink: 0;
  }
  :global(html.dark) .drawer-header {
    border-bottom-color: #1e293b;
  }

  .drawer-close-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: none;
    background: none;
    color: #475569;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .drawer-close-btn:hover { background: #f1f5f9; color: #0f172a; }
  :global(html.dark) .drawer-close-btn { color: #94a3b8; }
  :global(html.dark) .drawer-close-btn:hover { background: #1e293b; color: #f1f5f9; }

  /* Botón CTA pequeño en header mobile */
  .mobile-cta-btn {
    display: none;
    font-size: 12px;
    font-weight: 700;
    color: #0f172a;
    background: #03BB85;
    padding: 7px 12px;
    border-radius: 8px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
  }
  .mobile-cta-btn:hover { background: #02a676; }
  @media (max-width: 768px) { .mobile-cta-btn { display: inline-flex; } }

  /* Mobile right wrapper — oculto en desktop */
  .mobile-right { display: none; }
  @media (max-width: 768px) { .mobile-right { display: flex; } }

  /* Items entran en cascada después de que el drawer se abre */
  .mobile-nav > *,
  .mobile-ctas {
    opacity: 0;
    transform: translateX(-12px);
    transition: opacity 0.22s ease, transform 0.22s ease;
  }
  .mobile-menu.menu-open .mobile-nav > *:nth-child(1) { opacity:1; transform:none; transition-delay: 0.15s; }
  .mobile-menu.menu-open .mobile-nav > *:nth-child(2) { opacity:1; transform:none; transition-delay: 0.20s; }
  .mobile-menu.menu-open .mobile-nav > *:nth-child(3) { opacity:1; transform:none; transition-delay: 0.25s; }
  .mobile-menu.menu-open .mobile-nav > *:nth-child(4) { opacity:1; transform:none; transition-delay: 0.28s; }
  .mobile-menu.menu-open .mobile-nav > *:nth-child(5) { opacity:1; transform:none; transition-delay: 0.31s; }
  .mobile-menu.menu-open .mobile-ctas                 { opacity:1; transform:none; transition-delay: 0.34s; }

  /* Ocultar drawer y backdrop en desktop */
  @media (min-width: 769px) {
    .mobile-menu { display: none !important; }
    .mobile-backdrop { display: none !important; }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu { transition: none; }
    .mobile-menu.menu-open .mobile-nav > *,
    .mobile-menu.menu-open .mobile-ctas { opacity:1; transform:none; transition:none; }
  }

  .mobile-nav {
    padding: 12px 24px 8px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mobile-link {
    display: block;
    padding: 10px 12px;
    font-size: 15px;
    font-weight: 500;
    color: #374151;
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.1s;
  }
  .mobile-link:hover { background: #f8fafc; }
  :global(html.dark) .mobile-link { color: #cbd5e1; }
  :global(html.dark) .mobile-link:hover { background: #1e293b; }

  .mobile-link-sub {
    font-size: 14px;
    font-weight: 400;
    color: #64748b;
    padding-left: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  :global(html.dark) .mobile-link-sub { color: #94a3b8; }

  .mobile-section-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px;
    font-size: 15px;
    font-weight: 500;
    color: #374151;
    background: none;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.1s;
  }
  .mobile-section-toggle:hover { background: #f8fafc; }
  :global(html.dark) .mobile-section-toggle { color: #cbd5e1; }
  :global(html.dark) .mobile-section-toggle:hover { background: #1e293b; }

  .mobile-section-toggle.open .chevron { transform: rotate(180deg); }

  .mobile-ctas {
    padding: 16px 24px 24px;
    border-top: 1px solid #f1f5f9;
    margin-top: auto;
  }
  :global(html.dark) .mobile-ctas { border-top-color: #1e293b; }

  .mobile-login-link {
    display: block;
    text-align: center;
    font-size: 13px;
    color: #94a3b8;
    text-decoration: none;
    padding: 8px;
    transition: color 0.15s;
  }
  .mobile-login-link strong { color: #475569; font-weight: 600; }
  .mobile-login-link:hover { color: #03BB85; }
  .mobile-login-link:hover strong { color: #03BB85; }
  :global(html.dark) .mobile-login-link { color: #64748b; }
  :global(html.dark) .mobile-login-link strong { color: #94a3b8; }
  :global(html.dark) .mobile-login-link:hover,
  :global(html.dark) .mobile-login-link:hover strong { color: #4CE5B5; }
</style>

<script>

  // ── Scroll behavior: sombra al hacer scroll ──
  const header = document.getElementById('header')!;

  window.addEventListener('scroll', () => {
    header.classList.toggle('header-scrolled', window.scrollY > 20);
  }, { passive: true });

  // ── Theme toggle ──
  function applyTheme(dark: boolean) {
    document.documentElement.classList.toggle('dark', dark);
    try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (_) {}
  }

  function initThemeBtn(btn: HTMLElement | null) {
    if (!btn) return;
    btn.addEventListener('click', () => {
      applyTheme(!document.documentElement.classList.contains('dark'));
    });
  }

  initThemeBtn(document.getElementById('theme-toggle'));
  initThemeBtn(document.getElementById('theme-toggle-mobile'));

  // ── Dropdown toggle (desktop) — hover + click ──
  function closeAll() {
    document.querySelectorAll('.nav-dropdown').forEach(d => d.classList.remove('open'));
    document.querySelectorAll('.nav-trigger').forEach(t => {
      t.classList.remove('active');
      t.setAttribute('aria-expanded', 'false');
    });
  }

  function openDropdown(trigger: HTMLButtonElement, dropdown: HTMLElement) {
    closeAll();
    dropdown.classList.add('open');
    trigger.classList.add('active');
    trigger.setAttribute('aria-expanded', 'true');
  }

  document.querySelectorAll('.nav-item').forEach((item) => {
    const trigger = item.querySelector('.nav-trigger') as HTMLButtonElement;
    const dropdown = item.querySelector('.nav-dropdown') as HTMLElement;
    if (!trigger || !dropdown) return;

    // Hover
    item.addEventListener('mouseenter', () => openDropdown(trigger, dropdown));
    item.addEventListener('mouseleave', closeAll);

    // Click (accesibilidad / teclado)
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdown.classList.contains('open') ? closeAll() : openDropdown(trigger, dropdown);
    });
  });

  document.addEventListener('click', closeAll);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAll(); });

  // ── Mobile drawer ──
  const toggle = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const backdrop = document.getElementById('mobile-backdrop')!;
  const drawerClose = document.getElementById('drawer-close')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  function openMenu() {
    mobileMenu.classList.add('menu-open');
    backdrop.classList.add('backdrop-open');
    toggle.setAttribute('aria-expanded', 'true');
    iconOpen.classList.add('hidden');
    iconClose.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileMenu.classList.remove('menu-open');
    backdrop.classList.remove('backdrop-open');
    toggle.setAttribute('aria-expanded', 'false');
    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
    document.body.style.overflow = '';
  }

  toggle.addEventListener('click', () => {
    mobileMenu.classList.contains('menu-open') ? closeMenu() : openMenu();
  });

  // Cerrar al hacer click en backdrop o en botón X del drawer
  backdrop.addEventListener('click', closeMenu);
  drawerClose.addEventListener('click', closeMenu);

  // ── Mobile section toggles ──
  document.querySelectorAll('.mobile-section-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const body = btn.nextElementSibling as HTMLElement;
      const isOpen = !body.classList.contains('hidden');
      body.classList.toggle('hidden', isOpen);
      btn.classList.toggle('open', !isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  // Close on link click
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
