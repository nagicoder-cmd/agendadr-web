---
import Button from '../ui/Button.astro';
import AnnouncementBar from './AnnouncementBar.astro';
import {
  ChevronDown, Menu, X, Sun, Moon,
  Calendar, CreditCard, MessageCircle, ClipboardList,
  FileText, Building2, BarChart2, MapPin, Percent, Stethoscope,
  UserRound, Store, Hospital, HeartPulse, Users, Sparkles
} from '@lucide/astro';

const paraQuien = [
  { href: '/para/doctores',        label: 'Doctores independientes' },
  { href: '/para/consultorios',    label: 'Consultorios' },
  { href: '/para/clinicas',        label: 'Clínicas' },
  { href: '/para/centros-medicos', label: 'Centros médicos' },
  { href: '/para/policlinicos',    label: 'Policlínicos' },
];
---

<AnnouncementBar />
<header id="header" class="site-header">
  <div class="header-inner">
    <div class="header-content">

      <!-- Hamburger (mobile izquierda / desktop oculto) -->
      <button id="menu-toggle" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu" class="hamburger">
        <Menu id="icon-open"  size={20} />
        <X    id="icon-close" size={20} class="hidden" />
      </button>

      <!-- Logo (centro en mobile / izquierda en desktop) -->
      <a href="/" class="logo" aria-label="AgendaDr inicio">
        <img src="/images/logos/logo-color-green.svg" alt="AgendaDr" class="logo-img logo-light" />
        <img src="/images/logos/logo-white.svg"       alt="AgendaDr" class="logo-img logo-dark"  />
      </a>

      <!-- Nav desktop -->
      <nav class="nav-desktop" aria-label="Navegación principal">

        <!-- Funcionalidades dropdown -->
        <div class="nav-item" id="drop-func">
          <button class="nav-trigger" aria-expanded="false" aria-haspopup="true">
            Funcionalidades
            <ChevronDown size={14} class="chevron" />
          </button>
          <div class="nav-dropdown dropdown-wide" role="menu">
            <div class="dropdown-grid">
              <a href="/funcionalidades/citas-online"      class="dropdown-item" role="menuitem"><Calendar      size={15} class="dropdown-icon" /><span>Citas online</span></a>
              <a href="/funcionalidades/pagos-medicos"     class="dropdown-item" role="menuitem"><CreditCard    size={15} class="dropdown-icon" /><span>Pagos médicos</span></a>
              <a href="/funcionalidades/whatsapp-clinicas" class="dropdown-item" role="menuitem"><MessageCircle size={15} class="dropdown-icon" /><span>WhatsApp automático</span><span class="item-badge badge-new">Nuevo</span></a>
              <a href="/funcionalidades/historial-medico"  class="dropdown-item" role="menuitem"><ClipboardList size={15} class="dropdown-icon" /><span>Historial médico</span></a>
              <a href="/funcionalidades/recetas-digitales" class="dropdown-item" role="menuitem"><FileText      size={15} class="dropdown-icon" /><span>Recetas digitales</span></a>
              <a href="/funcionalidades/gestion-clinicas"  class="dropdown-item" role="menuitem"><Building2     size={15} class="dropdown-icon" /><span>Gestión de clínica</span></a>
              <a href="/funcionalidades/reportes"          class="dropdown-item" role="menuitem"><BarChart2     size={15} class="dropdown-icon" /><span>Reportes</span></a>
              <a href="/funcionalidades/multi-sede"        class="dropdown-item" role="menuitem"><MapPin        size={15} class="dropdown-icon" /><span>Multi-sede</span></a>
              <a href="/funcionalidades/comisiones"        class="dropdown-item" role="menuitem"><Percent       size={15} class="dropdown-icon" /><span>Comisiones</span></a>
              <a href="/funcionalidades/planes-tratamiento"class="dropdown-item" role="menuitem"><Stethoscope   size={15} class="dropdown-icon" /><span>Planes de tratamiento</span></a>
            </div>
          </div>
        </div>

        <!-- Para quién dropdown -->
        <div class="nav-item" id="drop-para">
          <button class="nav-trigger" aria-expanded="false" aria-haspopup="true">
            Para quién
            <ChevronDown size={14} class="chevron" />
          </button>
          <div class="nav-dropdown dropdown-narrow" role="menu">
            <a href="/para/doctores"        class="dropdown-item" role="menuitem"><UserRound  size={15} class="dropdown-icon" /><span>Doctores independientes</span></a>
            <a href="/para/consultorios"    class="dropdown-item" role="menuitem"><Store      size={15} class="dropdown-icon" /><span>Consultorios</span></a>
            <a href="/para/clinicas"        class="dropdown-item" role="menuitem"><Hospital   size={15} class="dropdown-icon" /><span>Clínicas</span></a>
            <a href="/para/centros-medicos" class="dropdown-item" role="menuitem"><HeartPulse size={15} class="dropdown-icon" /><span>Centros médicos</span></a>
            <a href="/para/policlinicos"    class="dropdown-item" role="menuitem"><Users      size={15} class="dropdown-icon" /><span>Policlínicos</span></a>
          </div>
        </div>

        <a href="/planes"   class="nav-link">Precios</a>
        <a href="/nosotros" class="nav-link">Nosotros</a>
        <a href="/contacto" class="nav-link">Contacto</a>
      </nav>

      <!-- CTAs desktop -->
      <div class="nav-ctas">
        <button id="theme-toggle" type="button" aria-label="Cambiar tema" class="theme-btn">
          <Sun  id="icon-sun"  size={18} class="theme-icon" />
          <Moon id="icon-moon" size={18} class="theme-icon" />
        </button>
        <Button variant="ghost" size="sm" href="https://app.agendadr.com/login">Iniciar sesión</Button>
        <Button variant="primary" size="sm" href="/demo">Empezar gratis</Button>
      </div>

      <!-- Mobile right: CTA + theme toggle -->
      <div class="mobile-right">
        <a href="/demo" class="mobile-cta-btn">Empezar gratis</a>
        <button id="theme-toggle-mobile" type="button" aria-label="Cambiar tema" class="theme-btn theme-btn-mobile">
          <Sun  id="icon-sun-mobile"  size={18} class="theme-icon" />
          <Moon id="icon-moon-mobile" size={18} class="theme-icon" />
        </button>
      </div>

    </div>
  </div>
</header>

<!--
  Backdrop y drawer FUERA del <header> para evitar que el stacking context
  del header (z-index: 50) limite su apilamiento frente al announcement bar (z-index: 60).
-->
<div id="mobile-backdrop" class="mobile-backdrop"></div>

<div id="mobile-menu" class="mobile-menu" role="dialog" aria-modal="true" aria-label="Menú de navegación">

  <!-- Drawer header: logo + cerrar -->
  <div class="drawer-header">
    <a href="/" class="logo" aria-label="AgendaDr inicio">
      <img src="/images/logos/logo-color-green.svg" alt="AgendaDr" class="logo-img logo-light" />
      <img src="/images/logos/logo-white.svg"       alt="AgendaDr" class="logo-img logo-dark"  />
    </a>
    <button id="drawer-close" type="button" aria-label="Cerrar menú" class="drawer-close-btn">
      <X size={20} />
    </button>
  </div>

  <!-- Nav links -->
  <nav class="mobile-nav">

    <!-- Funcionalidades accordion -->
    <div class="mobile-section">
      <button class="mobile-section-toggle" aria-expanded="false">
        Funcionalidades
        <ChevronDown size={14} class="chevron" />
      </button>
      <div class="mobile-section-body hidden">
        <a href="/funcionalidades/citas-online"       class="mobile-link mobile-link-sub"><Calendar      size={14} /><span>Citas online</span></a>
        <a href="/funcionalidades/pagos-medicos"      class="mobile-link mobile-link-sub"><CreditCard    size={14} /><span>Pagos médicos</span></a>
        <a href="/funcionalidades/whatsapp-clinicas"  class="mobile-link mobile-link-sub"><MessageCircle size={14} /><span>WhatsApp automático</span></a>
        <a href="/funcionalidades/historial-medico"   class="mobile-link mobile-link-sub"><ClipboardList size={14} /><span>Historial médico</span></a>
        <a href="/funcionalidades/recetas-digitales"  class="mobile-link mobile-link-sub"><FileText      size={14} /><span>Recetas digitales</span></a>
        <a href="/funcionalidades/gestion-clinicas"   class="mobile-link mobile-link-sub"><Building2     size={14} /><span>Gestión de clínica</span></a>
        <a href="/funcionalidades/reportes"           class="mobile-link mobile-link-sub"><BarChart2     size={14} /><span>Reportes</span></a>
        <a href="/funcionalidades/multi-sede"         class="mobile-link mobile-link-sub"><MapPin        size={14} /><span>Multi-sede</span></a>
        <a href="/funcionalidades/comisiones"         class="mobile-link mobile-link-sub"><Percent       size={14} /><span>Comisiones</span></a>
        <a href="/funcionalidades/planes-tratamiento" class="mobile-link mobile-link-sub"><Stethoscope   size={14} /><span>Planes de tratamiento</span></a>
      </div>
    </div>

    <!-- Para quién accordion -->
    <div class="mobile-section">
      <button class="mobile-section-toggle" aria-expanded="false">
        Para quién
        <ChevronDown size={14} class="chevron" />
      </button>
      <div class="mobile-section-body hidden">
        {paraQuien.map(({ href, label }) => (
          <a href={href} class="mobile-link mobile-link-sub">{label}</a>
        ))}
      </div>
    </div>

    <a href="/planes"   class="mobile-link">Precios</a>
    <a href="/nosotros" class="mobile-link">Nosotros</a>
    <a href="/contacto" class="mobile-link">Contacto</a>
  </nav>

  <!-- Separador visual entre nav y zona de conversión -->
  <div class="drawer-separator"></div>

  <!-- Zona de conversión -->
  <div class="drawer-promo">

    <!-- Card promo con icono decorativo -->
    <div class="promo-card">
      <div class="promo-card-body">
        <div class="promo-badge">
          <Sparkles size={11} />
          14 días gratis
        </div>
        <p class="promo-title">Digitaliza tu consultorio hoy</p>
        <p class="promo-sub">Sin tarjeta de crédito · Cancela cuando quieras</p>
        <a href="/demo" class="promo-cta">Solicitar demo gratuita →</a>
      </div>
      <!-- Icono decorativo de fondo -->
      <div class="promo-deco" aria-hidden="true">
        <Calendar size={72} />
      </div>
    </div>

    <!-- Rating social proof -->
    <div class="rating-row">
      <span class="stars">★★★★★</span>
      <span class="rating-text"><strong>4.8</strong> · +200 reseñas verificadas</span>
    </div>

    <!-- Quick wins pills -->
    <div class="quick-wins">
      <span class="quick-pill">✓ Citas online</span>
      <span class="quick-pill">✓ Recordatorios</span>
      <span class="quick-pill">✓ Pagos digitales</span>
    </div>

    <!-- Trust signal con dot pulsante -->
    <div class="trust-row">
      <span class="trust-dot"></span>
      <span class="trust-text">+500 médicos confían en AgendaDr</span>
    </div>

  </div>

  <!-- Bottom: planes + login -->
  <div class="mobile-ctas">
    <a href="/planes" class="drawer-planes-btn">
      Ver todos los planes →
    </a>
    <a href="https://app.agendadr.com/login" class="mobile-login-link">
      ¿Ya tienes cuenta? <strong>Iniciar sesión</strong>
    </a>
  </div>

</div>

<!-- Botón flotante WhatsApp — siempre visible, z-index menor al drawer -->
<a id="wa-float-btn" href="https://wa.me/51999999999" class="wa-float" target="_blank" rel="noopener noreferrer" aria-label="Contactar por WhatsApp">
  <svg class="wa-icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
  <span class="wa-label">¿Necesitas ayuda?</span>
</a>

<style>
  /* ── Base header ── */
  .site-header {
    position: fixed;
    top: 40px; left: 0; right: 0;
    z-index: 50;
    transition: box-shadow 0.3s ease;
  }

  .header-inner {
    background: #ffffff;
    border-bottom: 1px solid #f1f5f9;
    transition: box-shadow 0.3s ease;
  }
  .site-header.header-scrolled .header-inner {
    box-shadow: 0 1px 12px rgba(0,0,0,0.07);
  }
  :global(html.dark) .header-inner {
    background: #0f172a;
    border-bottom-color: #1e293b;
  }

  .header-content {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  /* Mobile grid: hamburger | logo | [cta + toggle] */
  @media (max-width: 768px) {
    .header-content {
      display: grid;
      grid-template-columns: 44px 1fr auto;
      gap: 0;
      padding: 0 8px 0 4px;
    }
    .logo          { grid-column: 2; justify-self: center; }
    .hamburger     { grid-column: 1; justify-self: start; margin-left: 0; }
    .mobile-right  { grid-column: 3; display: flex; align-items: center; gap: 4px; }
    .nav-desktop,
    .nav-ctas      { display: none !important; }
  }

  /* ── Logo ── */
  .logo { text-decoration: none; flex-shrink: 0; display: flex; align-items: center; }

  .logo-img {
    height: 32px;
    width: auto;
    max-width: 140px;
    display: block;
    object-fit: contain;
    /* Fuerza dimensiones en SVGs sin width/height en el elemento raíz */
    flex-shrink: 0;
  }
  @media (max-width: 768px) {
    .logo-img { height: 28px; max-width: 110px; }
  }

  /* Light mode: mostrar verde, ocultar white */
  .logo-dark { display: none; }

  /* Dark mode: ocultar verde, mostrar white */
  :global(html.dark) .logo-light { display: none; }
  :global(html.dark) .logo-dark  { display: block; }

  /* ── Nav desktop ── */
  .nav-desktop {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    flex: 1;
  }
  @media (max-width: 768px) { .nav-desktop { display: none; } }

  .nav-link {
    padding: 6px 12px;
    font-size: 14px;
    font-weight: 500;
    color: #475569;
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .nav-link:hover { color: #03BB85; background: #f0fdf9; }
  :global(html.dark) .nav-link { color: #94a3b8; }
  :global(html.dark) .nav-link:hover { color: #4CE5B5; background: rgba(3,187,133,0.1); }

  /* ── Dropdown trigger ── */
  .nav-item { position: relative; }

  .nav-trigger {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 6px 12px;
    font-size: 14px;
    font-weight: 500;
    color: #475569;
    background: none;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
    font-family: inherit;
  }
  .nav-trigger:hover { color: #0f172a; background: #f1f5f9; }
  :global(html.dark) .nav-trigger { color: #94a3b8; }
  :global(html.dark) .nav-trigger:hover { color: #f1f5f9; background: rgba(255,255,255,0.08); }
  .nav-trigger.active { color: #03BB85; background: #f0fdf9; }
  :global(html.dark) .nav-trigger.active { color: #4CE5B5; background: rgba(3,187,133,0.1); }

  .chevron { transition: transform 0.2s ease; }
  .nav-trigger[aria-expanded="true"] .chevron { transform: rotate(180deg); }

  /* ── Dropdown panel ── */
  .nav-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.10);
    padding: 8px;
    z-index: 100;
    animation: dropIn 0.15s ease-out;
  }
  :global(html.dark) .nav-dropdown {
    background: #1e293b;
    border-color: #334155;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .nav-dropdown.open { display: block; }

  @keyframes dropIn {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .dropdown-wide   { width: 440px; }
  .dropdown-narrow { width: 220px; }

  .dropdown-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    font-size: 13px;
    font-weight: 500;
    color: #0f172a;
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.1s, color 0.1s;
    white-space: nowrap;
  }
  .dropdown-item:hover { background: #f0fdf9; color: #03BB85; }
  :global(html.dark) .dropdown-item { color: #e2e8f0; }
  :global(html.dark) .dropdown-item:hover { background: #134e4a; color: #4CE5B5; }

  .dropdown-icon { flex-shrink: 0; color: #64748b; transition: color 0.1s; }
  .dropdown-item:hover .dropdown-icon { color: #03BB85; }

  /* ── Badges ── */
  .item-badge {
    margin-left: auto;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 2px 7px;
    border-radius: 999px;
    line-height: 1.6;
    flex-shrink: 0;
  }
  .badge-new { background: #ecfdf5; color: #059669; }
  :global(html.dark) .badge-new { background: rgba(5,150,105,0.15); color: #34d399; }

  /* ── Theme toggle ── */
  .theme-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: none;
    background: none;
    color: #475569;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    flex-shrink: 0;
  }
  .theme-btn:hover { background: rgba(0,0,0,0.05); color: #0f172a; }
  :global(html.dark) .theme-btn { color: #94a3b8; }
  :global(html.dark) .theme-btn:hover { background: rgba(255,255,255,0.08); color: #f1f5f9; }

  .theme-icon { position: absolute; transition: opacity 0.2s ease, transform 0.2s ease; }

  /* Light mode: moon visible, sun hidden */
  #icon-sun, #icon-sun-mobile   { opacity: 0; transform: scale(0.6) rotate(-30deg); }
  #icon-moon, #icon-moon-mobile { opacity: 1; transform: scale(1) rotate(0deg); }
  /* Dark mode: sun visible, moon hidden */
  :global(html.dark) #icon-sun, :global(html.dark) #icon-sun-mobile   { opacity: 1; transform: scale(1) rotate(0deg); }
  :global(html.dark) #icon-moon, :global(html.dark) #icon-moon-mobile { opacity: 0; transform: scale(0.6) rotate(30deg); }

  .theme-btn-mobile { display: none; }
  @media (max-width: 768px) { .theme-btn-mobile { display: flex; } }

  /* ── CTAs desktop ── */
  .nav-ctas { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
  @media (max-width: 768px) { .nav-ctas { display: none; } }

  /* ── Hamburger ── */
  .hamburger {
    display: none;
    padding: 8px;
    border-radius: 8px;
    border: none;
    background: none;
    color: #475569;
    cursor: pointer;
  }
  .hamburger:hover { background: #f1f5f9; }
  :global(html.dark) .hamburger { color: #94a3b8; }
  :global(html.dark) .hamburger:hover { background: #1e293b; }
  @media (max-width: 768px) { .hamburger { display: flex; } }

  /* Mobile CTA btn */
  .mobile-cta-btn {
    display: none;
    font-size: 12px;
    font-weight: 700;
    color: #0f172a;
    background: #03BB85;
    padding: 7px 12px;
    border-radius: 8px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
  }
  .mobile-cta-btn:hover { background: #02a676; }
  @media (max-width: 768px) { .mobile-cta-btn { display: inline-flex; } }

  .mobile-right { display: none; }
  @media (max-width: 768px) { .mobile-right { display: flex; } }

  /* ─────────────────────────────────────────────
     MOBILE BACKDROP
     z-index 200 → está en root stacking context,
     supera al announcement bar (z-index: 60)
  ───────────────────────────────────────────── */
  .mobile-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }
  .mobile-backdrop.backdrop-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* ─────────────────────────────────────────────
     MOBILE DRAWER
     z-index 201 → sobre el backdrop y sobre el
     announcement bar (z-index: 60)
  ───────────────────────────────────────────── */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 80vw;
    max-width: 300px;
    background: #ffffff;
    border-right: 1px solid #e2e8f0;
    overflow-y: auto;
    overflow-x: hidden;
    display: flex;
    flex-direction: column;
    z-index: 201;
    transform: translateX(-100%);
    pointer-events: none;
    transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .mobile-menu.menu-open {
    transform: translateX(0);
    pointer-events: auto;
    box-shadow: 8px 0 40px rgba(0,0,0,0.20);
  }
  :global(html.dark) .mobile-menu {
    background: #0f172a;
    border-right-color: #1e293b;
  }

  /* Ocultar en desktop */
  @media (min-width: 769px) {
    .mobile-menu    { display: none !important; }
    .mobile-backdrop{ display: none !important; }
  }

  /* ── Drawer header ── */
  .drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 12px 12px 16px;
    border-bottom: 1px solid #f1f5f9;
