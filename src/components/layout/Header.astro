    background: #03BB85;
    flex-shrink: 0;
    animation: pulse-dot 2.2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(3,187,133,0.4); }
    50%       { box-shadow: 0 0 0 5px rgba(3,187,133,0); }
  }
  .trust-text {
    font-size: 11.5px;
    color: #64748b;
    font-weight: 500;
  }
  :global(html.dark) .trust-text { color: #94a3b8; }

  /* ── Bottom CTAs ── */
  .mobile-ctas {
    padding: 14px 16px 28px;
    border-top: 1px solid #f1f5f9;
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  :global(html.dark) .mobile-ctas { border-top-color: #1e293b; }

  .whatsapp-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    padding: 11px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 700;
    color: #ffffff;
    background: #25D366;
    text-decoration: none;
    transition: background 0.15s, transform 0.12s, box-shadow 0.15s;
