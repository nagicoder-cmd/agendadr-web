  }
  :global(html.dark) .drawer-header { border-bottom-color: #1e293b; }

  .drawer-close-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: none;
    background: none;
