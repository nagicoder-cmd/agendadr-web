---
import Button from '../ui/Button.astro';

const funcionalidades = [
  { href: '/funcionalidades/citas-online',       label: 'Citas online',          icon: '📅' },
  { href: '/funcionalidades/pagos-medicos',       label: 'Pagos médicos',         icon: '💳' },
  { href: '/funcionalidades/whatsapp-clinicas',   label: 'WhatsApp automático',   icon: '💬' },
  { href: '/funcionalidades/historial-medico',    label: 'Historial médico',      icon: '📋' },
  { href: '/funcionalidades/recetas-digitales',   label: 'Recetas digitales',     icon: '📄' },
  { href: '/funcionalidades/gestion-clinicas',    label: 'Gestión de clínica',    icon: '🏥' },
  { href: '/funcionalidades/reportes',            label: 'Reportes',              icon: '📊' },
  { href: '/funcionalidades/multi-sede',          label: 'Multi-sede',            icon: '🏢' },
  { href: '/funcionalidades/comisiones',          label: 'Comisiones',            icon: '💰' },
  { href: '/funcionalidades/planes-tratamiento',  label: 'Planes de tratamiento', icon: '🩺' },
];

const paraQuien = [
  { href: '/para/doctores',        label: 'Doctores independientes' },
  { href: '/para/consultorios',    label: 'Consultorios' },
  { href: '/para/clinicas',        label: 'Clínicas' },
  { href: '/para/centros-medicos', label: 'Centros médicos' },
  { href: '/para/policlinicos',    label: 'Policlínicos' },
];
---

<header id="header" class="site-header">
  <div class="header-inner">
    <div class="header-content">

      <!-- Logo -->
      <a href="/" class="logo" aria-label="AgendaDr inicio">
        <span class="logo-text">Agenda<span class="logo-accent">Dr</span></span>
      </a>

      <!-- Nav desktop -->
      <nav class="nav-desktop" aria-label="Navegación principal">

        <!-- Funcionalidades dropdown -->
        <div class="nav-item" id="drop-func">
          <button class="nav-trigger" aria-expanded="false" aria-haspopup="true">
            Funcionalidades
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="chevron">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="nav-dropdown dropdown-wide" role="menu">
            <div class="dropdown-grid">
              {funcionalidades.map(({ href, label, icon }) => (
                <a href={href} class="dropdown-item" role="menuitem">
                  <span class="dropdown-icon">{icon}</span>
                  <span>{label}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Para quién dropdown -->
        <div class="nav-item" id="drop-para">
          <button class="nav-trigger" aria-expanded="false" aria-haspopup="true">
            Para quién
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="chevron">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="nav-dropdown dropdown-narrow" role="menu">
            {paraQuien.map(({ href, label }) => (
              <a href={href} class="dropdown-item" role="menuitem">
                <span>{label}</span>
              </a>
            ))}
          </div>
        </div>

        <a href="/planes"    class="nav-link">Precios</a>
        <a href="/nosotros"  class="nav-link">Nosotros</a>
        <a href="/contacto"  class="nav-link">Contacto</a>
      </nav>

      <!-- CTAs desktop -->
      <div class="nav-ctas">
        <Button variant="ghost" size="sm" href="https://app.agendadr.com/login">Iniciar sesión</Button>
        <Button variant="primary" size="sm" href="https://app.agendadr.com/registro">Empezar gratis</Button>
      </div>

      <!-- Hamburger -->
      <button id="menu-toggle" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu" class="hamburger">
        <svg id="icon-open"  class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>

    </div>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="mobile-menu hidden">
    <nav class="mobile-nav">

      <!-- Funcionalidades -->
      <div class="mobile-section">
        <button class="mobile-section-toggle" aria-expanded="false">
          Funcionalidades
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="chevron"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mobile-section-body hidden">
          {funcionalidades.map(({ href, label, icon }) => (
            <a href={href} class="mobile-link mobile-link-sub">
              <span>{icon}</span> {label}
            </a>
          ))}
        </div>
      </div>

      <!-- Para quién -->
      <div class="mobile-section">
        <button class="mobile-section-toggle" aria-expanded="false">
          Para quién
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="chevron"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mobile-section-body hidden">
          {paraQuien.map(({ href, label }) => (
            <a href={href} class="mobile-link mobile-link-sub">{label}</a>
          ))}
        </div>
      </div>

      <a href="/planes"   class="mobile-link">Precios</a>
      <a href="/nosotros" class="mobile-link">Nosotros</a>
      <a href="/contacto" class="mobile-link">Contacto</a>
    </nav>

    <div class="mobile-ctas">
      <Button variant="ghost"   size="md" href="https://app.agendadr.com/login">Iniciar sesión</Button>
      <Button variant="primary" size="md" href="https://app.agendadr.com/registro">Empezar gratis</Button>
    </div>
  </div>
</header>

<style>
  /* ── Base ── */
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
  }

  .header-inner {
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  :global(html.dark) .header-inner {
    background: rgba(15,23,42,0.85);
    border-bottom-color: rgba(255,255,255,0.06);
  }

  .header-content {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  /* ── Logo ── */
  .logo { text-decoration: none; flex-shrink: 0; }
  .logo-text {
    font-family: 'Cal Sans', Inter, sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: #0f172a;
  }
  :global(html.dark) .logo-text { color: #f1f5f9; }
  .logo-accent { color: #03BB85; }

  /* ── Nav desktop ── */
  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
  }

  @media (max-width: 768px) {
    .nav-desktop { display: none; }
  }

  .nav-link {
    padding: 6px 12px;
    font-size: 14px;
    font-weight: 500;
    color: #475569;
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .nav-link:hover { color: #0f172a; background: rgba(0,0,0,0.04); }
  :global(html.dark) .nav-link { color: #94a3b8; }
  :global(html.dark) .nav-link:hover { color: #f1f5f9; background: rgba(255,255,255,0.06); }

  /* ── Dropdown trigger ── */
  .nav-item {
    position: relative;
  }

  .nav-trigger {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 6px 12px;
    font-size: 14px;
    font-weight: 500;
    color: #475569;
    background: none;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
    font-family: inherit;
  }
  .nav-trigger:hover { color: #0f172a; background: rgba(0,0,0,0.04); }
  :global(html.dark) .nav-trigger { color: #94a3b8; }
  :global(html.dark) .nav-trigger:hover { color: #f1f5f9; background: rgba(255,255,255,0.06); }

  .nav-trigger.active { color: #0f172a; }
  :global(html.dark) .nav-trigger.active { color: #f1f5f9; }

  .chevron {
    transition: transform 0.2s ease;
  }
  .nav-trigger.active .chevron,
  .nav-trigger[aria-expanded="true"] .chevron {
    transform: rotate(180deg);
  }

  /* ── Dropdown panel ── */
  .nav-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.10);
    padding: 8px;
    z-index: 100;
    animation: dropIn 0.15s ease-out;
  }

  :global(html.dark) .nav-dropdown {
    background: #1e293b;
    border-color: #334155;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }

  .nav-dropdown.open { display: block; }

  @keyframes dropIn {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .dropdown-wide  { width: 400px; }
  .dropdown-narrow { width: 220px; }

  .dropdown-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    font-size: 13px;
    font-weight: 500;
    color: #374151;
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.1s, color 0.1s;
    white-space: nowrap;
  }
  .dropdown-item:hover { background: #f8fafc; color: #0f172a; }
  :global(html.dark) .dropdown-item { color: #cbd5e1; }
  :global(html.dark) .dropdown-item:hover { background: #334155; color: #f1f5f9; }

  .dropdown-icon {
    font-size: 15px;
    line-height: 1;
    flex-shrink: 0;
  }

  /* ── CTAs ── */
  .nav-ctas {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
    margin-left: auto;
  }

  @media (max-width: 768px) { .nav-ctas { display: none; } }

  /* ── Hamburger ── */
  .hamburger {
    display: none;
    padding: 8px;
    border-radius: 8px;
    border: none;
    background: none;
    color: #475569;
    cursor: pointer;
    margin-left: auto;
  }
  .hamburger:hover { background: #f1f5f9; }
  :global(html.dark) .hamburger { color: #94a3b8; }
  :global(html.dark) .hamburger:hover { background: #1e293b; }

  @media (max-width: 768px) { .hamburger { display: flex; } }

  /* ── Mobile menu ── */
  .mobile-menu {
    background: #ffffff;
    border-top: 1px solid #f1f5f9;
  }
  :global(html.dark) .mobile-menu {
    background: #0f172a;
    border-top-color: #1e293b;
  }

  .mobile-nav {
    padding: 12px 24px 8px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mobile-link {
    display: block;
    padding: 10px 12px;
    font-size: 15px;
    font-weight: 500;
    color: #374151;
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.1s;
  }
  .mobile-link:hover { background: #f8fafc; }
  :global(html.dark) .mobile-link { color: #cbd5e1; }
  :global(html.dark) .mobile-link:hover { background: #1e293b; }

  .mobile-link-sub {
    font-size: 14px;
    font-weight: 400;
    color: #64748b;
    padding-left: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  :global(html.dark) .mobile-link-sub { color: #94a3b8; }

  .mobile-section-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px;
    font-size: 15px;
    font-weight: 500;
    color: #374151;
    background: none;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.1s;
  }
  .mobile-section-toggle:hover { background: #f8fafc; }
  :global(html.dark) .mobile-section-toggle { color: #cbd5e1; }
  :global(html.dark) .mobile-section-toggle:hover { background: #1e293b; }

  .mobile-section-toggle.open .chevron { transform: rotate(180deg); }

  .mobile-ctas {
    padding: 12px 24px 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    border-top: 1px solid #f1f5f9;
    margin-top: 4px;
  }
  :global(html.dark) .mobile-ctas { border-top-color: #1e293b; }
</style>

<script>
  // ── Dropdown toggle (desktop) ──
  const dropItems = document.querySelectorAll('.nav-item');

  dropItems.forEach((item) => {
    const trigger = item.querySelector('.nav-trigger') as HTMLButtonElement;
    const dropdown = item.querySelector('.nav-dropdown') as HTMLElement;
    if (!trigger || !dropdown) return;

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = dropdown.classList.contains('open');
      // Close all
      document.querySelectorAll('.nav-dropdown').forEach(d => d.classList.remove('open'));
      document.querySelectorAll('.nav-trigger').forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        dropdown.classList.add('open');
        trigger.classList.add('active');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Close on outside click
  document.addEventListener('click', () => {
    document.querySelectorAll('.nav-dropdown').forEach(d => d.classList.remove('open'));
    document.querySelectorAll('.nav-trigger').forEach(t => {
      t.classList.remove('active');
      t.setAttribute('aria-expanded', 'false');
    });
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.nav-dropdown').forEach(d => d.classList.remove('open'));
      document.querySelectorAll('.nav-trigger').forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-expanded', 'false');
      });
    }
  });

  // ── Mobile hamburger ──
  const toggle = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    iconOpen.classList.toggle('hidden', isOpen);
    iconClose.classList.toggle('hidden', !isOpen);
  });

  // ── Mobile section toggles ──
  document.querySelectorAll('.mobile-section-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const body = btn.nextElementSibling as HTMLElement;
      const isOpen = !body.classList.contains('hidden');
      body.classList.toggle('hidden', isOpen);
      btn.classList.toggle('open', !isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  // Close mobile menu on link click
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
