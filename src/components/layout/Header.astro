  }
  .whatsapp-link:hover {
    background: #1ebe5d;
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(37,211,102,0.45);
  }
  :global(html.dark) .whatsapp-link {
    background: #1a9e4a;
    box-shadow: 0 2px 8px rgba(37,211,102,0.2);
  }
  :global(html.dark) .whatsapp-link:hover {
