  }
  .mobile-login-link strong { color: #475569; font-weight: 600; }
  .mobile-login-link:hover { color: #03BB85; }
  .mobile-login-link:hover strong { color: #03BB85; }
  :global(html.dark) .mobile-login-link { color: #64748b; }
  :global(html.dark) .mobile-login-link strong { color: #94a3b8; }
  :global(html.dark) .mobile-login-link:hover,
  :global(html.dark) .mobile-login-link:hover strong { color: #4CE5B5; }

  /* Botón "Ver planes" en el drawer */
  .drawer-planes-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 700;
    color: #03BB85;
    background: #f0fdf9;
    border: 1px solid #a7f3d0;
    text-decoration: none;
    transition: background 0.15s, color 0.15s, transform 0.12s;
  }
  .drawer-planes-btn:hover { background: #d1fae5; color: #047857; transform: translateY(-1px); }
  :global(html.dark) .drawer-planes-btn {
    background: rgba(3,187,133,0.08);
    border-color: rgba(3,187,133,0.22);
    color: #4CE5B5;
  }
  :global(html.dark) .drawer-planes-btn:hover { background: rgba(3,187,133,0.15); }

  /* ── Botón flotante WhatsApp ── */
  .wa-float {
    position: fixed;
    bottom: 24px;
    right: 20px;
    z-index: 99;
    display: flex;
    align-items: center;
    gap: 10px;
    background: #25D366;
    color: #ffffff;
    border-radius: 999px;
    padding: 14px;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(37,211,102,0.45), 0 1px 4px rgba(0,0,0,0.1);
    transition: transform 0.2s ease, box-shadow 0.2s ease, padding 0.3s ease;
    /* Entra con animación diferida (3s) */
    opacity: 0;
    animation: wa-enter 0.5s cubic-bezier(0.34,1.56,0.64,1) 3s forwards;
  }
  .wa-float:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 8px 28px rgba(37,211,102,0.55), 0 2px 6px rgba(0,0,0,0.12);
  }

  .wa-icon { flex-shrink: 0; }

  .wa-label { display: none; }

  @keyframes wa-enter {
    from { opacity: 0; transform: translateY(16px) scale(0.85); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .wa-float { animation: none; opacity: 1; }
  }

  /* ── Cascade animation ── */
  .mobile-nav > *,
  .drawer-separator,
  .drawer-promo,
  .mobile-ctas {
    opacity: 0;
    transform: translateX(-14px);
    transition: opacity 0.22s ease, transform 0.22s ease;
  }
  .mobile-menu.menu-open .mobile-nav > *:nth-child(1) { opacity:1; transform:none; transition-delay:0.10s; }
  .mobile-menu.menu-open .mobile-nav > *:nth-child(2) { opacity:1; transform:none; transition-delay:0.14s; }
  .mobile-menu.menu-open .mobile-nav > *:nth-child(3) { opacity:1; transform:none; transition-delay:0.18s; }
  .mobile-menu.menu-open .mobile-nav > *:nth-child(4) { opacity:1; transform:none; transition-delay:0.21s; }
  .mobile-menu.menu-open .mobile-nav > *:nth-child(5) { opacity:1; transform:none; transition-delay:0.24s; }
  .mobile-menu.menu-open .drawer-separator            { opacity:1; transform:none; transition-delay:0.26s; }
  .mobile-menu.menu-open .drawer-promo               { opacity:1; transform:none; transition-delay:0.29s; }
  .mobile-menu.menu-open .mobile-ctas                { opacity:1; transform:none; transition-delay:0.34s; }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu { transition: none; }
    .mobile-backdrop { transition: none; }
    .mobile-nav > *, .drawer-separator, .drawer-promo, .mobile-ctas {
      opacity:1; transform:none; transition:none;
    }
    .trust-dot { animation: none; }
    @keyframes pulse-dot { 0%, 100% { box-shadow: none; } }
  }
</style>

<script>
  // ── Scroll: sombra en header ──
  const header = document.getElementById('header')!;
  window.addEventListener('scroll', () => {
    header.classList.toggle('header-scrolled', window.scrollY > 20);
  }, { passive: true });

  // ── Theme toggle ──
  function applyTheme(dark: boolean) {
    document.documentElement.classList.toggle('dark', dark);
    try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (_) {}
  }
  function initThemeBtn(btn: HTMLElement | null) {
    if (!btn) return;
    btn.addEventListener('click', () => {
      applyTheme(!document.documentElement.classList.contains('dark'));
    });
  }
  initThemeBtn(document.getElementById('theme-toggle'));
  initThemeBtn(document.getElementById('theme-toggle-mobile'));

  // ── Dropdown desktop (hover + click) ──
  function closeAll() {
    document.querySelectorAll('.nav-dropdown').forEach(d => d.classList.remove('open'));
    document.querySelectorAll('.nav-trigger').forEach(t => {
      t.classList.remove('active');
      t.setAttribute('aria-expanded', 'false');
    });
  }
  function openDropdown(trigger: HTMLButtonElement, dropdown: HTMLElement) {
    closeAll();
    dropdown.classList.add('open');
    trigger.classList.add('active');
    trigger.setAttribute('aria-expanded', 'true');
  }
  document.querySelectorAll('.nav-item').forEach((item) => {
    const trigger  = item.querySelector('.nav-trigger') as HTMLButtonElement;
    const dropdown = item.querySelector('.nav-dropdown') as HTMLElement;
    if (!trigger || !dropdown) return;
    item.addEventListener('mouseenter', () => openDropdown(trigger, dropdown));
    item.addEventListener('mouseleave', closeAll);
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdown.classList.contains('open') ? closeAll() : openDropdown(trigger, dropdown);
    });
  });
  document.addEventListener('click', closeAll);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAll(); });

  // ── Mobile drawer ──
  const toggle     = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const backdrop   = document.getElementById('mobile-backdrop')!;
  const drawerClose = document.getElementById('drawer-close')!;
  const iconOpen   = document.getElementById('icon-open')!;
  const iconClose  = document.getElementById('icon-close')!;

  function openMenu() {
    mobileMenu.classList.add('menu-open');
    backdrop.classList.add('backdrop-open');
    toggle.setAttribute('aria-expanded', 'true');
    iconOpen.classList.add('hidden');
    iconClose.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    mobileMenu.classList.remove('menu-open');
    backdrop.classList.remove('backdrop-open');
    toggle.setAttribute('aria-expanded', 'false');
    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
    document.body.style.overflow = '';
  }

  toggle.addEventListener('click', () => {
    mobileMenu.classList.contains('menu-open') ? closeMenu() : openMenu();
  });
  backdrop.addEventListener('click', closeMenu);
  drawerClose.addEventListener('click', closeMenu);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });

  // ── Accordion secciones mobile ──
  document.querySelectorAll('.mobile-section-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const body = btn.nextElementSibling as HTMLElement;
      const isOpen = !body.classList.contains('hidden');
      body.classList.toggle('hidden', isOpen);
      btn.classList.toggle('open', !isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  // Cerrar drawer al navegar
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
