    line-height: 1;
  }
  .rating-text {
    font-size: 12px;
    color: #64748b;
  }
  .rating-text strong { color: #374151; font-weight: 700; }
  :global(html.dark) .rating-text { color: #94a3b8; }
  :global(html.dark) .rating-text strong { color: #cbd5e1; }

  /* Quick wins pills */
  .quick-wins {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    padding: 8px 0 0;
  }
  .quick-pill {
    font-size: 11px;
    font-weight: 600;
    color: #047857;
    background: #ecfdf5;
    border: 1px solid #a7f3d0;
    border-radius: 999px;
    padding: 3px 9px;
    white-space: nowrap;
  }
  :global(html.dark) .quick-pill {
