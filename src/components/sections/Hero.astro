---
import { Spotlight } from '../animations/Spotlight';
import { ShimmerButton } from '../animations/ShimmerButton';
---

<section
  id="hero"
  class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden bg-slate-950 px-6 pt-24 pb-16"
>
  <!-- Spotlights -->
  <Spotlight
    client:load
    className="-top-40 left-0 h-[80vh] w-[50vw] md:-top-20 md:left-20"
    fill="#03BB85"
  />
  <Spotlight
    client:load
    className="top-10 right-0 h-[60vh] w-[40vw] md:right-20"
    fill="#5AC0F9"
  />

  <!-- Grid pattern fondo sutil -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.03]"
    style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 64px 64px;"
    aria-hidden="true"
  />

  <!-- Contenido -->
  <div class="relative z-10 mx-auto max-w-4xl text-center">

    <!-- Badge -->
    <div
      class="mb-8 inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-4 py-1.5 text-sm font-medium text-primary"
      style="animation: fadeInUp 0.6s ease-out 0.2s both;"
    >
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-primary"></span>
      </span>
      Nuevo — Recordatorios automáticos por WhatsApp
    </div>

    <!-- Headline -->
    <h1
      class="h1 text-white"
      style="animation: fadeInUp 0.6s ease-out 0.35s both;"
    >
      La agenda médica que{' '}
      <span
        class="relative inline-block"
        style="background: linear-gradient(135deg, #03BB85 0%, #5AC0F9 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
      >
        trabaja por ti
      </span>
    </h1>

    <!-- Subtítulo -->
    <p
      class="body-lg mx-auto mt-6 max-w-2xl text-slate-400"
      style="animation: fadeInUp 0.6s ease-out 0.5s both;"
    >
      Gestiona citas, envía recordatorios automáticos y mantén el historial de tus pacientes en un solo lugar.
      Sin complicaciones. Diseñado para el rubro médico peruano.
    </p>

    <!-- CTAs -->
    <div
      class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row"
      style="animation: fadeInUp 0.6s ease-out 0.65s both;"
    >
      <ShimmerButton client:load href="#registro">
        Empezar gratis
        <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </ShimmerButton>

      <a
        href="#how-it-works"
        class="group inline-flex items-center gap-2 rounded-lg px-8 py-4 text-base font-semibold text-slate-300 transition-colors duration-150 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/30"
      >
        <svg class="h-5 w-5 rounded-full border border-slate-600 p-0.5 transition-colors group-hover:border-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Ver cómo funciona
      </a>
    </div>

    <!-- Trust line -->
    <p
      class="mt-5 text-sm text-slate-600"
      style="animation: fadeInUp 0.6s ease-out 0.75s both;"
    >
      Sin tarjeta de crédito &nbsp;·&nbsp; 30 días gratis &nbsp;·&nbsp; Soporte en español
    </p>
  </div>

  <!-- Stats -->
  <div
    class="relative z-10 mx-auto mt-20 grid w-full max-w-2xl grid-cols-3 gap-px overflow-hidden rounded-2xl border border-white/10 bg-white/10"
    style="animation: fadeInUp 0.6s ease-out 0.9s both;"
  >
    {
      [
        { value: '500+', label: 'Médicos activos' },
        { value: '50k+', label: 'Citas gestionadas' },
        { value: '60%', label: 'Menos inasistencias' },
      ].map(({ value, label }) => (
        <div class="flex flex-col items-center justify-center bg-slate-900/80 px-4 py-6 backdrop-blur-sm">
          <span class="font-display text-2xl font-semibold text-white sm:text-3xl">{value}</span>
          <span class="mt-1 text-xs text-slate-500 sm:text-sm">{label}</span>
        </div>
      ))
    }
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2"
    style="animation: fadeInUp 0.6s ease-out 1.1s both;"
    aria-hidden="true"
  >
    <div class="flex h-10 w-6 items-start justify-center rounded-full border border-white/20 p-1.5">
      <div
        class="h-2 w-1 rounded-full bg-white/40"
        style="animation: scrollDot 1.5s ease-in-out infinite;"
      />
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes scrollDot {
    0%, 100% { transform: translateY(0); opacity: 0.4; }
    50%       { transform: translateY(6px); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    * { animation: none !important; }
  }
</style>
